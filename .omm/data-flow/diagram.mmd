graph LR
    user-action["User Action\n(miniprogram)"]
    backend-api["Backend API\nbackend/src/"]
    mongodb["MongoDB\n(primary)"]
    redis-queue["Redis Queue\nbackend/src/utils/redis.js"]
    sync-service["Sync Service\nbackend/src/services/sync.service.js"]
    mysql["MySQL\n(replica)"]
    backup-service["Backup Service\nbackend/src/services/backup.service.js"]
    backup-files["Backup Files\nbackups/"]

    classDef store fill:#a6e3a1,stroke:#a6e3a1,color:#1e1e2e
    classDef entry fill:#89b4fa,stroke:#89b4fa,color:#1e1e2e
    class mongodb,mysql,backup-files store
    class user-action entry

    user-action -->|"write operation"| backend-api
    backend-api -->|"persist"| mongodb
    mongodb -->|"change event"| sync-service
    sync-service -->|"enqueue"| redis-queue
    redis-queue -->|"dequeue + write"| mysql
    backend-api -->|"schedule 02:00/02:30"| backup-service
    backup-service -->|"dump"| backup-files
