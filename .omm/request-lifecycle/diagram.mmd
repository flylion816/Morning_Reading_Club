graph LR
    client["Client\n(miniprogram / admin)"]
    express-router["Express Router\nbackend/src/routes/"]
    auth-mw["Auth Middleware\nbackend/src/middleware/auth.js"]
    tenant-mw["Tenant Context MW\nbackend/src/middleware/tenantContext.js"]
    controller["Controller\nbackend/src/controllers/"]
    service["Service\nbackend/src/services/"]
    model["Model + tenantPlugin\nbackend/src/models/"]
    cache["Cache\nbackend/src/utils/cache-helper.js"]
    db["MongoDB"]

    classDef entry fill:#89b4fa,stroke:#89b4fa,color:#1e1e2e
    classDef store fill:#a6e3a1,stroke:#a6e3a1,color:#1e1e2e
    class client entry
    class db store

    client -->|"HTTPS request + token + X-Wx-AppId"| express-router
    express-router -->|"verify JWT"| auth-mw
    auth-mw -->|"inject tenantId via AsyncLocalStorage"| tenant-mw
    tenant-mw -->|"validated request"| controller
    controller -->|"check cache"| cache
    cache -->|"cache miss: call service"| service
    service -->|"query with auto tenantId filter"| model
    model -->|"read/write"| db
    db -->|"result"| model
    model -->|"data"| service
    service -->|"result"| controller
    controller -->|"JSON response"| client
