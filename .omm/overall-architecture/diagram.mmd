graph LR
    miniprogram["WeChat Miniprogram\nminiprogram/"]
    admin["Admin Dashboard\nadmin/"]
    backend["Backend API\nbackend/src/"]
    mongodb["MongoDB\n(primary store)"]
    mysql["MySQL\n(sync/backup)"]
    redis["Redis\n(cache/pubsub)"]
    wechat-platform["WeChat Platform\n(external)"]

    classDef external fill:#585b70,stroke:#585b70,color:#cdd6f4
    classDef store fill:#a6e3a1,stroke:#a6e3a1,color:#1e1e2e
    classDef entry fill:#89b4fa,stroke:#89b4fa,color:#1e1e2e

    class wechat-platform external
    class mongodb,mysql,redis store
    class miniprogram,admin entry

    miniprogram -->|"HTTPS REST API + WebSocket"| backend
    admin -->|"HTTPS REST API"| backend
    backend -->|"read/write"| mongodb
    backend -->|"sync/backup"| mysql
    backend -->|"cache/pubsub"| redis
    backend -->|"OAuth login, subscribe msg"| wechat-platform
    miniprogram -->|"OAuth login"| wechat-platform
