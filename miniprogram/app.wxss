/**
 * 晨读营小程序 - 全局样式
 */
@import './theme.wxss';

/* 全局样式重置 */
page {
  --app-page-bg: #f3f6ef;
  --app-page-bg-deep: #e9efe7;
  --app-paper: #fffefa;
  --app-paper-muted: #f7f6ed;
  --app-surface: #ffffff;
  --app-surface-muted: #f8faf4;
  --app-text: #172019;
  --app-text-soft: #526055;
  --app-text-muted: #8a948b;
  --app-border: rgba(49, 72, 56, 0.1);
  --app-rule: rgba(49, 72, 56, 0.14);
  --app-shadow: 0 14rpx 34rpx rgba(37, 60, 43, 0.07);
  --app-shadow-soft: 0 8rpx 20rpx rgba(37, 60, 43, 0.04);
  --app-inner-line: inset 0 1rpx 0 rgba(255, 255, 255, 0.74);
  background-color: var(--app-page-bg);
  font-family: 'PingFang SC', 'HarmonyOS Sans SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 28rpx;
  color: var(--app-text);
  line-height: 1.5;
  font-variant-numeric: tabular-nums;
}

view {
  box-sizing: border-box;
}

/* 通用工具类 */
.flex {
  display: flex;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.text-center {
  text-align: center;
}

.hidden {
  display: none;
}
