.reading-loader {
  width: 100%;
  min-height: 300rpx;
  padding: 96rpx 0 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.reading-book {
  width: 148rpx;
  height: 94rpx;
  position: relative;
  perspective: 420rpx;
}

.book-page {
  position: absolute;
  top: 0;
  width: 74rpx;
  height: 94rpx;
  padding: 22rpx 12rpx;
  background: var(--app-paper);
  border: 1rpx solid rgba(49, 72, 56, 0.12);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.8);
  overflow: hidden;
}

.book-page-left {
  left: 0;
  border-radius: 16rpx 4rpx 4rpx 16rpx;
  transform-origin: right center;
}

.book-page-right {
  right: 0;
  border-radius: 4rpx 16rpx 16rpx 4rpx;
  transform-origin: left center;
}

.book-page-flip {
  left: 74rpx;
  border-radius: 4rpx 16rpx 16rpx 4rpx;
  transform-origin: left center;
  animation: reading-page-flip 1.8s ease-in-out infinite;
  z-index: 3;
}

.book-spine {
  position: absolute;
  left: 70rpx;
  top: 8rpx;
  width: 8rpx;
  height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  opacity: 0.54;
  z-index: 4;
}

.page-line {
  height: 4rpx;
  margin-bottom: 10rpx;
  border-radius: 999rpx;
  background: rgba(49, 72, 56, 0.16);
}

.page-line-long {
  width: 42rpx;
}

.page-line-mid {
  width: 36rpx;
}

.page-line-short {
  width: 28rpx;
}

.reading-loader-text {
  margin-top: 28rpx;
  font-size: 26rpx;
  color: var(--app-text-soft);
  line-height: 1.5;
}

.reading-dots {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.reading-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--theme-primary);
  opacity: 0.28;
  animation: reading-dot-pulse 1.4s ease-in-out infinite;
}

.reading-dot-two {
  animation-delay: 0.18s;
}

.reading-dot-three {
  animation-delay: 0.36s;
}

@keyframes reading-page-flip {
  0% {
    transform: rotateY(0deg);
    opacity: 1;
  }

  45% {
    transform: rotateY(-145deg);
    opacity: 0.9;
  }

  70% {
    transform: rotateY(-180deg);
    opacity: 0;
  }

  100% {
    transform: rotateY(-180deg);
    opacity: 0;
  }
}

@keyframes reading-dot-pulse {
  0%,
  100% {
    transform: translateY(0);
    opacity: 0.24;
  }

  50% {
    transform: translateY(-4rpx);
    opacity: 0.68;
  }
}
