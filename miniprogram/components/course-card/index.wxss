.course-card {
  --app-paper: #fffefa;
  --app-surface-muted: #f8faf7;
  --app-text: #17221b;
  --app-text-soft: #516055;
  --app-text-muted: #8b968f;
  background:
    linear-gradient(135deg, rgba(255, 254, 250, 0.98) 0%, var(--app-surface-muted) 100%);
  border-radius: 22rpx;
  padding: 30rpx;
  margin-bottom: 0;
  display: flex;
  gap: 24rpx;
  transition: transform 0.24s ease, background 0.24s ease;
  position: relative;
}

.course-card:active {
  transform: translateY(2rpx) scale(0.995);
  background:
    linear-gradient(135deg, rgba(255, 254, 250, 0.92) 0%, #f0f4ec 100%);
}

.course-card.pending {
  background:
    linear-gradient(135deg, var(--theme-primary-tint) 0%, var(--app-paper) 46%, var(--app-surface-muted) 100%);
}

/* 左侧缩略图 */
.course-thumb {
  width: 126rpx;
  height: 156rpx;
  flex-shrink: 0;
  background:
    radial-gradient(circle at 30% 20%, rgba(255,255,255,0.28) 0, rgba(255,255,255,0) 68rpx),
    linear-gradient(145deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.2);
  position: relative;
  overflow: hidden;
}

.course-thumb::before {
  display: none;
}

.thumb-icon {
  font-size: 58rpx;
  position: relative;
  z-index: 1;
}

/* 右侧内容区 */
.course-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.course-title {
  font-weight: 600;
  color: var(--app-text);
  font-size: 31rpx;
  margin-bottom: 10rpx;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.course-meta {
  font-size: 24rpx;
  color: var(--app-text-muted);
  margin-bottom: 18rpx;
}

/* 进度条区域 */
.course-progress {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.progress-bar {
  height: 7rpx;
  background: rgba(49, 72, 56, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
  box-shadow: inset 0 2rpx 4rpx rgba(37, 60, 43, 0.05);
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-fill-active {
  background: linear-gradient(90deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  box-shadow: none;
}

.progress-fill-done {
  background: #b8c2bb;
}

.course-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.course-actions.period-mode {
  justify-content: flex-end;
}

.status-text {
  font-size: 24rpx;
  color: var(--app-text-soft);
  flex: 1;
}

.status-text.status-right {
  flex: none;
  text-align: right;
  font-weight: 400;
  color: var(--app-text-muted);
}

.status-text.status-not_started,
.status-text.status-ongoing {
  color: var(--theme-primary);
}

.action-btn {
  padding: 8rpx 24rpx;
  border-radius: 14rpx;
  font-size: 24rpx;
  border: none;
  transition: all 0.3s;
  flex-shrink: 0;
  margin-left: auto;
}

.action-btn.primary {
  background: linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  color: #ffffff;
}

.action-btn.secondary {
  background: transparent;
  color: var(--theme-primary);
  border: 2rpx solid var(--theme-primary);
}

.action-btn.secondary::after {
  border: none;
}
