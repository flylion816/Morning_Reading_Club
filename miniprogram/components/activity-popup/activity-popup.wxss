.popup-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.popup-card {
  background: #fff;
  border-radius: 28rpx;
  width: 620rpx;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.25);
}

/* 海报区域 */
.popup-poster-wrap {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.popup-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.popup-cover-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
}

/* X 按钮 */
.popup-close-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 52rpx;
  height: 52rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 50%;
  color: #fff;
  font-size: 26rpx;
  line-height: 52rpx;
  text-align: center;
  backdrop-filter: blur(4px);
}

/* 类型标签叠在海报左下角 */
.popup-type-tag {
  position: absolute;
  bottom: 20rpx;
  left: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  color: var(--theme-primary);
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

/* 内容区 */
.popup-body {
  padding: 32rpx 32rpx 20rpx;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.45;
  margin-bottom: 14rpx;
}

.popup-time {
  font-size: 26rpx;
  color: #888;
}

/* 操作栏 */
.popup-actions {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx 32rpx;
  gap: 16rpx;
}

.popup-btn-close-text {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #bbb;
  padding: 20rpx 0;
}

.popup-btn-detail {
  flex: 2;
  text-align: center;
  background: linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 16rpx;
  line-height: 1;
}
