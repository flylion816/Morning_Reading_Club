.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.56);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

.popup-card {
  background: #fff;
  border-radius: 24rpx;
  width: 100%;
  max-width: 620rpx;
  overflow: hidden;
  box-shadow: 0 24rpx 70rpx rgba(15, 23, 42, 0.26);
}

.popup-poster-wrap {
  position: relative;
  width: 100%;
  height: 240rpx;
  overflow: hidden;
  background: #f6f8fb;
}

.popup-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.popup-poster-shade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 96rpx;
  background: linear-gradient(180deg, rgba(15, 23, 42, 0) 0%, rgba(15, 23, 42, 0.38) 100%);
}

.popup-compact-head {
  position: relative;
  min-height: 92rpx;
  padding: 28rpx 88rpx 8rpx 32rpx;
  background: linear-gradient(180deg, var(--theme-primary-alpha-08) 0%, rgba(255, 255, 255, 0) 100%);
}

.popup-head-line {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 8rpx;
  background: var(--theme-primary);
}

.popup-close-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 52rpx;
  height: 52rpx;
  background: rgba(15, 23, 42, 0.34);
  border-radius: 50%;
  color: #fff;
  font-size: 28rpx;
  line-height: 52rpx;
  text-align: center;
  backdrop-filter: blur(4px);
}

.popup-close-btn-plain {
  top: 22rpx;
  right: 24rpx;
  background: var(--theme-primary-alpha-12);
  color: var(--theme-primary);
  backdrop-filter: none;
}

.popup-type-tag {
  position: absolute;
  bottom: 18rpx;
  left: 20rpx;
  background: rgba(255, 255, 255, 0.92);
  color: var(--theme-primary);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  padding: 9rpx 18rpx;
  border-radius: 20rpx;
}

.popup-type-tag-plain {
  position: static;
  display: inline-flex;
  align-items: center;
  background: var(--theme-primary-tint);
  border: 1rpx solid var(--theme-primary-alpha-20);
}

.popup-body {
  padding: 18rpx 32rpx 18rpx;
}

.popup-kicker {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: var(--theme-primary);
  font-size: 23rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
}

.popup-kicker-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--theme-primary);
  box-shadow: 0 0 0 8rpx var(--theme-primary-alpha-12);
}

.popup-title {
  font-size: 33rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.38;
  margin-bottom: 18rpx;
}

.popup-time {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  font-size: 26rpx;
  color: #6b7280;
}

.popup-time-label {
  flex-shrink: 0;
  color: #9ca3af;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.popup-actions {
  display: flex;
  align-items: center;
  padding: 16rpx 28rpx 28rpx;
  gap: 16rpx;
  border-top: 1rpx solid #f1f5f9;
}

.popup-btn-close-text {
  flex: 0 0 176rpx;
  text-align: center;
  font-size: 25rpx;
  color: #9ca3af;
  padding: 22rpx 0;
  line-height: 1;
}

.popup-btn-detail {
  flex: 1;
  text-align: center;
  background: var(--theme-primary);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 24rpx 20rpx;
  border-radius: 14rpx;
  line-height: 1;
  box-shadow: 0 10rpx 24rpx var(--theme-primary-alpha-22);
}

.popup-btn-detail:active {
  background: var(--theme-primary-dark);
}

@media (max-width: 340px) {
  .popup-mask {
    padding: 32rpx;
  }

  .popup-actions {
    padding-left: 24rpx;
    padding-right: 24rpx;
  }

  .popup-btn-close-text {
    flex-basis: 156rpx;
    font-size: 24rpx;
  }
}
