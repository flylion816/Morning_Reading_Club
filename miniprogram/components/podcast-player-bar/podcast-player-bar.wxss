.podcast-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  background: #1c1917;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  height: calc(112rpx + constant(safe-area-inset-bottom));
  height: calc(112rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.3);
}

.podcast-bar-elevated {
  height: 112rpx;
  padding-bottom: 0;
}

.podcast-bar-visible {
  transform: translateY(0);
}

.podcast-bar-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
  margin-right: 24rpx;
}

.podcast-bar-play-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.podcast-bar-pause-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
}

.podcast-bar-pause-bar {
  width: 5rpx;
  height: 24rpx;
  background: #fff;
  border-radius: 3rpx;
}

.podcast-bar-play-icon {
  font-size: 28rpx;
  color: #fff;
}

.podcast-bar-info {
  flex: 1;
  overflow: hidden;
}

.podcast-bar-title {
  display: block;
  font-size: 26rpx;
  color: #f5f5f4;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.podcast-bar-progress-track {
  height: 4rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 2rpx;
  overflow: hidden;
}

.podcast-bar-progress-fill {
  height: 100%;
  background: #f97316;
  border-radius: 2rpx;
  transition: width 0.5s linear;
}

.podcast-bar-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.podcast-bar-close-icon {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}
