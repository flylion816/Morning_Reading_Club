.page-checkin-records {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7fbff 0%, #f5f7fb 35%, #f5f5f5 100%);
  padding: 24rpx;
  box-sizing: border-box;
}

.hero-card {
  padding: 28rpx 28rpx 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ffffff 0%, #f4f8ff 100%);
  box-shadow: 0 16rpx 40rpx rgba(74, 144, 226, 0.08);
}

.hero-user {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.hero-avatar-wrap {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  background: linear-gradient(135deg, #4a90e2 0%, #7fb1ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-avatar-image {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.hero-avatar-text {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
}

.hero-user-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.hero-user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d2433;
}

.hero-user-subtitle {
  font-size: 24rpx;
  color: #8c97a8;
}

.hero-stats {
  margin-top: 24rpx;
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  padding: 10rpx 8rpx 0;
}

.hero-stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.hero-stat-divider {
  width: 1rpx;
  background: rgba(74, 144, 226, 0.12);
  margin: 4rpx 20rpx 0;
}

.hero-stat-value {
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #2a5bd7;
}

.hero-stat-label {
  font-size: 24rpx;
  color: #8c97a8;
}

.section-block {
  margin-top: 24rpx;
  padding-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1d2433;
  margin: 4rpx 2rpx 18rpx;
}

.period-scroll {
  width: 100%;
  white-space: nowrap;
  box-sizing: border-box;
}

.period-scroll-inner {
  display: flex;
  gap: 18rpx;
  align-items: stretch;
  padding: 6rpx 2rpx 18rpx;
  box-sizing: border-box;
}

.period-card {
  width: 286rpx;
  min-height: 110rpx;
  flex-shrink: 0;
  display: flex;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid transparent;
  box-shadow: 0 10rpx 26rpx rgba(18, 46, 89, 0.06);
  box-sizing: border-box;
}

.period-card-active {
  border-color: #4a90e2;
  box-shadow: 0 16rpx 36rpx rgba(74, 144, 226, 0.16);
}

.period-card-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.period-card-icon-text {
  font-size: 38rpx;
}

.period-card-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.period-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1d2433;
  line-height: 1.2;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.period-card-subtitle {
  font-size: 22rpx;
  line-height: 1.35;
  color: #8c97a8;
}

.selected-period-banner {
  margin: 10rpx 0 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eef5ff 100%);
  border: 1rpx solid rgba(74, 144, 226, 0.12);
  display: flex;
  align-items: center;
  gap: 22rpx;
  box-sizing: border-box;
}

.selected-period-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.selected-period-icon-text {
  font-size: 36rpx;
}

.selected-period-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-left: 4rpx;
}

.selected-period-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1d2433;
}

.selected-period-line {
  font-size: 22rpx;
  color: #708096;
}

.selected-period-arrow {
  font-size: 36rpx;
  color: #c3ccdb;
}

.records-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.record-row {
  display: flex;
  gap: 16rpx;
}

.record-date-col {
  width: 72rpx;
  flex-shrink: 0;
  padding-top: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.record-day {
  font-size: 40rpx;
  line-height: 1;
  font-weight: 700;
  color: #1d2433;
}

.record-month {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8c97a8;
}

.record-card {
  flex: 1;
  padding: 22rpx 22rpx 20rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(18, 46, 89, 0.06);
}

.record-header {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-bottom: 16rpx;
}

.record-avatar-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.record-avatar-image {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.record-avatar-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 700;
}

.record-header-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.record-user-name {
  font-size: 28rpx;
  color: #1d2433;
  font-weight: 700;
}

.record-header-subtitle {
  font-size: 22rpx;
  color: #8c97a8;
}

.record-more {
  color: #c3ccdb;
  font-size: 36rpx;
  line-height: 1;
}

.record-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #3b4657;
  white-space: pre-wrap;
  word-break: break-word;
}

.record-content-empty {
  color: #9aa5b4;
}

.record-footer {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.record-meta {
  font-size: 22rpx;
  color: #8c97a8;
}

.record-like {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #8c97a8;
}

.record-like-icon {
  font-size: 24rpx;
  color: #ea4f4f;
}

.record-like-count {
  font-size: 22rpx;
}

.empty-state {
  margin-top: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
  padding: 40rpx 0 28rpx;
}

.empty-state-icon {
  font-size: 64rpx;
}

.empty-state-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d2433;
}

.empty-state-desc {
  font-size: 24rpx;
  color: #8c97a8;
  text-align: center;
  line-height: 1.6;
}

.load-more {
  text-align: center;
  font-size: 22rpx;
  color: #8c97a8;
  padding: 16rpx 0 8rpx;
}
