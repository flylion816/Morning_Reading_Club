<view class="page-checkin-records" wx:if="{{accessChecked}}">
  <view class="hero-card">
    <view class="hero-user">
      <view wx:if="{{userInfo.avatarUrl}}" class="hero-avatar-wrap">
        <image class="hero-avatar-image" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      </view>
      <view wx:else class="hero-avatar-wrap hero-avatar-fallback" style="background: {{userInfo.avatarColor}}">
        <text class="hero-avatar-text">{{userInfo.avatarText}}</text>
      </view>
      <view class="hero-user-copy">
        <text class="hero-user-name">{{userInfo.userName}}</text>
        <text class="hero-user-subtitle">记录每一次觉察，也回看自己的成长轨迹</text>
      </view>
    </view>

    <view class="hero-stats">
      <view class="hero-stat">
        <text class="hero-stat-value">{{stats.diaryCount || 0}}</text>
        <text class="hero-stat-label">日记</text>
      </view>
      <view class="hero-stat-divider"></view>
      <view class="hero-stat">
        <text class="hero-stat-value">{{stats.likeCount || 0}}</text>
        <text class="hero-stat-label">获赞</text>
      </view>
    </view>
  </view>

  <view class="diary-search-bar">
    <view class="diary-search-input-wrap">
      <input
        class="diary-search-input"
        placeholder="在打卡内容中搜索"
        placeholder-style="color:#bbb"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchSubmit"
        confirm-type="search"
      />
      <view class="diary-search-clear" wx:if="{{searchKeyword}}" catchtap="onSearchClear">×</view>
    </view>
    <view class="diary-search-btn" catchtap="onSearchSubmit">搜索</view>
  </view>

  <view class="section-block">
    <view class="section-title">打卡记录</view>
    <scroll-view scroll-x class="period-scroll" show-scrollbar="{{false}}" enhanced="true">
      <view class="period-scroll-inner">
        <view
          wx:for="{{periodOptions}}"
          wx:key="id"
          class="period-card {{item.id === periodId ? 'period-card-active' : ''}}"
          bindtap="handlePeriodSelect"
          data-period-id="{{item.id}}"
        >
          <view class="period-card-icon" style="background: {{item.id === periodId ? item.color : '#eef3ff'}}">
            <text class="period-card-icon-text">{{item.icon}}</text>
          </view>
          <view class="period-card-copy">
            <text class="period-card-title">{{item.displayTitle || item.title}}</text>
            <text class="period-card-subtitle">{{item.subtitle}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view
    wx:if="{{selectedPeriod && selectedPeriod.id !== 'all'}}"
    class="selected-period-banner"
    bindtap="handleSelectedPeriodTap">
    <view class="selected-period-icon" style="background: {{selectedPeriod.color}}">
      <text class="selected-period-icon-text">{{selectedPeriod.icon}}</text>
    </view>
    <view class="selected-period-copy">
      <text class="selected-period-title">{{selectedPeriod.title}}</text>
      <text wx:for="{{selectedPeriodMetaLines}}" wx:key="*this" class="selected-period-line">{{item}}</text>
    </view>
    <text class="selected-period-arrow">›</text>
  </view>

  <view wx:if="{{checkinRecords.length > 0 || isSearchMode}}" class="records-list">
    <view wx:if="{{isSearchMode && searchLoading}}" class="search-loading">搜索中...</view>
    <view wx:elif="{{isSearchMode && searchResults.length === 0}}" class="empty-state">
      <text class="empty-state-icon">🔍</text>
      <text class="empty-state-title">没有找到相关打卡</text>
      <text class="empty-state-desc">换个关键词试试</text>
    </view>
    <view
      wx:for="{{isSearchMode ? searchResults : checkinRecords}}"
      wx:key="id"
      class="record-row"
      bindtap="handleRecordTap"
      data-checkin-id="{{item.id}}"
      data-section-id="{{item.sectionId}}"
    >
      <view class="record-date-col">
        <text class="record-day">{{item.dayLabel}}</text>
        <text class="record-month">{{item.monthLabel}}</text>
      </view>

      <view class="record-card">
        <view class="record-header">
          <view wx:if="{{userInfo.avatarUrl}}" class="record-avatar-wrap">
            <image class="record-avatar-image" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
          </view>
          <view wx:else class="record-avatar-wrap record-avatar-fallback" style="background: {{userInfo.avatarColor}}">
            <text class="record-avatar-text">{{userInfo.avatarText}}</text>
          </view>

          <view class="record-header-copy">
            <text class="record-user-name">{{userInfo.userName}}</text>
            <text class="record-header-subtitle">{{item.courseTitle}}</text>
          </view>

          <text class="record-more">···</text>
        </view>

        <view class="record-content {{item.hasDiary ? '' : 'record-content-empty'}}">
          <block wx:if="{{item.highlightParts}}">
            <text wx:for="{{item.highlightParts}}" wx:key="index" wx:for-item="part" class="{{part.highlight ? 'highlight-keyword' : ''}}">{{part.text}}</text>
          </block>
          <block wx:else>{{item.preview}}</block>
        </view>

        <view class="record-footer">
          <text class="record-meta">{{item.metaLabel}}</text>
          <view class="record-like">
            <text class="record-like-icon">♡</text>
            <text class="record-like-count">{{item.likeCount}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{!loading && !isSearchMode && checkinRecords.length === 0}}" class="empty-state">
    <text class="empty-state-icon">📝</text>
    <text class="empty-state-title">还没有打卡日记</text>
    <text class="empty-state-desc">完成晨读打卡后，这里会汇总你的所有记录</text>
  </view>

  <view wx:if="{{loadingMore}}" class="load-more">加载更多中...</view>
</view>

<podcast-player-bar />
