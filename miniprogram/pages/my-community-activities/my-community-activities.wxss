.page-my-activities {
  background: #f5f7fa;
  min-height: 100vh;
  padding: 20rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: var(--theme-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 20rpx;
  gap: 20rpx;
}

.item-poster {
  width: 140rpx;
  height: 100rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.item-poster-placeholder {
  width: 140rpx;
  height: 100rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  background: var(--theme-primary-tint);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.item-status {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.item-status-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.registration-status {
  color: #667085;
  font-size: 22rpx;
}

.detail-link {
  margin-top: 10rpx;
  color: var(--theme-primary);
  font-size: 24rpx;
  font-weight: 600;
}

.item-status.status-upcoming { background: var(--theme-primary-tint); color: var(--theme-primary); }
.item-status.status-ongoing { background: #e8f5e9; color: #43a047; }
.item-status.status-ended { background: #f5f5f5; color: #999; }
.item-status.status-cancelled { background: #fce8e8; color: #e53935; }

.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}

.detail-sheet {
  width: 100%;
  max-height: 72vh;
  padding: 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
  box-sizing: border-box;
}

.detail-head,
.detail-meta,
.detail-answer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.detail-title {
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-close {
  color: var(--theme-primary);
  font-size: 26rpx;
}

.detail-meta {
  justify-content: flex-start;
  flex-wrap: wrap;
  margin-top: 14rpx;
  color: #667085;
  font-size: 24rpx;
}

.detail-section-title {
  margin-top: 26rpx;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 700;
}

.detail-answer-list {
  margin-top: 10rpx;
}

.detail-answer-row {
  min-height: 66rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.detail-answer-label {
  color: #667085;
  font-size: 25rpx;
}

.detail-answer-value {
  color: #1f2937;
  font-size: 25rpx;
  font-weight: 600;
  text-align: right;
}
