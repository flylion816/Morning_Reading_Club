.page-my-activities {
  background: #f5f7fa;
  min-height: 100vh;
  padding: 20rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  padding: 20rpx;
  gap: 20rpx;
}

.item-poster {
  width: 140rpx;
  height: 100rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.item-poster-placeholder {
  width: 140rpx;
  height: 100rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
  background: #e8f0fe;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.item-status {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.item-status.status-upcoming { background: #e8f0fe; color: #4a6cf7; }
.item-status.status-ongoing { background: #e8f5e9; color: #43a047; }
.item-status.status-ended { background: #f5f5f5; color: #999; }
.item-status.status-cancelled { background: #fce8e8; color: #e53935; }
