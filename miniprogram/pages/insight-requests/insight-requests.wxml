<view class="page-insight-requests">
  <view class="notification-reminder" wx:if="{{notificationReminder}}">
    <text class="notification-reminder-text">{{notificationReminder}}</text>
    <view class="notification-reminder-link" bindtap="navigateToNotificationSettings">去补充</view>
  </view>

  <view class="request-direction-tabs">
    <view
      wx:for="{{requestDirectionTabs}}"
      wx:key="value"
      class="request-direction-tab {{activeRequestDirection === item.value ? 'request-direction-tab-active' : ''}}"
      bindtap="handleRequestDirectionTap"
      data-direction="{{item.value}}">
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="requests-loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="requests-list" wx:elif="{{requests.length > 0}}">
    <view
      wx:for="{{requests}}"
      wx:key="id"
      class="request-item"
      bindtap="handleRequestTap"
      data-request="{{item}}">
      <view class="request-item-left">
        <view class="request-user-avatar" style="background: {{item.avatarColor}}" catchtap="handleRequestAvatarClick" data-request="{{item}}" data-user-id="{{item.displayUserId}}" data-period-id="{{item.periodId}}">
          <image wx:if="{{item.displayUserAvatarUrl}}" class="request-avatar-image" src="{{item.displayUserAvatarUrl}}" mode="aspectFill" />
          <text wx:else class="request-avatar-text">{{item.displayUserAvatarText}}</text>
        </view>
        <view class="request-info">
          <view class="request-top-row">
            <text class="request-user-role">{{item.displayUserRoleText}}</text>
            <text class="request-user-name">{{item.displayUserName}}</text>
          </view>
          <text class="request-meta">{{item.requestMeta}}</text>
          <text class="request-time">{{item.time}}</text>
        </view>
      </view>
      <view class="request-side">
        <text class="request-status request-status-{{item.statusClass}}">{{item.statusText}}</text>
        <view class="request-actions" wx:if="{{item.canApprove || item.canReject}}">
          <view class="request-btn approve-btn" catchtap="handleApproveRequest" data-request="{{item}}">
            <text>同意</text>
          </view>
          <view class="request-btn reject-btn" catchtap="handleRejectRequest" data-request="{{item}}">
            <text>拒绝</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">📬</text>
    <text class="empty-text">{{emptyText}}</text>
  </view>
</view>

<podcast-player-bar />
