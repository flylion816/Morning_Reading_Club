.page-insight-requests {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.requests-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.notification-reminder {
  background: #fff8e8;
  border: 2rpx solid #f7d48b;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #8a5a00;
}

.notification-reminder-text {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.6;
}

.notification-reminder-link {
  flex-shrink: 0;
  color: #357abd;
  font-size: 22rpx;
  font-weight: 600;
}

.request-card {
  background: white;
  border-radius: 16rpx;
  padding: 18rpx 18rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.2s ease, background 0.2s ease;
}

.request-card:active {
  background: #eef4ff;
  transform: scale(0.99);
}

.request-user {
  display: flex;
  gap: 16rpx;
}

.request-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 16rpx rgba(74, 144, 226, 0.14);
}

.request-avatar-text {
  font-size: 28rpx;
  color: white;
  font-weight: 600;
}

.request-user-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.request-user-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.request-user-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.request-status {
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}

.request-status-pending {
  background: #eef4ff;
  color: #4a90e2;
}

.request-status-approved {
  background: #e8f8ef;
  color: #1f9d55;
}

.request-status-rejected {
  background: #fff1f0;
  color: #d94841;
}

.request-status-revoked {
  background: #f3f4f6;
  color: #6b7280;
}

.request-meta {
  font-size: 24rpx;
  color: #5b6b82;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.request-time {
  font-size: 20rpx;
  color: #9aa3b2;
}

.request-actions {
  display: flex;
  justify-content: flex-end;
  gap: 10rpx;
  margin-top: 14rpx;
}

.request-action {
  min-width: 104rpx;
  padding: 12rpx 0;
  border-radius: 999rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 600;
}

.request-action.approve {
  background: #4a90e2;
  color: white;
}

.request-action.reject {
  background: #f3f4f6;
  color: #666;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}
