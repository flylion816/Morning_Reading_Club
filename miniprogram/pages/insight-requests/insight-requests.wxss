.page-insight-requests {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.requests-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.notification-reminder {
  background: #fff8e8;
  border: 2rpx solid #f7d48b;
  border-radius: 16rpx;
  padding: 18rpx 20rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  color: #8a5a00;
}

.notification-reminder-text {
  flex: 1;
  font-size: 22rpx;
  line-height: 1.6;
}

.notification-reminder-link {
  flex-shrink: 0;
  color: #357abd;
  font-size: 22rpx;
  font-weight: 600;
}

.request-item {
  display: flex;
  justify-content: space-between;
  align-items: stretch;
  padding: 16rpx 14rpx;
  background: #f7f9fc;
  border-radius: 12rpx;
  border: none;
  transition: transform 0.2s ease, background 0.2s ease;
}

.request-item:active {
  background: #eef4ff;
  transform: scale(0.99);
}

.request-item-left {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.request-user-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6rpx 16rpx rgba(74, 144, 226, 0.16);
}

.request-avatar-text {
  font-size: 28rpx;
  color: white;
  font-weight: 600;
}

.request-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  flex: 1;
  min-width: 0;
}

.request-top-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.request-user-name {
  font-size: 26rpx;
  color: #333333;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.request-status {
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  align-self: flex-end;
}

.request-status-pending {
  background: #eef4ff;
  color: #4a90e2;
}

.request-status-approved {
  background: #e8f8ef;
  color: #1f9d55;
}

.request-status-rejected {
  background: #fff1f0;
  color: #d94841;
}

.request-status-revoked {
  background: #f3f4f6;
  color: #6b7280;
}

.request-meta {
  font-size: 24rpx;
  color: #5b6b82;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.request-time {
  font-size: 20rpx;
  color: #9aa3b2;
}

.request-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  margin-left: 12rpx;
  flex-shrink: 0;
  min-width: 168rpx;
}

.request-actions {
  display: flex;
  flex-direction: row;
  gap: 8rpx;
  align-items: center;
  justify-content: flex-end;
  flex-wrap: nowrap;
  margin-top: auto;
}

.request-btn {
  min-width: 76rpx;
  height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  transition: all 0.3s;
}

.approve-btn {
  background: #4a90e2;
  color: #ffffff;
}

.reject-btn {
  background: #f3f4f6;
  color: #666666;
}

.approve-btn:active,
.reject-btn:active {
  transform: scale(0.96);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 180rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}
