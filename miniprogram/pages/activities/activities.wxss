.page-activities {
  background: #f5f7fa;
  min-height: 100vh;
  padding: 20rpx 24rpx 40rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #4a90e2;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #aaa;
}

.activity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.activity-item {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  gap: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.activity-item:active {
  opacity: 0.85;
}

.item-poster {
  width: 160rpx;
  height: 186rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  object-fit: cover;
}

.item-poster-placeholder {
  width: 160rpx;
  height: 186rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: linear-gradient(135deg, #e8f0fe 0%, #d0e4ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.item-poster-emoji {
  font-size: 52rpx;
}

.item-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  height: 186rpx;
  justify-content: space-between;
}

.item-meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.item-type-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.item-type-tag.type-witness {
  background: #fff3e0;
  color: #e65100;
}

.item-type-tag.type-chat {
  background: #e8f5e9;
  color: #2e7d32;
}

.item-type-tag {
  background: #e8f0fe;
  color: #1a73e8;
}

.item-status {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.item-status.status-upcoming { background: #e8f0fe; color: #4a6cf7; }
.item-status.status-ongoing  { background: #e8f5e9; color: #43a047; }
.item-status.status-ended    { background: #f5f5f5; color: #999; }
.item-status.status-cancelled{ background: #fce8e8; color: #e53935; }

.item-title {
  display: -webkit-box;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  height: 84rpx;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.item-time {
  display: block;
  font-size: 24rpx;
  color: #888;
}

.item-location {
  font-size: 24rpx;
  color: #888;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.load-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 40rpx 0 20rpx;
}

.load-more-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #e0e0e0;
  border-top-color: #4a90e2;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.load-more-text {
  font-size: 28rpx;
  color: #4a90e2;
}

.no-more {
  text-align: center;
  padding: 40rpx 0 20rpx;
  font-size: 24rpx;
  color: #ccc;
}
