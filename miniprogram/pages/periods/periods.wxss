/* 期次列表样式 */

.page-periods {
  min-height: 100vh;
  background:
    radial-gradient(circle at 20% 0%, var(--theme-primary-alpha-08) 0, rgba(255,255,255,0) 280rpx),
    linear-gradient(180deg, var(--app-page-bg) 0%, #fafaf5 100%);
  padding-bottom: 120rpx;
}

/* 顶部横幅 */
.home-banner {
  background:
    radial-gradient(circle at 76% 4%, rgba(255,255,255,0.22) 0, rgba(255,255,255,0) 230rpx),
    linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  padding: 56rpx 36rpx 56rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  min-height: 196rpx;
  overflow: hidden;
}

.banner-text-container {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  align-items: flex-start;
  text-align: left;
  position: relative;
  z-index: 2;
}

.banner-eyebrow {
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
  font-weight: 500;
}

.banner-text {
  font-size: 54rpx;
  font-weight: 700;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  line-height: 1.2;
}

.banner-subtext {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  max-width: 520rpx;
  line-height: 1.55;
}

.banner-orbit {
  position: absolute;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  pointer-events: none;
}

.banner-orbit-large {
  width: 260rpx;
  height: 260rpx;
  right: -72rpx;
  bottom: -94rpx;
}

.banner-orbit-small {
  width: 126rpx;
  height: 126rpx;
  right: 88rpx;
  top: 34rpx;
  opacity: 0.62;
}

/* 用户信息卡片 */
.user-card {
  margin: 16rpx 32rpx;
  padding: 24rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.user-card-header {
  margin-bottom: 12rpx;
}

.user-card-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.user-signature {
  padding: 12rpx;
  background: #f9fafb;
  border-left: 4rpx solid var(--theme-primary);
  border-radius: 8rpx;
}

.signature-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 期次列表容器 */
.periods-container {
  padding: 0 24rpx 32rpx;
  margin-top: 24rpx;
  background: transparent;
  min-height: 60vh;
  position: relative;
  z-index: 3;
}

.periods-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin: 0 4rpx 20rpx;
  padding: 0 2rpx 4rpx 2rpx;
  border-radius: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  position: relative;
  overflow: hidden;
}

.periods-heading::before {
  display: none;
}

.periods-heading-title,
.periods-heading-subtitle {
  display: block;
  position: relative;
  z-index: 1;
}

.periods-heading-title {
  color: var(--app-text);
  font-size: 31rpx;
  font-weight: 600;
  line-height: 1.3;
}

.periods-heading-subtitle {
  margin-top: 6rpx;
  color: var(--app-text-muted);
  font-size: 23rpx;
}

.periods-heading-count {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  padding: 0;
  border-radius: 0;
  background: transparent;
  color: var(--theme-primary-dark);
  font-size: 23rpx;
  font-weight: 500;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  padding: 6rpx 0 48rpx;
  gap: 18rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--theme-primary-alpha-20);
  border-top-color: var(--theme-primary);
  border-radius: 18rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 4rpx;
  font-size: 26rpx;
  color: var(--app-text-muted);
  text-align: center;
}

.period-skeleton {
  display: flex;
  gap: 24rpx;
  padding: 30rpx;
  border-radius: 22rpx;
  background: linear-gradient(180deg, var(--app-paper) 0%, rgba(255, 255, 255, 0.94) 100%);
  border: 1rpx solid rgba(49, 72, 56, 0.08);
  overflow: hidden;
}

.period-skeleton-thumb {
  width: 126rpx;
  height: 156rpx;
  flex-shrink: 0;
  border-radius: 20rpx;
  background: linear-gradient(90deg, #edf1e9 0%, #f8faf4 48%, #edf1e9 100%);
  animation: skeletonPulse 1.4s ease-in-out infinite;
}

.period-skeleton-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 22rpx;
}

.period-skeleton-line,
.period-skeleton-progress {
  border-radius: 999rpx;
  background: linear-gradient(90deg, #edf1e9 0%, #f8faf4 48%, #edf1e9 100%);
  animation: skeletonPulse 1.4s ease-in-out infinite;
}

.period-skeleton-title {
  width: 82%;
  height: 28rpx;
}

.period-skeleton-meta {
  width: 62%;
  height: 22rpx;
}

.period-skeleton-progress {
  width: 100%;
  height: 8rpx;
}

@keyframes skeletonPulse {
  0% {
    opacity: 0.58;
  }

  50% {
    opacity: 1;
  }

  100% {
    opacity: 0.58;
  }
}

.loading-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #9ca3af;
}

.no-more {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #cbd5e0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 110rpx 0;
  border-radius: 24rpx;
  background: rgba(255, 254, 250, 0.86);
  border: 1rpx solid var(--app-border);
}

.empty-state-icon {
  font-size: 116rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-state-text {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 期次包装器 - 可点击 */
.period-wrapper {
  margin-bottom: 22rpx;
  background:
    linear-gradient(180deg, var(--app-paper) 0%, rgba(255, 255, 255, 0.94) 100%);
  border-radius: 22rpx;
  overflow: hidden;
  box-shadow: var(--app-shadow-soft);
  border: 1rpx solid rgba(49, 72, 56, 0.08);
  position: relative;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.period-wrapper::before {
  display: none;
}

.period-wrapper:active {
  box-shadow: var(--app-shadow);
  transform: translateY(2rpx) scale(0.995);
}

.period-wrapper-loading {
  opacity: 0.72;
  pointer-events: none;
}

/* 报名状态标签 */
.enrollment-label {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  z-index: 10;
}

.label-text {
  display: inline-block;
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.enrollment-label.enrolled .label-text {
  background: var(--theme-primary-tint);
  color: var(--theme-primary-dark);
  box-shadow: none;
  border: 1rpx solid var(--theme-primary-alpha-18);
}

.enrollment-label.enroll-label-inline .label-text {
  background: var(--app-text);
  color: white;
  box-shadow: 0 8rpx 18rpx rgba(23, 34, 27, 0.16);
}

.enrollment-label.not-enrolled .label-text {
  background: #eef1ec;
  color: var(--app-text-muted);
}

.enrollment-label.enroll-label-inline:active .label-text {
  opacity: 0.85;
}

/* 邀请栏 */
.period-invite-bar {
  display: flex;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: var(--theme-primary-tint);
  border-top: 1rpx solid var(--theme-primary-tint);
}

.btn-invite {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--theme-primary);
  background: white;
  border: 2rpx solid var(--theme-primary);
  border-radius: 32rpx;
  padding: 0;
  margin: 0;
  text-align: center;
}

.btn-invite::after {
  border: none;
}

.btn-invite:active {
  background: var(--theme-primary-tint);
}

.btn-enroll-entry {
  flex: 1;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: white;
  background: linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  border: none;
  border-radius: 32rpx;
  padding: 0;
  margin: 0;
  text-align: center;
}

.btn-enroll-entry::after {
  border: none;
}

.btn-enroll-entry:active {
  opacity: 0.9;
}
