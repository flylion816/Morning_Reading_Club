<!--期次列表页面-->
<view class="page-periods">
  <!-- 顶部横幅 -->
  <view class="home-banner">
    <view class="banner-text-container">
      <text class="banner-eyebrow">{{brandName}}</text>
      <text class="banner-text">晨读营</text>
      <text class="banner-subtext">按期次跟读，把每天的 15 分钟留下来</text>
    </view>
    <view class="banner-orbit banner-orbit-large"></view>
    <view class="banner-orbit banner-orbit-small"></view>
  </view>

  <!-- 期次列表 -->
  <view class="periods-container">
    <view class="periods-heading">
      <view>
        <text class="periods-heading-title">全部期次</text>
        <text class="periods-heading-subtitle">{{isLogin ? '按自己的节奏，回到正在跟读的一期' : '选择一期了解课程安排'}}</text>
      </view>
      <text class="periods-heading-count" wx:if="{{periods.length > 0}}">共 {{periods.length}} 期</text>
    </view>

    <view
      wx:for="{{periods}}"
      wx:key="_id"
      class="period-wrapper {{navigatingPeriodId === item._id ? 'period-wrapper-loading' : ''}}"
      data-period-id="{{item._id}}"
      data-period-name="{{item.name}}"
      bindtap="handlePeriodClick"
    >
      <course-card
        course="{{item}}"
        mode="period"
        enrolled="{{periodEnrollmentStatus[item._id]}}"
        showCheckin="{{isLogin}}"
      />

      <!-- 报名状态标签 -->
      <view wx:if="{{periodEnrollmentStatus[item._id]}}">
        <!-- 已报名 -->
        <view class="enrollment-label enrolled" wx:if="{{periodEnrollmentStatus[item._id].isEnrolled}}">
          <text class="label-text">✓ 已报名</text>
        </view>
        <!-- 未报名：有报名入口时显示立即报名按钮，否则显示未报名标签 -->
        <block wx:if="{{!periodEnrollmentStatus[item._id].isEnrolled}}">
          <view wx:if="{{item.enrollmentOpen}}" class="enrollment-label enroll-label-inline" catchtap="stopPropagation" data-period-id="{{item._id}}" data-period-name="{{item.name}}" bindtap="handleEnrollEntry">
            <text class="label-text">→ 去报名</text>
          </view>
          <view wx:else class="enrollment-label not-enrolled">
            <text class="label-text">未报名</text>
          </view>
        </block>
      </view>

      <!-- 邀请好友按钮（仅 enrollmentOpen=true 的期次显示） -->

    </view>

    <!-- 加载中 -->
    <view wx:if="{{loading && periods.length === 0}}" class="loading-container">
      <view class="period-skeleton" wx:for="{{skeletonItems}}" wx:key="*this">
        <view class="period-skeleton-thumb"></view>
        <view class="period-skeleton-body">
          <view class="period-skeleton-line period-skeleton-title"></view>
          <view class="period-skeleton-line period-skeleton-meta"></view>
          <view class="period-skeleton-progress"></view>
        </view>
      </view>
      <text class="loading-text">正在整理期次...</text>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{!loading && periods.length === 0}}" class="empty-state">
      <text class="empty-state-icon">📚</text>
      <text class="empty-state-text">暂无期次</text>
    </view>
  </view>
</view>

<podcast-player-bar has-tabbar="{{true}}" ignore-safe-area="{{true}}" />
