.page-admin-workbench {
  min-height: 100vh;
  background: #f4f6f8;
  padding-bottom: 40rpx;
}

.tabs {
  position: sticky;
  top: 0;
  z-index: 5;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #edf0f5;
}

.tab {
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 10rpx;
  background: #eef3f8;
  color: #667085;
  font-size: 26rpx;
}

.tab.active {
  background: #2563eb;
  color: #ffffff;
  font-weight: 600;
}

.content {
  padding: 20rpx 24rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.search-input {
  flex: 1;
  height: 68rpx;
  border-radius: 10rpx;
  background: #ffffff;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.search-btn {
  width: 132rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 10rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 26rpx;
  padding: 0;
}

.search-btn::after {
  border: 0;
}

.state-box {
  padding: 44rpx 20rpx;
  border-radius: 10rpx;
  background: #ffffff;
  color: #98a2b3;
  font-size: 26rpx;
  text-align: center;
}

.state-box.compact {
  padding: 28rpx 20rpx;
  margin-top: 12rpx;
}

.user-list,
.activity-list,
.registration-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.user-card,
.activity-card,
.info-card,
.detail-panel,
.profile-box {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 14rpx rgba(31, 41, 55, 0.05);
}

.user-card,
.activity-card,
.info-card {
  padding: 20rpx;
}

.user-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  border: 2rpx solid transparent;
}

.user-card.selected,
.activity-card.selected {
  border-color: #93c5fd;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #eff6ff;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.user-main {
  min-width: 0;
  flex: 1;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.row.sub,
.foot {
  margin-top: 10rpx;
  color: #667085;
  font-size: 22rpx;
}

.name,
.card-title,
.profile-name {
  color: #1f2937;
  font-weight: 600;
}

.name {
  font-size: 28rpx;
}

.card-title {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-name {
  display: block;
  font-size: 32rpx;
}

.meta,
.latest,
.meta-line,
.profile-meta,
.panel-meta {
  color: #98a2b3;
  font-size: 22rpx;
}

.latest,
.profile-meta,
.meta-line {
  display: block;
  margin-top: 10rpx;
}

.arrow {
  color: #cbd5e1;
  font-size: 36rpx;
  flex-shrink: 0;
}

.detail-panel {
  margin-top: 20rpx;
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.sub-title {
  margin: 24rpx 0 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #344054;
}

.profile-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  box-shadow: none;
  background: #f8fafc;
}

.status-pill {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 22rpx;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.chip {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #475467;
  font-size: 22rpx;
  line-height: 30rpx;
}

.chip.blue {
  background: #eff6ff;
  color: #2563eb;
}

.amount {
  flex-shrink: 0;
  color: #2563eb;
  font-size: 28rpx;
  font-weight: 700;
}

.load-more {
  margin-top: 8rpx;
  padding: 22rpx 0;
  border-radius: 10rpx;
  background: #ffffff;
  color: #2563eb;
  text-align: center;
  font-size: 26rpx;
}
