<!--首页页面-->
<activity-popup
  show="{{showActivityPopup}}"
  activity="{{popupActivity}}"
  bind:close="handlePopupClose"
  bind:viewdetail="handlePopupViewDetail"
/>
<view class="page-profile">
  <!-- 已登录状态 - 显示主页内容 -->
  <view class="user-content" wx:if="{{isLogin}}">
    <!-- 顶部横幅 -->
    <view class="home-banner">
      <view class="user-avatar-container" style="background: {{userInfo.avatarColor || themePrimaryColor}}" bindtap="openEditProfile">
        <image wx:if="{{userInfo.avatarUrl}}" class="user-avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <text wx:else class="user-avatar-emoji">{{userInfo.avatarText || '用'}}</text>
        <view class="avatar-edit-badge">✏️</view>
      </view>
      <view class="banner-content">
        <view class="banner-top-row">
          <view class="user-info-display">
            <view class="user-name-and-period">
              <text class="user-name">{{userInfo.nickname || userInfo.name || '用户'}}</text>
              <view class="user-period-tag" wx:if="{{currentPeriod}}">{{currentPeriod.name || currentPeriod.title}}</view>
            </view>
          </view>
          <view class="banner-streak-actions">
            <text class="user-streak">累计打卡 <text class="streak-number">{{userStats.totalCheckinDays || 0}}</text> 天</text>
            <view class="task-notification-entry banner-notification-entry" bindtap="navigateToNotifications">
              <text class="task-notification-icon banner-notification-icon">🔔</text>
              <text
                wx:if="{{unreadNotificationCount > 0}}"
                class="task-notification-badge banner-notification-badge"
              >{{unreadNotificationCount > 99 ? '99+' : unreadNotificationCount}}</text>
            </view>
          </view>
        </view>
        <view class="banner-bubble">
          <text class="bubble-text" wx:if="{{hasValidSignature}}">{{userInfo.signature}}</text>
          <text class="bubble-text" wx:else>暂无签名</text>
        </view>
      </view>
    </view>

    <!-- 内容区域 -->
    <view class="content-area">
      <block wx:for="{{homeSections}}" wx:key="key">
      <!-- 近期活动 -->
      <view class="activity-section" wx:if="{{item.key === 'recentActivities' && upcomingActivities.length > 0 && canUsePaidFeatures}}">
        <view class="section-header">
          <view class="section-header-left">
            <view class="section-icon-calendar">📆</view>
            <text class="section-header-title">近期活动</text>
          </view>
          <view class="section-header-right" bindtap="handleMoreActivities">
            <text class="more-text">查看更多</text>
          </view>
        </view>
        <view class="activity-cards">
          <view
            class="activity-card"
            wx:for="{{upcomingActivities}}"
            wx:key="_id"
            data-id="{{item._id}}"
            bindtap="handleActivityCardTap"
          >
            <text class="activity-card-type">{{item.type === 'witness' ? '见证会' : item.type === 'chat' ? '聊天局' : item.type === 'cooking' ? '料理人生' : '活动'}}</text>
            <text class="activity-card-title">{{item.title}}</text>
            <text class="activity-card-time">{{item.startDateText}}</text>
          </view>
        </view>
      </view>

      <!-- 凡人生活 -->
      <view class="zaichang-section" wx:if="{{item.key === 'zaichang' && canUsePaidFeatures}}">
        <view class="section-header">
          <view class="section-header-left">
            <view class="section-icon-zaichang">🌿</view>
            <text class="section-header-title">凡人生活</text>
          </view>
          <view class="section-header-right" bindtap="navigateToZaichangPublish">
            <text class="more-text zaichang-publish-text">留下印记</text>
          </view>
        </view>

        <scroll-view
          wx:if="{{zaichangImprints.length > 0}}"
          scroll-x
          class="checkins-scroll"
          show-scrollbar="{{false}}"
          enhanced="true">
          <view class="checkins-scroll-track">
            <view
              wx:for="{{zaichangImprints}}"
              wx:key="_id"
              class="zaichang-card"
              bindtap="onTapZaichangCard"
              data-id="{{item._id}}"
            >
              <view class="zaichang-card-cover">
                <video
                  wx:if="{{item.coverUrl && item.coverType === 'video'}}"
                  class="zaichang-card-img zaichang-card-video"
                  src="{{item.coverUrl}}"
                  object-fit="cover"
                  controls="{{false}}"
                  show-play-btn="{{false}}"
                  show-center-play-btn="{{false}}"
                  enable-play-gesture="{{false}}"
                  autoplay="{{false}}"
                  muted
                />
                <image wx:elif="{{item.coverUrl}}" class="zaichang-card-img" src="{{item.coverUrl}}" mode="aspectFill" lazy-load/>
                <view wx:else class="zaichang-card-img-placeholder">🌿</view>
                <view wx:if="{{item.coverUrl && item.coverType === 'video'}}" class="zaichang-card-video-badge">▶</view>
              </view>
              <view class="zaichang-card-title">{{item.title}}</view>
              <view class="zaichang-card-meta">{{item.authorName}}{{item.dateStr ? ' · ' + item.dateStr : ''}}</view>
            </view>

            <view class="checkin-diary-more-card zaichang-more-card" bindtap="navigateToZaichang">
              <view class="checkin-diary-more-icon">→</view>
              <text class="checkin-diary-more-title">进入在场</text>
              <view class="checkin-diary-more-desc">
                <view>查看更多</view>
                <view>聚会印记</view>
              </view>
            </view>
          </view>
        </scroll-view>

        <view wx:else class="checkins-empty">
          <text class="checkins-empty-text">还没有印记，去留下第一个吧</text>
          <view class="checkins-empty-link" bindtap="navigateToZaichang">
            <text>进入在场</text>
            <text class="more-arrow">→</text>
          </view>
        </view>
      </view>

      <!-- 今日任务 -->
      <view class="task-section" wx:if="{{item.key === 'todayTask'}}">
        <view class="section-header">
          <view class="section-header-left">
            <view class="section-icon-clipboard">📋</view>
            <text class="section-header-title">今日任务</text>
          </view>
          <view class="section-header-right">
            <view class="refresh-timer" wx:if="{{refreshTime}}">
              <text class="timer-icon">⏱</text>
              <text class="timer-text">刷新 {{refreshTime}} 小时</text>
            </view>
          </view>
        </view>
        <view class="period-card" wx:if="{{todaySection}}" catchtap="handleTodaySectionClick">
          <view class="period-cover">
            <view class="book-icon-svg"></view>
            <text class="period-day">Day {{todaySection.dayDisplay}}</text>
          </view>
          <view class="period-info-new">
            <view class="period-title-area">
              <view class="period-title-new">{{todaySection.title}}</view>
              <view class="checkin-count-badge">
                <view wx:for="{{todaySection.visibleCheckinUsers}}" wx:key="index" wx:if="{{currentPeriodCommunityState === 'enabled'}}" class="mini-avatar" style="z-index: {{99 - index}}; background: {{item.avatarColor || themePrimaryColor}}" catchtap="handleMiniAvatarClick" data-user-id="{{item.userId || item._id}}">
                  <image wx:if="{{item.avatarUrl}}" class="mini-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
                  <text wx:else class="mini-avatar-emoji">{{item.avatarText || '用'}}</text>
                </view>
                <text class="checkin-count-text">{{todaySection.checkinCount || 0}}人{{currentPeriodCommunityState === 'enabled' ? '已打卡' : '已学习'}}</text>
              </view>
            </view>
            <view class="checkin-footer">
              <view class="footer-buttons">
                <view class="meeting-btn {{todaySection.readingCompleted ? 'completed' : ''}}" wx:if="{{todaySection}}" catchtap="handleJoinMeeting">
                  <text>{{todaySection.readingCompleted ? '已晨读' : '去晨读'}}</text>
                  <text wx:if="{{todaySection.readingCompleted}}" class="meeting-btn-check">✓</text>
                  <text class="btn-arrow" wx:if="{{!todaySection.readingCompleted}}">→</text>
                </view>
                <view class="checkin-btn {{todaySection.isCheckedIn ? 'checked' : ''}}" catchtap="handleCreateCheckin">
                  <text wx:if="{{currentPeriodCommunityState === 'enabled' && todaySection.isCheckedIn}}">✓ 已打卡</text>
                  <text wx:elif="{{currentPeriodCommunityState === 'enabled'}}">去打卡</text>
                  <text wx:else>去学习</text>
                  <text class="btn-arrow" wx:if="{{currentPeriodCommunityState !== 'enabled' || !todaySection.isCheckedIn}}">→</text>
                </view>
                <view class="podcast-btn" wx:if="{{todaySection.podcastUrl}}" catchtap="handleTodayPodcastBtnTap">
                  <text>去播客</text>
                  <text class="btn-arrow">→</text>
                </view>
                <view class="report-btn" wx:if="{{currentPeriodReport && currentPeriodReport.hasReport}}" catchtap="handleTodayReportBtnTap">
                  <text>看实录</text>
                  <text class="btn-arrow">→</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        <view class="task-empty" wx:else>
          <text>暂无进行中的课程</text>
        </view>
      </view>


      <view class="checkins-section" wx:if="{{item.key === 'myCheckins' && canUsePaidFeatures}}">
        <view class="section-header">
          <view class="section-header-left">
            <view class="section-icon-checkin">📝</view>
            <text class="section-header-title">我的打卡</text>
          </view>
        </view>

        <scroll-view
          wx:if="{{recentCheckins.length > 0}}"
          scroll-x
          class="checkins-scroll"
          show-scrollbar="{{false}}"
          enhanced="true">
          <view class="checkins-scroll-track">
            <view
              wx:for="{{recentCheckins}}"
              wx:key="id"
              class="checkin-diary-card"
              bindtap="handleRecentCheckinTap"
              data-checkin-id="{{item.id}}"
              data-section-id="{{item.sectionId}}"
              data-period-id="{{item.periodId}}">

              <view class="checkin-diary-card-title">{{item.sectionTitle}}</view>
              <view class="checkin-diary-card-preview">{{item.preview}}</view>

              <view class="checkin-diary-card-footer">
                <view class="checkin-diary-card-meta">
                  <text class="checkin-diary-card-date">{{item.dateLabel}}</text>
                  <view class="checkin-diary-card-like">
                    <text class="checkin-diary-card-like-icon">♡</text>
                    <text class="checkin-diary-card-like-count">{{item.likeCount}}</text>
                  </view>
                  <text wx:if="{{item.periodTitle}}" class="checkin-diary-card-period-badge">{{item.periodTitle}}</text>
                </view>
              </view>
            </view>

            <view class="checkin-diary-more-card" bindtap="navigateToCheckinRecords">
              <view class="checkin-diary-more-icon">→</view>
              <text class="checkin-diary-more-title">查看更多</text>
              <view class="checkin-diary-more-desc">
                <view>进入我的</view>
                <view>打卡日记</view>
              </view>
            </view>
          </view>
        </scroll-view>

        <view wx:else class="checkins-empty">
          <text class="checkins-empty-text">最近还没有打卡日记</text>
          <view class="checkins-empty-link" bindtap="navigateToCheckinRecords">
            <text>去看看我的打卡日记</text>
            <text class="more-arrow">→</text>
          </view>
        </view>
      </view>

      <!-- 小凡看见 -->
      <view class="insights-section" wx:if="{{item.key === 'xiaofanInsights' && canUsePaidFeatures}}">
        <view class="section-header">
          <view class="section-header-left">
            <view class="section-icon-sparkle">✨</view>
            <text class="section-header-title">小凡看见</text>
          </view>
        </view>
        <view class="request-direction-tabs">
          <view
            class="request-direction-tab {{insightActiveTab === 'mine' ? 'request-direction-tab-active' : ''}}"
            bindtap="handleInsightTabTap"
            data-tab="mine">我的</view>
          <view
            class="request-direction-tab {{insightActiveTab === 'others' ? 'request-direction-tab-active' : ''}}"
            bindtap="handleInsightTabTap"
            data-tab="others">他人的</view>
        </view>
        <view class="insights-list">
          <view
            wx:for="{{insightActiveTab === 'mine' ? recentInsights : recentOtherInsights}}"
            wx:key="id"
            class="insight-item"
            style="border-left-color: {{item.typeConfig.color}};background-color: {{item.typeConfig.bgColor}}"
            data-id="{{item.id}}"
            catchtap="handleInsightClick">
            <view class="insight-card-avatar" style="background:{{item.targetUserAvatarColor||themePrimaryColor}}">
              <image wx:if="{{item.targetUserAvatarUrl}}" class="insight-card-avatar-img" src="{{item.targetUserAvatarUrl}}" mode="aspectFill"/>
              <text wx:else class="insight-card-avatar-text">{{item.targetUserAvatarText}}</text>
            </view>
            <view class="insight-content-preview">
              <view class="insight-title-row">
                <text wx:if="{{item.courseDayLabel}}" class="insight-day-chip">{{item.courseDayLabel}}</text>
                <text class="insight-period-tag">{{item.courseTitle}}</text>
              </view>
              <block wx:if="{{item.mediaType === 'image' && item.imageUrl}}">
                <view
                  class="insight-thumb-small insight-thumb-top"
                  style="background-image: url('{{item.imageUrl}}');"></view>
              </block>
              <block wx:else>
                <view class="insight-text">{{item.preview}}</view>
              </block>
            </view>
          </view>
          <view class="insight-empty" wx:if="{{insightActiveTab === 'mine' && recentInsights.length === 0}}">
            本期暂无小凡看见记录
          </view>
          <view class="insight-empty" wx:if="{{insightActiveTab === 'others' && otherInsightsLoading}}">
            加载中...
          </view>
          <view class="insight-empty" wx:if="{{insightActiveTab === 'others' && recentOtherInsights.length === 0 && !otherInsightsLoading}}">
            暂无他人授权查看
          </view>
        </view>
        <view class="insights-more" catchtap="navigateToInsights">
          <text class="more-text">查看更多</text>
          <text class="more-arrow">→</text>
        </view>
      </view>

      <!-- 请求看见 -->
      <view class="requests-section" wx:if="{{item.key === 'insightRequests' && canUsePaidFeatures}}">
        <view class="section-header">
          <view class="section-header-left">
            <view class="section-icon-mailbox">📬</view>
            <text class="section-header-title">请求看见</text>
          </view>
        </view>
        <view class="request-direction-tabs">
          <view
            wx:for="{{requestDirectionTabs}}"
            wx:key="value"
            class="request-direction-tab {{activeInsightRequestDirection === item.value ? 'request-direction-tab-active' : ''}}"
            bindtap="handleInsightRequestDirectionTap"
            data-direction="{{item.value}}">
            <text>{{item.label}}</text>
          </view>
        </view>
        <view class="requests-content">
          <view
            wx:for="{{insightRequests}}"
            wx:key="id"
            id="request-{{item.id}}"
            class="request-item {{highlightRequestId === item.id ? 'request-item-focused' : ''}}"
            bindtap="handleInsightRequestTap"
            data-request="{{item}}">
            <view class="request-item-left">
              <view class="request-user-avatar" style="background: {{item.avatarColor || themePrimaryColor}}" catchtap="handleRequestAvatarClick" data-request="{{item}}" data-user-id="{{item.displayUserId}}" data-period-id="{{item.periodId}}">
                <image wx:if="{{item.displayUserAvatarUrl}}" class="request-avatar-image" src="{{item.displayUserAvatarUrl}}" mode="aspectFill" />
                <text wx:else class="request-avatar-text">{{item.displayUserAvatarText}}</text>
              </view>
              <view class="request-info">
                <view class="request-top-row">
                  <text class="request-user-role">{{item.displayUserRoleText}}</text>
                  <text class="request-user-name">{{item.displayUserName}}</text>
                </view>
                <text class="request-meta">{{item.requestMeta}}</text>
                <text class="request-time">{{item.time}}</text>
              </view>
            </view>
            <view class="request-side">
              <text class="request-status request-status-{{item.statusClass}}">{{item.statusText}}</text>
              <view class="request-actions" wx:if="{{item.canApprove || item.canReject}}">
                <view class="request-btn approve-btn" catchtap="handleApproveRequest" data-request="{{item}}">
                  <text>同意</text>
                </view>
                <view class="request-btn reject-btn" catchtap="handleRejectRequest" data-request="{{item}}">
                  <text>拒绝</text>
                </view>
              </view>
            </view>
          </view>
          <view class="requests-empty" wx:if="{{insightRequests.length === 0}}">
            {{insightRequestEmptyText}}
          </view>
        </view>
        <view class="requests-more" wx:if="{{insightRequestTotal > 3}}" catchtap="navigateToInsightRequests">
          <text class="more-text">查看更多</text>
          <text class="more-arrow">→</text>
        </view>
      </view>
      </block>
    </view>
  </view>

  <!-- 未登录状态 - 应用介绍页 -->
  <view class="guest-content" wx:if="{{!isLogin && !loading}}">
    <view class="guest-banner">
      <text class="guest-emoji">🦁</text>
      <text class="guest-title">{{brandName}}</text>
      <text class="guest-subtitle">每日晨读，遇见更好的自己</text>
    </view>

    <!-- 功能亮点 -->
    <view class="guest-features">
      <view class="guest-feature-item">
        <view class="feature-icon-wrap" style="background: #eef4ff;">
          <text class="feature-icon">📖</text>
        </view>
        <view class="feature-text">
          <text class="feature-title">每日晨读</text>
          <text class="feature-desc">精选七个习惯经典章节，每天15分钟，23天养成好习惯</text>
        </view>
      </view>
      <view class="guest-feature-item">
        <view class="feature-icon-wrap" style="background: #fff4e6;">
          <text class="feature-icon">📌</text>
        </view>
        <view class="feature-text">
          <text class="feature-title">学习进度</text>
          <text class="feature-desc">按天完成晨读内容，清晰掌握自己的学习节奏</text>
        </view>
      </view>
      <view class="guest-feature-item">
        <view class="feature-icon-wrap" style="background: #f0fdf4;">
          <text class="feature-icon">🧭</text>
        </view>
        <view class="feature-text">
          <text class="feature-title">课程引导</text>
          <text class="feature-desc">围绕经典章节设置问题与行动练习，帮助理解和应用</text>
        </view>
      </view>
      <view class="guest-feature-item">
        <view class="feature-icon-wrap" style="background: #fef2f2;">
          <text class="feature-icon">⏱</text>
        </view>
        <view class="feature-text">
          <text class="feature-title">晨读节奏</text>
          <text class="feature-desc">跟随课程安排稳步学习，持续积累晨读习惯</text>
        </view>
      </view>
    </view>

    <!-- 底部登录提示 -->
    <view class="guest-bottom">
      <view class="guest-login-subtle" bindtap="goToLogin">登录查看我的学习数据</view>
      <view class="guest-tip">
        <text>点击下方「晨读营」可先</text>
        <text class="guest-link" bindtap="handleBackHome">浏览课程</text>
      </view>
    </view>
  </view>

  <!-- 编辑个人信息模态框 -->
  <view class="edit-profile-modal" wx:if="{{showEditProfile}}" catchtap="closeEditProfile">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">编辑个人信息</text>
        <text class="modal-close" bindtap="closeEditProfile">×</text>
      </view>

      <!-- 头像 -->
      <view class="modal-section">
        <text class="section-label">头像</text>
        <view class="avatar-picker-panel">
          <view class="avatar-preview" style="background: {{editForm.avatarColor || themePrimaryColor}}">
            <image wx:if="{{editForm.avatarUrl}}" class="avatar-preview-image" src="{{editForm.avatarUrl}}" mode="aspectFill" />
            <text wx:else class="avatar-preview-emoji">{{editForm.avatarText || '用'}}</text>
          </view>
          <view class="avatar-picker-info">
            <text class="avatar-picker-title">使用你的微信头像</text>
            <text class="avatar-picker-desc">头像仅用于晨读营内展示</text>
          </view>
          <button class="avatar-action-button primary" open-type="chooseAvatar" bindchooseavatar="handleChooseWechatAvatar">
            更换微信头像
          </button>
        </view>
      </view>

      <!-- 昵称输入 -->
      <view class="modal-section">
        <text class="section-label">昵称</text>
        <input
          class="modal-input"
          type="text"
          placeholder="请输入你的昵称"
          placeholder-class="input-placeholder"
          value="{{editForm.nickname}}"
          bindinput="onNicknameInput"
          maxlength="20"
        />
        <text class="input-count">{{editForm.nickname.length}}/20</text>
      </view>

      <!-- 个人签名输入 -->
      <view class="modal-section">
        <text class="section-label">个人签名</text>
        <textarea
          class="modal-textarea"
          placeholder="选填，分享你的座右铭或想法"
          placeholder-class="input-placeholder"
          value="{{editForm.signature}}"
          bindinput="onSignatureInput"
          maxlength="200"
          show-confirm-bar="false"
          fixed="false"
        ></textarea>
        <text class="input-count">{{editForm.signature.length}}/200</text>
      </view>

      <!-- 操作按钮 -->
      <view class="modal-actions">
        <view class="btn btn-cancel" bindtap="closeEditProfile">取消</view>
        <view class="btn btn-submit {{isSavingProfile ? 'loading' : ''}}" bindtap="saveUserProfile">
          {{isSavingProfile ? '保存中...' : '保存'}}
        </view>
      </view>
    </view>
  </view>

  <!-- 晨读时间确认弹窗 -->
  <view class="morning-read-modal" wx:if="{{showMorningReadPrompt}}" catchtap="handleMorningReadPromptCancel">
    <view class="morning-read-card" catchtap="stopPropagation">
      <view class="morning-read-visual">
        <view class="morning-read-sun"></view>
        <view class="morning-read-book">📖</view>
      </view>
      <view class="morning-read-title">今天的晨读时间到了</view>
      <view class="morning-read-desc">
        <text>趁早上安静的 10 分钟，</text>
        <text>咱们一起读完今天这一课。</text>
      </view>
      <view class="morning-read-actions">
        <view class="morning-read-btn morning-read-btn-cancel" bindtap="handleMorningReadPromptCancel">取消</view>
        <view class="morning-read-btn morning-read-btn-primary" bindtap="handleMorningReadPromptGo">
          <text>去晨读</text>
          <text class="morning-read-arrow">→</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="loading-spinner"></view>
  </view>
</view>

<podcast-player-bar has-tabbar="{{true}}" ignore-safe-area="{{true}}" />
