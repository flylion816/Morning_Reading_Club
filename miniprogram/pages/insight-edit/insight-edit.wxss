page {
  background: #f5f5f5;
  height: 100%;
}

.page-insight-edit {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  box-sizing: border-box;
}

.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.header-card {
  background: linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  color: white;
  padding: 32rpx 24rpx;
  flex-shrink: 0;
}

.header-title {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
}

.header-period {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
  display: block;
}

/* 编辑区域撑满剩余空间 */
.editor-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  margin: 16rpx 24rpx 0;
  background: white;
  border-radius: 16rpx;
}

.toolbar {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.tool-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  background: #f5f7fa;
}

.tool-btn:active {
  background: #e0eaff;
}

.tool-icon {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  line-height: 1;
}

.tool-italic {
  font-style: italic;
}

.rich-editor {
  flex: 1;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  overflow-y: auto;
}

/* 操作栏贴底 */
.action-row {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  margin: 0;
  line-height: 88rpx;
}

.btn::after {
  border: none;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.btn-cancel:active {
  background: #e0e0e0;
}

.btn-save {
  background: linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  color: white;
}

.btn-save:active {
  opacity: 0.85;
}

.btn-saving {
  opacity: 0.6;
}
