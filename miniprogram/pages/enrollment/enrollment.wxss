/* 报名页面样式 */

.page-enrollment {
  background: white;
  min-height: 100vh;
  padding: 0;
}

/* 加载中 */
.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #f5f5f5;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #4a90e2;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading text {
  font-size: 28rpx;
  color: #666;
}

/* 页面容器 */
.enrollment-container {
  padding: 0;
  padding-bottom: 100rpx;
  background: white;
}

/* 页面头部 */
.enrollment-header {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  padding: 60rpx 30rpx;
  text-align: center;
  margin: 0;
  position: relative;
  overflow: hidden;
}

.header-with-image {
  padding: 0;
  height: 600rpx;
}

.header-cover-image {
  width: 100%;
  height: 600rpx;
  display: block;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-content-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 表单 */
.enrollment-form {
  background: white;
  padding: 0 30rpx 30rpx 30rpx;
  margin: 0;
  border-radius: 0;
  box-shadow: none;
}

/* 表单组 */
.form-group {
  margin-bottom: 30rpx;
  margin-top: 0;
  margin-left: 30rpx;
  margin-right: 30rpx;
}

.form-group:first-of-type {
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.form-group:last-of-type {
  margin-bottom: 20rpx;
}

/* 表单标签 */
.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #ff6b6b;
  margin-right: 6rpx;
  font-weight: bold;
}

/* 表单控制 - 基础样式 */
.form-control {
  display: block;
  width: 100%;
  padding: 0 30rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #333;
  background: white;
  box-sizing: border-box;
  transition: all 0.3s ease;
  line-height: 60rpx;
  height: 60rpx;
}

.form-control:focus {
  border-color: #4a90e2;
  box-shadow: 0 0 0 2rpx rgba(74, 144, 226, 0.15);
}

.form-control::placeholder {
  color: #999;
}

/* input 元素特殊处理 - 垂直居中 */
input.form-control {
  height: 60rpx !important;
  width: 100% !important;
  padding: 0 16rpx !important;
  line-height: 60rpx !important;
  box-sizing: border-box !important;
}

/* 统一 placeholder 样式，防止焦点时上移 */
input.form-control::placeholder {
  color: #999;
  opacity: 1;
}

/* Picker 控制 */
picker {
  display: block;
  width: 100%;
}

.picker-control {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 60rpx;
  padding: 16rpx 16rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  background: white;
  box-sizing: border-box;
  transition: all 0.3s ease;
}

.picker-control:active {
  border-color: #4a90e2;
  background: #f9fbff;
}

.picker-icon {
  color: #4a90e2;
  font-size: 32rpx;
  font-weight: bold;
}

/* 地址组 */
.address-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.address-group .form-control {
  width: 100%;
}

/* 单选按钮组 */
.radio-group {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  min-height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  background: white;
  cursor: pointer;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.radio-item:active {
  background: #f9fbff;
  border-color: #4a90e2;
}

.radio-item radio {
  margin-right: 12rpx;
  transform: scale(0.6);
}

.radio-item text {
  font-size: 24rpx;
  color: #333;
  line-height: 1.4;
}

/* 文本域 */
textarea.form-control {
  font-family: inherit !important;
  font-size: 24rpx !important;
  line-height: 1.6 !important;
  min-height: 180rpx !important;
  max-height: 350rpx !important;
  width: 100% !important;
  padding: 16rpx 16rpx !important;
  resize: vertical !important;
  box-sizing: border-box !important;
}

/* textarea placeholder 样式统一 */
textarea.form-control::placeholder {
  color: #999;
  opacity: 1;
}

/* 文字计数 */
.text-count {
  font-size: 22rpx;
  color: #999;
  text-align: right;
  margin-top: 8rpx;
}

/* 提交按钮 */
.form-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 30rpx;
  margin-left: 30rpx;
  margin-right: 30rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid #e8e8e8;
}

.btn {
  flex: 1;
  padding: 16rpx 20rpx;
  border: none;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.3s ease;
  text-align: center;
}

.btn-primary {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-secondary {
  background: #f5f5f5;
  color: #333;
  border: 1rpx solid #e8e8e8;
}

.btn-secondary:active {
  background: #efefef;
  border-color: #d8d8d8;
}

/* 错误提示（如果需要） */
.error-message {
  font-size: 22rpx;
  color: #ff6b6b;
  margin-top: 6rpx;
}

.form-error {
  display: block;
  font-size: 22rpx;
  color: #e74c3c;
  margin-top: 8rpx;
}

.form-control-error {
  border-color: #e74c3c !important;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
  background: white;
  border-bottom: 1rpx solid #f0f0f0;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ddd;
  color: #999;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.step-item.active .step-dot {
  background: #4a90e2;
  color: white;
}

.step-label {
  font-size: 20rpx;
  color: #999;
}

.step-item.active .step-label {
  color: #4a90e2;
  font-weight: 500;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: #ddd;
  margin: 0 12rpx;
  margin-bottom: 20rpx;
  transition: background 0.3s ease;
}

.step-line.active {
  background: #4a90e2;
}

/* 手机号区域 */
.phone-bound {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16rpx;
  height: 60rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  background: #f9f9f9;
}

.phone-number {
  font-size: 24rpx;
  color: #333;
}

.phone-change {
  font-size: 22rpx;
  color: #4a90e2;
}

.phone-auth-wrap {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.btn-phone-auth {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: white;
  border: none;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 500;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  margin: 0;
}

.btn-phone-auth::after {
  border: none;
}

.phone-manual {
  margin-top: 0;
}

/* 步骤操作按钮 */
.step-actions {
  display: flex;
  gap: 20rpx;
  margin: 40rpx 30rpx 20rpx 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 跳过步骤 */
.skip-step {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 16rpx 0 30rpx;
  text-decoration: underline;
}

/* 确认信息区域 */
.confirm-section {
  margin: 30rpx;
  background: #f9fbff;
  border: 1rpx solid #d6e8ff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.confirm-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e0ecff;
}

.confirm-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eef4ff;
}

.confirm-item:last-child {
  border-bottom: none;
}

.confirm-label {
  font-size: 24rpx;
  color: #666;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.confirm-value {
  font-size: 24rpx;
  color: #333;
  text-align: right;
  flex: 1;
}

.confirm-item-price {
  border-top: 1rpx solid #e0eaff;
  margin-top: 8rpx;
  padding-top: 20rpx;
}

.confirm-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #e74c3c;
}

.confirm-price-free {
  font-size: 28rpx;
  font-weight: bold;
  color: #27ae60;
}

/* 响应式调整 */
@media (max-width: 360px) {
  .enrollment-form {
    padding: 0 32rpx 24rpx 32rpx;
  }

  .form-group {
    margin-bottom: 24rpx;
  }

  .header-title {
    font-size: 32rpx;
  }
}
