<!-- 报名页面 -->
<view class="page-enrollment">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 页面内容 -->
  <view wx:if="{{!loading}}" class="enrollment-container">
    <!-- 页面头部 -->
    <view class="enrollment-header {{selectedPeriodCoverImage ? 'header-with-image' : ''}}">
      <image wx:if="{{selectedPeriodCoverImage}}" src="{{selectedPeriodCoverImage}}" class="header-cover-image" mode="aspectFill" />
      <view wx:if="{{!selectedPeriodCoverImage}}" class="header-content">
        <view class="header-icon">{{selectedPeriodIcon}}</view>
        <view class="header-title">{{periodName}}</view>
        <view class="header-subtitle">填写报名信息</view>
      </view>
    </view>

    <!-- 步骤指示器 -->
    <view class="step-indicator">
      <view class="step-item {{currentStep >= 1 ? 'active' : ''}}">
        <view class="step-dot">1</view>
        <text class="step-label">基本信息</text>
      </view>
      <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
      <view class="step-item {{currentStep >= 2 ? 'active' : ''}}">
        <view class="step-dot">2</view>
        <text class="step-label">了解你</text>
      </view>
      <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
      <view class="step-item {{currentStep >= 3 ? 'active' : ''}}">
        <view class="step-dot">3</view>
        <text class="step-label">确认</text>
      </view>
    </view>

    <!-- 表单容器 -->
    <form class="enrollment-form" bindsubmit="handleSubmit">

      <!-- Step 1: 基本信息 -->
      <block wx:if="{{currentStep === 1}}">
        <!-- 报名期次 -->
        <view class="form-group">
          <view class="form-label">
            <text class="required">*</text>
            <text>报名期次</text>
          </view>
          <picker bindchange="handlePeriodChange" value="{{selectedPeriodIndex}}" range="{{periodList}}" range-key="name">
            <view class="form-control picker-control {{errors.periodId ? 'form-control-error' : ''}}">
              <text>{{selectedPeriodName || '请选择报名期次'}}</text>
              <text class="picker-icon">›</text>
            </view>
          </picker>
          <text wx:if="{{errors.periodId}}" class="form-error">{{errors.periodId}}</text>
        </view>

        <!-- 姓名 -->
        <view class="form-group">
          <view class="form-label">
            <text class="required">*</text>
            <text>姓名</text>
          </view>
          <input
            type="text"
            class="form-control {{errors.name ? 'form-control-error' : ''}}"
            name="name"
            placeholder="请输入您的姓名"
            value="{{form.name}}"
            bindinput="handleInput"
            data-field="name"
          />
          <text wx:if="{{errors.name}}" class="form-error">{{errors.name}}</text>
        </view>

        <!-- 手机号 -->
        <view class="form-group">
          <view class="form-label">
            <text>手机号</text>
          </view>
          <view wx:if="{{phoneAuthorized}}" class="phone-bound">
            <text class="phone-number">{{form.phone}}</text>
            <text class="phone-change" bindtap="clearPhone">重新授权</text>
          </view>
          <view wx:else class="phone-auth-wrap">
            <button
              class="btn-phone-auth"
              open-type="getPhoneNumber"
              bindgetphonenumber="onGetPhoneNumber"
            >一键获取手机号</button>
            <input
              type="number"
              class="form-control phone-manual"
              placeholder="或手动输入手机号（选填）"
              value="{{form.phone}}"
              bindinput="handleInput"
              data-field="phone"
              maxlength="11"
            />
          </view>
        </view>

        <!-- 承诺全程 -->
        <view class="form-group">
          <view class="form-label">
            <text class="required">*</text>
            <text>每期晨读营持续23天，每天早上6:00-7:00，您是否承诺全程参加？</text>
          </view>
          <radio-group bindchange="handleRadioChange" data-field="commitment">
            <view class="radio-group">
              <label class="radio-item" wx:for="{{commitmentOptions}}" wx:key="value">
                <radio value="{{item.value}}" checked="{{form.commitment === item.value}}" color="{{themePrimaryColor}}"/>
                <text>{{item.label}}</text>
              </label>
            </view>
          </radio-group>
          <text wx:if="{{errors.commitment}}" class="form-error">{{errors.commitment}}</text>
        </view>

        <view class="step-actions">
          <button class="btn btn-secondary" bindtap="handleCancel">取消</button>
          <button class="btn btn-primary" bindtap="goNextStep">下一步 →</button>
        </view>
      </block>

      <!-- Step 2: 了解你（选填） -->
      <block wx:elif="{{currentStep === 2}}">
        <!-- 性别 -->
        <view class="form-group">
          <view class="form-label">
            <text class="required">*</text>
            <text>性别</text>
          </view>
          <radio-group bindchange="handleRadioChange" data-field="gender">
            <view class="radio-group">
              <label class="radio-item" wx:for="{{genderOptions}}" wx:key="value">
                <radio value="{{item.value}}" checked="{{form.gender === item.value}}" color="{{themePrimaryColor}}"/>
                <text>{{item.label}}</text>
              </label>
            </view>
          </radio-group>
          <text wx:if="{{errors.gender}}" class="form-error">{{errors.gender}}</text>
        </view>

        <!-- 地址 -->
        <view class="form-group">
          <view class="form-label">
            <text class="required">*</text>
            <text>地址</text>
          </view>
          <view class="address-group">
            <picker bindchange="handleProvinceChange" value="{{selectedProvinceIndex}}" range="{{provinceList}}">
              <view class="form-control picker-control {{errors.province ? 'form-control-error' : ''}}">
                <text>{{form.province || '请选择省/市/区(县)'}}</text>
                <text class="picker-icon">›</text>
              </view>
            </picker>
            <input
              type="text"
              class="form-control"
              placeholder="详细地址（选填）"
              value="{{form.detailedAddress}}"
              bindinput="handleInput"
              data-field="detailedAddress"
              maxlength="100"
            />
          </view>
          <text wx:if="{{errors.province}}" class="form-error">{{errors.province}}</text>
        </view>

        <!-- 年龄 -->
        <view class="form-group">
          <view class="form-label">
            <text class="required">*</text>
            <text>年龄</text>
          </view>
          <input
            type="number"
            class="form-control {{errors.age ? 'form-control-error' : ''}}"
            placeholder="请输入您的年龄（11-120）"
            value="{{form.age}}"
            bindinput="handleNumberInput"
            bindblur="handleNumberBlur"
            data-field="age"
            maxlength="3"
          />
          <text wx:if="{{errors.age}}" class="form-error">{{errors.age}}</text>
        </view>

        <!-- 是否读过 -->
        <view class="form-group">
          <view class="form-label">
            <text class="required">*</text>
            <text>您是否读过《高效能人士的七个习惯》</text>
          </view>
          <radio-group bindchange="handleRadioChange" data-field="hasReadBook">
            <view class="radio-group">
              <label class="radio-item" wx:for="{{readOptions}}" wx:key="value">
                <radio value="{{item.value}}" checked="{{form.hasReadBook === item.value}}" color="{{themePrimaryColor}}"/>
                <text>{{item.label}}</text>
              </label>
            </view>
          </radio-group>
          <text wx:if="{{errors.hasReadBook}}" class="form-error">{{errors.hasReadBook}}</text>
        </view>

        <!-- 读过几遍 -->
        <view wx:if="{{form.hasReadBook === 'yes'}}" class="form-group">
          <view class="form-label">
            <text class="required">*</text>
            <text>您读过几遍</text>
          </view>
          <input
            type="number"
            class="form-control {{errors.readTimes ? 'form-control-error' : ''}}"
            placeholder="请输入阅读次数（正整数）"
            value="{{form.readTimes}}"
            bindinput="handleNumberInput"
            bindblur="handleNumberBlur"
            data-field="readTimes"
            maxlength="3"
          />
          <text wx:if="{{errors.readTimes}}" class="form-error">{{errors.readTimes}}</text>
        </view>

        <!-- 参加课程的缘起 -->
        <view class="form-group">
          <view class="form-label">
            <text class="required">*</text>
            <text>您参加课程的缘起</text>
          </view>
          <textarea
            class="form-control textarea {{errors.enrollReason ? 'form-control-error' : ''}}"
            placeholder="请简述参加课程的原因..."
            value="{{form.enrollReason}}"
            bindinput="handleInput"
            data-field="enrollReason"
            maxlength="500"
          />
          <view class="text-count">{{form.enrollReason.length}}/500</view>
          <text wx:if="{{errors.enrollReason}}" class="form-error">{{errors.enrollReason}}</text>
        </view>

        <!-- 对课程的期待 -->
        <view class="form-group">
          <view class="form-label">
            <text class="required">*</text>
            <text>您对课程的期待</text>
          </view>
          <textarea
            class="form-control textarea {{errors.expectation ? 'form-control-error' : ''}}"
            placeholder="请简述对课程的期待..."
            value="{{form.expectation}}"
            bindinput="handleInput"
            data-field="expectation"
            maxlength="500"
          />
          <view class="text-count">{{form.expectation.length}}/500</view>
          <text wx:if="{{errors.expectation}}" class="form-error">{{errors.expectation}}</text>
        </view>

        <!-- 推荐人 -->
        <view class="form-group">
          <view class="form-label">
            <text>您的推荐人</text>
          </view>
          <input
            type="text"
            class="form-control"
            placeholder="请输入推荐人名字（选填）"
            value="{{form.referrer}}"
            bindinput="handleInput"
            data-field="referrer"
          />
        </view>

        <view class="step-actions">
          <button class="btn btn-secondary" bindtap="goPrevStep">← 上一步</button>
          <button class="btn btn-primary" bindtap="goNextStep">下一步 →</button>
        </view>
      </block>

      <!-- Step 3: 确认报名 -->
      <block wx:elif="{{currentStep === 3}}">
        <view class="confirm-section">
          <view class="confirm-title">确认报名信息</view>
          <view class="confirm-item">
            <text class="confirm-label">期次</text>
            <text class="confirm-value">{{selectedPeriodName}}</text>
          </view>
          <view class="confirm-item">
            <text class="confirm-label">姓名</text>
            <text class="confirm-value">{{form.name}}</text>
          </view>
          <view wx:if="{{form.phone}}" class="confirm-item">
            <text class="confirm-label">手机号</text>
            <text class="confirm-value">{{form.phone}}</text>
          </view>
          <view wx:if="{{form.referrer}}" class="confirm-item">
            <text class="confirm-label">推荐人</text>
            <text class="confirm-value">{{form.referrer}}</text>
          </view>
          <view class="confirm-item">
            <text class="confirm-label">承诺全程</text>
            <text class="confirm-value">{{form.commitment === 'yes' ? '是' : '否'}}</text>
          </view>
          <view wx:if="{{selectedPeriodPriceFen > 0}}" class="confirm-item confirm-item-price">
            <text class="confirm-label">报名金额</text>
            <text class="confirm-value confirm-price">¥{{selectedPeriodPrice}}</text>
          </view>
          <view wx:else class="confirm-item confirm-item-price">
            <text class="confirm-label">报名金额</text>
            <text class="confirm-value confirm-price-free">免费</text>
          </view>
        </view>

        <view class="step-actions">
          <button class="btn btn-secondary" bindtap="goPrevStep">← 上一步</button>
          <button class="btn btn-primary" formType="submit" loading="{{submitting}}">{{submitting ? '提交中...' : '提交报名'}}</button>
        </view>
      </block>

    </form>
  </view>
</view>

<podcast-player-bar />
