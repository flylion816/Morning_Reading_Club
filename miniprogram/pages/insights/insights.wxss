.page-insights {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.insights-header {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  padding: 32rpx;
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.header-emoji {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-weight: bold;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

.insights-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.insight-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 8rpx solid #4a90e2;
  min-height: 220rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.insight-item.is-locked {
  background: #fbfcff;
  border-left-color: #b8c4d9;
}

.insight-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.insight-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.insight-day {
  font-size: 22rpx;
  color: #4a90e2;
  font-weight: 500;
}

.insight-period {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.insight-title {
  font-weight: bold;
  font-size: 28rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
  min-height: 84rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.insight-preview {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
  flex: 1;
  min-height: 76rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.insight-lock-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  flex-shrink: 0;
}

.insight-lock-badge.locked {
  background: #eef2f9;
}

.insight-lock-badge.unlocked {
  background: #e8f8ef;
}

.insight-date {
  font-size: 22rpx;
  color: #999;
}

.permission-block {
  background: white;
  border-radius: 16rpx;
  padding: 60rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.permission-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.permission-text {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.permission-btn {
  display: inline-block;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  font-size: 28rpx;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
}

.permission-status {
  font-size: 26rpx;
  color: #999;
}

.permission-rejected {
  color: #e74c3c;
}

.insight-thumb {
  width: 100%;
  height: 96rpx;
  border-radius: 8rpx;
  background-repeat: no-repeat;
  background-size: cover;
  background-position: top center;
}

.insight-thumb-top {
  overflow: hidden;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}
