.page-insights {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
}

.insights-header {
  background: linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  color: white;
  padding: 32rpx;
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.header-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin: 0 auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.header-avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.header-emoji {
  font-size: 48rpx;
  line-height: 1;
}

.header-title {
  font-weight: bold;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 24rpx;
  opacity: 0.9;
}

/* Tab 栏 */
.insight-tab-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.insight-tab {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  padding: 20rpx 0;
  border-bottom: 4rpx solid transparent;
}

.insight-tab-active {
  color: var(--theme-primary);
  font-weight: 600;
  border-bottom-color: var(--theme-primary);
}

.insights-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.insight-item {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  border-left: 8rpx solid var(--theme-primary);
  min-height: 188rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.insight-item.is-locked {
  background: #fbfcff;
  border-left-color: #b8c4d9;
}

.insight-header {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

/* 卡片头像 */
.insight-card-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.insight-card-avatar-img {
  width: 100%;
  height: 100%;
}

.insight-card-avatar-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

/* 标题+期次横排，期次右对齐 */
.insight-title-meta {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.insight-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.insight-day {
  font-size: 22rpx;
  color: var(--theme-primary);
  font-weight: 500;
}

.insight-period {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  flex-shrink: 0;
  max-width: 220rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.insight-title {
  font-weight: bold;
  font-size: 28rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.insight-preview {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
  flex: 1;
  min-height: 52rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.locked-placeholder {
  flex: 1;
  min-height: 52rpx;
  margin-bottom: 12rpx;
  border-radius: 12rpx;
  background:
    linear-gradient(135deg, var(--theme-primary-alpha-05) 0%, var(--theme-primary-alpha-01) 100%);
  border: 1rpx dashed var(--theme-primary-alpha-18);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 16rpx;
  box-sizing: border-box;
}

.locked-placeholder-text {
  color: #8a94a6;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
}

.insight-request-state {
  align-self: flex-start;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.insight-request-state.approved {
  background: #e8f8ef;
  color: #1f9d55;
}

.insight-request-state.pending {
  background: #fff3e6;
  color: #d97a00;
}

.insight-request-state.rejected,
.insight-request-state.revoked {
  background: #fdecec;
  color: #d64545;
}

.insight-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: auto;
}

.insight-request-spacer {
  min-width: 2rpx;
  min-height: 40rpx;
}

.insight-date {
  font-size: 22rpx;
  color: #999;
  margin-left: auto;
  text-align: right;
  line-height: 1.4;
}

.insight-thumb {
  width: 100%;
  height: 96rpx;
  border-radius: 8rpx;
  background-repeat: no-repeat;
  background-size: cover;
  background-position: top center;
}

.insight-thumb-top {
  overflow: hidden;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
}

.request-share-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
  background: rgba(0, 0, 0, 0.52);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.request-share-panel {
  width: 100%;
  max-width: 560rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 54rpx 0 0;
  box-sizing: border-box;
  overflow: hidden;
  box-shadow: 0 20rpx 64rpx rgba(15, 23, 42, 0.18);
}

.request-share-title {
  padding: 0 48rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.35;
  text-align: center;
}

.request-share-desc {
  margin-top: 26rpx;
  padding: 0 48rpx;
  font-size: 28rpx;
  color: #7a7f89;
  line-height: 1.55;
  text-align: center;
}

.request-share-target {
  margin: 28rpx 42rpx 42rpx;
  padding: 18rpx 22rpx;
  border-radius: 12rpx;
  background: #f5f7fb;
  color: #426ea9;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.45;
  text-align: center;
}

.request-share-actions {
  display: flex;
  border-top: 1rpx solid #edf0f5;
}

.request-share-secondary,
.request-share-primary {
  flex: 1;
  height: 96rpx;
  border-radius: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 96rpx;
  white-space: nowrap;
}

.request-share-secondary::after,
.request-share-primary::after {
  border: none;
}

.request-share-secondary {
  color: #1f2937;
}

.request-share-primary {
  color: #4a6f9f;
  border-left: 1rpx solid #edf0f5;
}

.insight-search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.insight-search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 24rpx;
  height: 72rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  position: relative;
}

.insight-search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  height: 72rpx;
  line-height: 72rpx;
}

.insight-search-clear {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #ccc;
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  line-height: 1;
}

.insight-search-btn {
  background: var(--theme-primary);
  color: #fff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 40rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
