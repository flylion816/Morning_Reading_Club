<view class="page-insights">
  <view class="insights-header">
    <view class="header-emoji">{{headerEmoji}}</view>
    <view class="header-title">{{headerTitle}}</view>
    <view class="header-desc">{{headerDesc}}</view>
  </view>

  <view class="insights-list">
    <view
      wx:for="{{insights}}"
      wx:key="id"
      class="insight-item {{item.isAccessible ? 'is-unlocked' : 'is-locked'}}"
      bindtap="handleInsightClick"
      data-id="{{item.id}}"
      data-accessible="{{item.isAccessible}}"
      data-period-id="{{item.periodId}}"
      data-request-status="{{item.requestStatus}}"
      data-title="{{item.title}}"
      data-period-name="{{item.periodName}}"
      data-day-number="{{item.dayNumber}}">
      <view class="insight-header">
        <view class="insight-title">{{item.title}}</view>
        <view class="insight-meta">
          <view class="insight-period">{{item.periodName}}</view>
        </view>
      </view>
      <block wx:if="{{item.mediaType === 'image' && item.imageUrl}}">
        <view class="insight-preview">
          <view
            class="insight-thumb insight-thumb-top"
            style="background-image: url('{{item.imageUrl}}');"></view>
        </view>
      </block>
      <block wx:elif="{{!item.isAccessible}}">
        <view class="locked-placeholder">
          <view class="locked-placeholder-text">{{item.lockedPlaceholder.text}}</view>
        </view>
      </block>
      <block wx:else>
        <view class="insight-preview">{{item.preview}}</view>
      </block>
      <view class="insight-footer">
        <view
          wx:if="{{isOtherUser && item.requestStatusText}}"
          class="insight-request-state {{item.requestStatus}}">
          {{item.requestStatusText}}
        </view>
        <view wx:else class="insight-request-spacer"></view>
        <view class="insight-date">{{item.date}}</view>
      </view>
    </view>

    <view class="empty-state" wx:if="{{insights.length === 0}}">
      <text class="empty-icon">✨</text>
      <text class="empty-text">暂无反馈</text>
    </view>
  </view>

  <view wx:if="{{showRequestSharePrompt}}" class="request-share-mask" catchtap="closeRequestSharePrompt">
    <view class="request-share-panel" catchtap="stopTap">
      <view class="request-share-title">申请已发送</view>
      <view class="request-share-desc">
        转发给{{pendingShareRequest.toUserName}}，对方点开后会直接定位到这条请求。
      </view>
      <view class="request-share-target">{{pendingShareRequest.requestLabel}}</view>
      <view class="request-share-actions">
        <button class="request-share-secondary" catchtap="closeRequestSharePrompt">取消转发到微信</button>
        <button
          class="request-share-primary"
          open-type="share"
          data-share-type="insightRequest">
          转发给好友或群
        </button>
      </view>
    </view>
  </view>
</view>
