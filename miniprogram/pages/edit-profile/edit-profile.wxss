.page-edit-profile {
  min-height: 100vh;
  background: #f6f7f9;
  padding: 24rpx 24rpx 168rpx;
  box-sizing: border-box;
}

/* Section */
.section {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  font-weight: 600;
}

/* Avatar */
.avatar-picker-panel {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f7fbff 0%, #eef6ff 100%);
  border: 1rpx solid #dbeafe;
  border-radius: 20rpx;
}

.avatar-preview {
  width: 116rpx;
  height: 116rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.18);
  overflow: hidden;
}

.avatar-preview-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-preview-emoji {
  font-size: 62rpx;
  line-height: 1;
}

.avatar-picker-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.avatar-picker-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.3;
}

.avatar-picker-desc {
  font-size: 23rpx;
  color: #6b7280;
  line-height: 1.4;
}

.avatar-action-button {
  width: 220rpx;
  height: 64rpx;
  flex-shrink: 0;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

button.avatar-action-button {
  margin: 0;
  padding: 0;
  line-height: 64rpx;
  border: none;
}

button.avatar-action-button::after {
  border: none;
}

.avatar-action-button.primary {
  color: #fff;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  box-shadow: 0 8rpx 18rpx rgba(74, 144, 226, 0.22);
}

/* Input field */
.input-wrap {
  position: relative;
}

.field-input {
  width: 100%;
  height: 76rpx;
  padding: 0 100rpx 0 0;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #e5e7eb;
  box-sizing: border-box;
}

.field-input:focus {
  border-bottom-color: #4a90e2;
}

/* Textarea */
.textarea-wrap {
  position: relative;
}

.field-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 0 100rpx 0 0;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  border-bottom: 1rpx solid #e5e7eb;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}

.field-textarea:focus {
  border-bottom-color: #4a90e2;
}

/* Placeholder */
.field-placeholder {
  color: #bbb;
  font-size: 30rpx;
}

/* Char count */
.char-count {
  position: absolute;
  right: 0;
  bottom: 8rpx;
  font-size: 24rpx;
  color: #bbb;
}

/* Save bar fixed at bottom */
.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.save-btn:active:not(.loading) {
  opacity: 0.85;
  transform: scale(0.98);
}

.save-btn.loading {
  opacity: 0.65;
  pointer-events: none;
}
