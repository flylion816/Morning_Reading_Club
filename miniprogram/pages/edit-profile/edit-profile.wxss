.page-edit-profile {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 24rpx 160rpx;
  box-sizing: border-box;
}

/* Section */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
  font-weight: 500;
}

/* Avatar section */
.avatar-section {
  text-align: center;
}

.current-avatar-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.current-avatar {
  font-size: 96rpx;
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  text-align: center;
  background: #f0f4ff;
  border-radius: 50%;
  border: 4rpx solid #4a90e2;
}

/* Avatar grid: 4 columns, 3 rows */
.avatar-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.avatar-item {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  border: 3rpx solid #e0e0e0;
  background: #fafafa;
  transition: all 0.2s;
}

.avatar-item:active {
  transform: scale(0.92);
}

.avatar-item.selected {
  border-color: #4a90e2;
  background: #f0f6ff;
  box-shadow: 0 0 12rpx rgba(74, 144, 226, 0.35);
}

.avatar-emoji {
  font-size: 52rpx;
}

/* Input field */
.input-wrap {
  position: relative;
}

.field-input {
  width: 100%;
  height: 80rpx;
  padding: 0 100rpx 0 0;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #e0e0e0;
  box-sizing: border-box;
}

.field-input:focus {
  border-bottom-color: #4a90e2;
}

/* Textarea */
.textarea-wrap {
  position: relative;
}

.field-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 0 100rpx 0 0;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  border-bottom: 1rpx solid #e0e0e0;
  box-sizing: border-box;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}

.field-textarea:focus {
  border-bottom-color: #4a90e2;
}

/* Placeholder */
.field-placeholder {
  color: #bbb;
  font-size: 30rpx;
}

/* Char count */
.char-count {
  position: absolute;
  right: 0;
  bottom: 8rpx;
  font-size: 24rpx;
  color: #bbb;
}

/* Save bar fixed at bottom */
.save-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.save-btn:active:not(.loading) {
  opacity: 0.85;
  transform: scale(0.98);
}

.save-btn.loading {
  opacity: 0.65;
  pointer-events: none;
}
