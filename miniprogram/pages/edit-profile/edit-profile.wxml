<!--编辑资料页面-->
<view class="page-edit-profile">
  <!-- 头像选择区 -->
  <view class="section avatar-section">
    <view class="section-title">选择头像</view>
    <view class="current-avatar-wrap">
      <text class="current-avatar">{{avatar}}</text>
    </view>
    <view class="avatar-grid">
      <view
        wx:for="{{avatarList}}"
        wx:key="index"
        class="avatar-item {{avatar === item ? 'selected' : ''}}"
        bindtap="selectAvatar"
        data-avatar="{{item}}"
      >
        <text class="avatar-emoji">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 昵称输入 -->
  <view class="section">
    <view class="section-title">昵称</view>
    <view class="input-wrap">
      <input
        class="field-input"
        type="text"
        placeholder="请输入昵称"
        placeholder-class="field-placeholder"
        value="{{nickname}}"
        bindinput="onNicknameInput"
        maxlength="20"
      />
      <text class="char-count">{{nickname.length}}/20</text>
    </view>
  </view>

  <!-- 个性签名输入 -->
  <view class="section">
    <view class="section-title">个性签名</view>
    <view class="textarea-wrap">
      <textarea
        class="field-textarea"
        placeholder="写一句个性签名吧"
        placeholder-class="field-placeholder"
        value="{{signature}}"
        bindinput="onSignatureInput"
        maxlength="200"
        show-confirm-bar="false"
        auto-height
      ></textarea>
      <text class="char-count">{{signature.length}}/200</text>
    </view>
  </view>

  <!-- 底部保存按钮 -->
  <view class="save-bar">
    <view class="save-btn {{saving ? 'loading' : ''}}" bindtap="handleSave">
      <text>{{saving ? '保存中...' : '保存'}}</text>
    </view>
  </view>
</view>
