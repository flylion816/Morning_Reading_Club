.page-activity-registrations {
  min-height: 100vh;
  background: #f4f6f8;
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.activity-summary,
.registration-card,
.state-box,
.load-more {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 14rpx rgba(31, 41, 55, 0.05);
}

.activity-summary {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.summary-head,
.summary-row,
.name-row,
.foot-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.activity-title {
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.status-pill {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: var(--theme-primary-tint);
  color: var(--theme-primary);
  font-size: 22rpx;
}

.summary-row {
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
}

.summary-stats,
.chip-row,
.metric-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.summary-stats {
  margin-top: 18rpx;
}

.summary-stats text {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #475467;
  font-size: 22rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.search-input {
  flex: 1;
  height: 68rpx;
  border-radius: 10rpx;
  background: #ffffff;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.search-btn {
  width: 132rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 10rpx;
  background: var(--theme-primary);
  color: #ffffff;
  font-size: 26rpx;
  padding: 0;
}

.search-btn::after {
  border: 0;
}

.tab-row {
  display: flex;
  gap: 10rpx;
  padding: 8rpx;
  margin-bottom: 18rpx;
  border-radius: 12rpx;
  background: #e9eef5;
}

.tab-item {
  flex: 1;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 10rpx;
  color: #667085;
  font-size: 26rpx;
  text-align: center;
}

.tab-item.active {
  background: #ffffff;
  color: var(--theme-primary);
  font-weight: 700;
}

.state-box {
  padding: 44rpx 20rpx;
  color: #98a2b3;
  font-size: 26rpx;
  text-align: center;
}

.state-box.small {
  padding: 24rpx 0;
  box-shadow: none;
  background: transparent;
}

.registration-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border-radius: 10rpx;
  background: #ffffff;
  color: #667085;
  font-size: 24rpx;
}

.filter-clear {
  color: var(--theme-primary);
}

.registration-card {
  padding: 22rpx;
}

.user-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  overflow: hidden;
  color: var(--theme-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-text {
  line-height: 76rpx;
}

.user-main {
  min-width: 0;
  flex: 1;
}

.user-name {
  min-width: 0;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.amount {
  flex-shrink: 0;
  color: var(--theme-primary);
  font-size: 28rpx;
  font-weight: 700;
}

.phone {
  display: block;
  margin-top: 8rpx;
  color: #98a2b3;
  font-size: 22rpx;
}

.metric-row {
  margin-top: 18rpx;
}

.metric {
  flex: 1;
  min-width: 150rpx;
  padding: 14rpx 10rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  text-align: center;
}

.metric-value {
  display: block;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.metric-label {
  display: block;
  margin-top: 4rpx;
  color: #667085;
  font-size: 20rpx;
  line-height: 28rpx;
}

.chip-row {
  margin-top: 16rpx;
}

.answer-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 14rpx;
}

.answer-chip {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: #fff7ed;
  color: #9a3412;
  font-size: 22rpx;
  line-height: 30rpx;
}

.chip {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #475467;
  font-size: 22rpx;
  line-height: 30rpx;
}

.chip.blue {
  background: var(--theme-primary-tint);
  color: var(--theme-primary);
}

.foot-row {
  margin-top: 14rpx;
  color: #98a2b3;
  font-size: 22rpx;
}

.load-more {
  margin-top: 8rpx;
  padding: 22rpx 0;
  color: var(--theme-primary);
  text-align: center;
  font-size: 26rpx;
}

.stats-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.stats-card {
  padding: 22rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(31, 41, 55, 0.05);
}

.stats-title {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.stats-option,
.stats-right,
.detail-head,
.detail-meta,
.detail-answer-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.stats-option {
  min-height: 62rpx;
  border-top: 1rpx solid #eef2f7;
  color: #344054;
  font-size: 25rpx;
}

.stats-right {
  color: #667085;
  font-size: 24rpx;
}

.stats-link {
  color: var(--theme-primary);
}

.detail-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}

.detail-sheet {
  width: 100%;
  max-height: 72vh;
  padding: 28rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  border-radius: 28rpx 28rpx 0 0;
  background: #ffffff;
}

.detail-title {
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 700;
}

.detail-close {
  color: var(--theme-primary);
  font-size: 26rpx;
}

.detail-meta {
  justify-content: flex-start;
  flex-wrap: wrap;
  margin-top: 14rpx;
  color: #667085;
  font-size: 23rpx;
}

.detail-section-title {
  margin-top: 24rpx;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 700;
}

.detail-answer-list {
  margin-top: 10rpx;
}

.detail-answer-row {
  min-height: 64rpx;
  border-bottom: 1rpx solid #eef2f7;
}

.detail-answer-label {
  color: #667085;
  font-size: 25rpx;
}

.detail-answer-value {
  color: #1f2937;
  font-size: 25rpx;
  font-weight: 600;
  text-align: right;
}
