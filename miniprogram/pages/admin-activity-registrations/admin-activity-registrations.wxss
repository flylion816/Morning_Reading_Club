.page-activity-registrations {
  min-height: 100vh;
  background: #f4f6f8;
  padding: 20rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.activity-summary,
.registration-card,
.state-box,
.load-more {
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 14rpx rgba(31, 41, 55, 0.05);
}

.activity-summary {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.summary-head,
.summary-row,
.name-row,
.foot-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.activity-title {
  flex: 1;
  min-width: 0;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.status-pill {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 22rpx;
}

.summary-row {
  margin-top: 12rpx;
  color: #667085;
  font-size: 24rpx;
}

.summary-stats,
.chip-row,
.metric-row {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.summary-stats {
  margin-top: 18rpx;
}

.summary-stats text {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #475467;
  font-size: 22rpx;
}

.search-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.search-input {
  flex: 1;
  height: 68rpx;
  border-radius: 10rpx;
  background: #ffffff;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.search-btn {
  width: 132rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 10rpx;
  background: #2563eb;
  color: #ffffff;
  font-size: 26rpx;
  padding: 0;
}

.search-btn::after {
  border: 0;
}

.state-box {
  padding: 44rpx 20rpx;
  color: #98a2b3;
  font-size: 26rpx;
  text-align: center;
}

.registration-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.registration-card {
  padding: 22rpx;
}

.user-line {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  overflow: hidden;
  color: #2563eb;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.avatar-image {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-text {
  line-height: 76rpx;
}

.user-main {
  min-width: 0;
  flex: 1;
}

.user-name {
  min-width: 0;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 700;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.amount {
  flex-shrink: 0;
  color: #2563eb;
  font-size: 28rpx;
  font-weight: 700;
}

.phone {
  display: block;
  margin-top: 8rpx;
  color: #98a2b3;
  font-size: 22rpx;
}

.metric-row {
  margin-top: 18rpx;
}

.metric {
  flex: 1;
  min-width: 150rpx;
  padding: 14rpx 10rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  text-align: center;
}

.metric-value {
  display: block;
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 36rpx;
}

.metric-label {
  display: block;
  margin-top: 4rpx;
  color: #667085;
  font-size: 20rpx;
  line-height: 28rpx;
}

.chip-row {
  margin-top: 16rpx;
}

.chip {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  background: #f1f5f9;
  color: #475467;
  font-size: 22rpx;
  line-height: 30rpx;
}

.chip.blue {
  background: #eff6ff;
  color: #2563eb;
}

.foot-row {
  margin-top: 14rpx;
  color: #98a2b3;
  font-size: 22rpx;
}

.load-more {
  margin-top: 8rpx;
  padding: 22rpx 0;
  color: #2563eb;
  text-align: center;
  font-size: 26rpx;
}
