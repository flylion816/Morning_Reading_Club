.page-notification-settings {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.settings-header {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  color: white;
  margin-bottom: 20rpx;
}

.settings-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.settings-desc {
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  opacity: 0.92;
}

.summary-card {
  background: white;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(53, 122, 189, 0.08);
}

.summary-main {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.summary-block {
  flex: 1;
  background: #f5f9ff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.summary-number {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #357abd;
}

.summary-label {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6b7280;
}

.subscribe-all-btn {
  width: 100%;
  border-radius: 999rpx;
  background: #4a90e2;
  color: white;
  font-size: 26rpx;
  font-weight: 600;
}

.subscribe-all-btn::after {
  border: none;
}

.subscribe-all-hint {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #64748b;
}

.loading-state {
  padding: 120rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 26rpx;
}

.scene-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.scene-card {
  background: white;
  border-radius: 20rpx;
  padding: 26rpx;
  display: flex;
  gap: 20rpx;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(15, 23, 42, 0.05);
}

.scene-copy {
  flex: 1;
  min-width: 0;
}

.scene-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.scene-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.scene-count {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.scene-count.has-count {
  background: #e8f6ee;
  color: #1f9d55;
}

.scene-count.empty-count {
  background: #eef2f7;
  color: #64748b;
}

.scene-desc {
  display: block;
  font-size: 23rpx;
  color: #64748b;
  line-height: 1.6;
}

.scene-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  color: #94a3b8;
}

.scene-action {
  min-width: 180rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #edf4ff;
  color: #357abd;
  font-size: 24rpx;
  font-weight: 600;
}

.scene-action::after {
  border: none;
}
