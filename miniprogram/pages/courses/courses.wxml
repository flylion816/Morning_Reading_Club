<!--课节列表页-->
<view class="page-courses">
  <!-- 头部区域（滚动时收起） -->
  <view class="page-header {{headerCollapsed ? 'collapsed' : ''}}">
    <view class="header-content">
      <view class="period-name">{{periodName}}</view>
      <view class="period-date">{{periodDate}}</view>
    </view>
  </view>

  <!-- 待支付提醒横幅 -->
  <view class="payment-banner" wx:if="{{paymentPending}}" bindtap="navigateToPayment">
    <view class="payment-banner-content">
      <text class="payment-banner-icon">💳</text>
      <text class="payment-banner-text">您有待支付订单（¥99），点击前往支付</text>
    </view>
    <text class="payment-banner-arrow">›</text>
  </view>

  <!-- 功能按钮区（紧凑横排 + 滚动时收起） -->
  <view class="action-buttons {{headerCollapsed ? 'collapsed' : ''}}" wx:if="{{communityAccessState === 'enabled'}}">
    <view class="action-btn" bindtap="handleRanking">
      <text class="btn-icon">🏆</text>
      <text class="btn-text">排行榜</text>
    </view>
    <view class="action-btn" bindtap="handleCheckinRecords">
      <text class="btn-icon">📅</text>
      <text class="btn-text">打卡记录</text>
    </view>
    <view class="action-btn" bindtap="handleMembers">
      <text class="btn-icon">👥</text>
      <text class="btn-text">成员</text>
    </view>
  </view>

  <!-- Tab切换 -->
  <view class="tabs-container" wx:if="{{communityAccessState === 'enabled'}}">
    <view class="tabs">
      <view
        class="tab-item {{currentTab === 'tasks' ? 'active' : ''}}"
        bindtap="handleTabChange"
        data-tab="tasks">
        <text>任务</text>
        <view class="tab-underline" wx:if="{{currentTab === 'tasks'}}"></view>
      </view>
      <view
        class="tab-item {{currentTab === 'dynamics' ? 'active' : ''}}"
        bindtap="handleTabChange"
        data-tab="dynamics"
        wx:if="{{communityAccessState === 'enabled'}}">
        <text>动态</text>
        <view class="tab-underline" wx:if="{{currentTab === 'dynamics'}}"></view>
      </view>
    </view>
  </view>

  <!-- 滚动内容区 -->
  <scroll-view
    scroll-y
    class="content-scroll"
    scroll-top="{{scrollTop}}"
    scroll-with-animation
    bindscroll="onContentScroll">

    <!-- 任务区域 -->
    <view id="tasks-section" class="section-wrapper">
      <!-- 课节列表 -->
      <view class="sections-container">
        <view
          wx:for="{{sections}}"
          wx:key="id"
          class="section-card"
          bindtap="handleSectionClick"
          data-section="{{item}}">
          <!-- 课节标题 -->
          <view class="section-title">{{item.title}}</view>

          <!-- 时间范围 -->
          <view class="section-time" wx:if="{{item.startTime && item.endTime}}">{{item.startTime.split('T')[0]}} 至 {{item.endTime.split('T')[0]}}</view>

          <!-- 底部：人数信息 + 按钮 -->
          <view class="section-footer">
            <text class="checkin-info">{{item.checkinCount || 0}}人{{communityAccessState === 'enabled' ? '已打卡' : '已学习'}}</text>
            <view class="btn-action" catchtap="handleCheckinClick" data-section="{{item}}">
              {{communityAccessState === 'enabled' ? '去打卡' : '去学习'}}
            </view>
          </view>
        </view>

        <!-- 加载中 -->
        <view wx:if="{{loading && sections.length === 0}}" class="loading-container">
          <view class="loading-spinner"></view>
          <text class="loading-text">加载中...</text>
        </view>

        <!-- 空状态 -->
        <view wx:if="{{!loading && sections.length === 0}}" class="empty-state">
          <text class="empty-state-icon">📚</text>
          <text class="empty-state-text">暂无课节</text>
        </view>
      </view>
    </view>

    <!-- 动态区域（打卡记录） -->
    <view id="dynamics-section" class="section-wrapper" wx:if="{{communityAccessState === 'enabled'}}">
      <view class="all-checkins-section" wx:if="{{allCheckins.length > 0}}">
        <view class="checkins-header">
          <text class="checkins-title">所有打卡记录</text>
          <text class="checkins-count">（{{allCheckins.length}} 条）</text>
        </view>

        <view class="checkins-list">
          <view class="checkin-item" wx:for="{{allCheckins}}" wx:key="id">
            <view class="checkin-avatar" style="background: {{item.avatarColor || '#4a90e2'}}" bindtap="handleAvatarClick" data-user-id="{{item.userId}}">
              <text class="avatar-text">{{item.avatarText || item.userName}}</text>
            </view>
            <view class="checkin-main">
              <!-- 用户名 + 第几天标签 + 时间 -->
              <view class="checkin-top">
                <view class="checkin-user-section">
                  <text class="checkin-user" bindtap="handleAvatarClick" data-user-id="{{item.userId}}">{{item.userName}}</text>
                  <text class="section-tag">第{{item.sectionDay}}天</text>
                </view>
                <text class="checkin-time">{{item.createTime}}</text>
              </view>
              <!-- 课节标题 -->
              <view class="checkin-section-title">{{item.sectionTitle}}</view>
              <!-- 打卡内容 -->
              <view class="checkin-content">{{item.content}}</view>
            </view>
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{allCheckins.length === 0}}" class="empty-state">
        <text class="empty-state-icon">📝</text>
        <text class="empty-state-text">暂无打卡记录</text>
      </view>
    </view>
  </scroll-view>
</view>
