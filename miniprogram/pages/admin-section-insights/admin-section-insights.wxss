.page-admin-insights {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.page-header {
  background: #fff;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
}

.header-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #4a90e2;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #999;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.insights-scroll {
  flex: 1;
  padding: 20rpx 24rpx;
}

.insight-card {
  background: white;
  border-radius: 16rpx;
  padding: 28rpx 28rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-user {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-text {
  color: white;
  font-size: 28rpx;
  font-weight: 600;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.share-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.share-tag.shared {
  color: #059669;
  background: #d1fae5;
}

.share-tag.unshared {
  color: #999;
  background: #f3f4f6;
}

.card-image-wrap {
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.card-image {
  width: 100%;
  height: 300rpx;
  display: block;
}

.card-preview {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 5;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f3f4f6;
}

.like-count,
.danmaku-count {
  font-size: 24rpx;
  color: #999;
}

.card-arrow {
  font-size: 36rpx;
  color: #ccc;
  font-weight: bold;
  margin-left: auto;
}
