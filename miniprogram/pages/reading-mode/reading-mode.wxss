.page-reading-mode {
  min-height: 100vh;
  background: #fffdf8;
  color: #2f3437;
}

.reader-init-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fffdf8;
  z-index: 999;
}

.reading-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  min-height: 112rpx;
  display: flex;
  align-items: center;
  padding-left: 24rpx;
  padding-right: 24rpx;
  box-sizing: content-box;
  background: rgba(255, 253, 248, 0.94);
  backdrop-filter: blur(16rpx);
  border-bottom: 1rpx solid rgba(31, 41, 55, 0.06);
}

.reading-back {
  width: 72rpx;
  height: 72rpx;
  line-height: 66rpx;
  text-align: center;
  font-size: 64rpx;
  color: #4a5568;
  flex-shrink: 0;
}

.reading-title-wrap {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
}

.reading-title-row {
  display: block;
}

.reading-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1f2937;
}

.reading-progress {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #4a90e2;
  font-weight: 700;
}

.reading-progress-bar-wrap {
  margin-top: 10rpx;
}

.reading-progress-bar-track {
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(74, 144, 226, 0.15);
  overflow: hidden;
}

.reading-progress-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4a90e2 0%, #357abd 100%);
  transition: width 0.3s ease;
}

.reader-scroll {
  height: 100vh;
}

.reader-content {
  padding-left: 48rpx;
  padding-right: 48rpx;
  padding-bottom: calc(54vh + 180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.reader-meta {
  padding: 48rpx 0 36rpx;
}

.reader-period {
  display: inline-flex;
  max-width: 100%;
  margin-left: -18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #357abd;
  font-size: 24rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.reader-heading {
  margin-top: 28rpx;
  color: #e85d6a;
  font-size: 32rpx;
  font-weight: 800;
  text-decoration: underline;
  text-underline-offset: 6rpx;
}

.reader-paragraph {
  position: relative;
  margin: 0 0 34rpx;
  padding: 0 0 0 22rpx;
  color: rgba(86, 96, 109, 0.56);
  font-size: 36rpx;
  line-height: 2.05;
  letter-spacing: 0;
  font-weight: 500;
  transition:
    color 0.42s ease,
    opacity 0.42s ease,
    background-color 0.42s ease;
}

.reader-paragraph::before {
  content: "";
  position: absolute;
  left: 0;
  top: 18rpx;
  bottom: 18rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: transparent;
  opacity: 0;
  transition: background-color 0.42s ease, opacity 0.42s ease;
}

.reader-paragraph-active {
  color: #1f2937;
  font-weight: 700;
  opacity: 1;
}

.reader-paragraph-active::before {
  background: #4a90e2;
  opacity: 1;
}

.reader-font-large .reader-paragraph {
  font-size: 40rpx;
}

.reader-font-xlarge .reader-paragraph {
  font-size: 44rpx;
}

.reader-empty {
  padding: 160rpx 0;
  text-align: center;
  color: #9ca3af;
  font-size: 28rpx;
}

.reading-toolbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 30;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(74, 144, 226, 0.12);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 50rpx rgba(31, 41, 55, 0.12);
  box-sizing: border-box;
  backdrop-filter: blur(18rpx);
}

.toolbar-btn {
  height: 72rpx;
  min-width: 88rpx;
  padding: 0 20rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4b5563;
  font-size: 26rpx;
  font-weight: 700;
  background: #f4f6f8;
  box-sizing: border-box;
}

.toolbar-btn-primary {
  flex: 1;
  min-width: 0;
  color: #ffffff;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  box-shadow: 0 10rpx 24rpx rgba(74, 144, 226, 0.24);
}

.toolbar-btn-secondary {
  flex: 1;
  min-width: 0;
  padding: 0;
  color: #357abd;
  background: #eef5ff;
}

.poster-panel-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(8, 15, 30, 0.76);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.poster-panel {
  width: 100%;
  max-height: 92vh;
  border-radius: 36rpx 36rpx 0 0;
  background: #fffdf8;
  padding: 28rpx;
  box-sizing: border-box;
}

.poster-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.poster-panel-title {
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 800;
}

.poster-panel-subtitle {
  margin-top: 6rpx;
  color: #7b8798;
  font-size: 22rpx;
}

.poster-panel-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #eff3f8;
  color: #7b8798;
  font-size: 34rpx;
  line-height: 56rpx;
  text-align: center;
}

.poster-preview-wrap {
  height: 760rpx;
  border-radius: 24rpx;
  background: #edf2f7;
  overflow: hidden;
  box-shadow: inset 0 0 0 1rpx rgba(31, 41, 55, 0.06);
}

.poster-preview {
  width: 100%;
  height: 100%;
}

.poster-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.poster-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  background: #4a90e2;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.poster-btn::after {
  border: none;
}

.poster-btn-plain {
  background: #f4f6f8;
  color: #4b5563;
}

.poster-btn-ghost {
  background: #eef5ff;
  color: #357abd;
}

.reading-poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 900px;
  height: 1800px;
  opacity: 0;
  pointer-events: none;
}


.reader-image {
  width: 100%;
  border-radius: 8rpx;
  display: block;
}

.reading-completion-card {
  position: relative;
  margin: 54rpx 0 28rpx;
  padding: 34rpx 32rpx 48rpx;
  border: 1rpx solid rgba(16, 185, 129, 0.22);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f1fbf5 0%, #fffdf8 100%);
  box-shadow: 0 14rpx 34rpx rgba(16, 185, 129, 0.1);
  overflow: visible;
}

.completion-kicker {
  display: inline-flex;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(16, 185, 129, 0.12);
  color: #047857;
  font-size: 22rpx;
  font-weight: 700;
}

.completion-title {
  margin-top: 18rpx;
  color: #1f2937;
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 800;
}

.completion-text {
  margin-top: 12rpx;
  color: #56606d;
  font-size: 27rpx;
  line-height: 1.8;
  font-weight: 500;
}

.completion-fireworks-ring {
  position: absolute;
  left: -18rpx;
  right: -18rpx;
  top: -18rpx;
  bottom: -18rpx;
  pointer-events: none;
  opacity: 0;
  animation: fireworksFade 5s ease-out forwards;
}

.firework {
  position: absolute;
  width: 44rpx;
  height: 44rpx;
  transform: scale(0.2);
  opacity: 0;
  animation: fireworkBloom 1.08s ease-out forwards;
}

.firework-1 {
  left: 2%;
  top: 8rpx;
  animation-delay: 0.05s;
}

.firework-2 {
  left: 36%;
  top: -6rpx;
  animation-delay: 0.18s;
}

.firework-3 {
  right: 6%;
  top: 8rpx;
  animation-delay: 0.1s;
}

.firework-4 {
  right: -6rpx;
  top: 42%;
  animation-delay: 0.26s;
}

.firework-5 {
  right: 8%;
  bottom: -6rpx;
  animation-delay: 0.15s;
}

.firework-6 {
  left: 44%;
  bottom: -12rpx;
  animation-delay: 0.32s;
}

.firework-7 {
  left: 8%;
  bottom: -6rpx;
  animation-delay: 0.21s;
}

.firework-8 {
  left: -6rpx;
  top: 44%;
  animation-delay: 0.38s;
}

.spark {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 7rpx;
  height: 22rpx;
  margin-left: -3.5rpx;
  margin-top: -11rpx;
  border-radius: 999rpx;
  background: #f5b841;
  transform-origin: 50% 86%;
}

.spark-b {
  background: #10b981;
  transform: rotate(90deg);
}

.spark-c {
  background: #4a90e2;
  transform: rotate(45deg);
}

.spark-d {
  background: #f28ca2;
  transform: rotate(135deg);
}

@keyframes fireworksFade {
  0% {
    opacity: 0;
  }

  12% {
    opacity: 1;
  }

  76% {
    opacity: 1;
  }

  100% {
    opacity: 0;
  }
}

@keyframes fireworkBloom {
  0% {
    opacity: 0;
    transform: translateY(24rpx) scale(0.2);
  }

  38% {
    opacity: 1;
    transform: translateY(-12rpx) scale(1);
  }

  100% {
    opacity: 0;
    transform: translateY(-42rpx) scale(1.08);
  }
}
