.page-reading-mode {
  min-height: 100vh;
  background: #fffdf8;
  color: #2f3437;
}

.reading-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  min-height: 112rpx;
  display: flex;
  align-items: center;
  padding-left: 24rpx;
  padding-right: 24rpx;
  box-sizing: content-box;
  background: rgba(255, 253, 248, 0.94);
  backdrop-filter: blur(16rpx);
  border-bottom: 1rpx solid rgba(31, 41, 55, 0.06);
}

.reading-back {
  width: 72rpx;
  height: 72rpx;
  line-height: 66rpx;
  text-align: center;
  font-size: 64rpx;
  color: #4a5568;
  flex-shrink: 0;
}

.reading-title-wrap {
  flex: 1;
  min-width: 0;
  padding: 0 16rpx;
}

.reading-title {
  font-size: 30rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #1f2937;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.reading-progress {
  min-width: 72rpx;
  text-align: right;
  font-size: 24rpx;
  color: #4a90e2;
  font-weight: 700;
}

.reader-scroll {
  height: 100vh;
}

.reader-content {
  padding-left: 48rpx;
  padding-right: 48rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

.reader-meta {
  padding: 48rpx 0 36rpx;
}

.reader-period {
  display: inline-flex;
  max-width: 100%;
  margin-left: -18rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #357abd;
  font-size: 24rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.reader-heading {
  margin-top: 28rpx;
  color: #e85d6a;
  font-size: 32rpx;
  font-weight: 800;
  text-decoration: underline;
  text-underline-offset: 6rpx;
}

.reader-paragraph {
  position: relative;
  margin: 0 0 34rpx;
  padding: 0 0 0 22rpx;
  color: rgba(86, 96, 109, 0.56);
  font-size: 36rpx;
  line-height: 2.05;
  letter-spacing: 0;
  font-weight: 500;
  transition:
    color 0.42s ease,
    opacity 0.42s ease,
    background-color 0.42s ease;
}

.reader-paragraph::before {
  content: "";
  position: absolute;
  left: 0;
  top: 18rpx;
  bottom: 18rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: transparent;
  opacity: 0;
  transition: background-color 0.42s ease, opacity 0.42s ease;
}

.reader-paragraph-active {
  color: #1f2937;
  font-weight: 700;
  opacity: 1;
}

.reader-paragraph-active::before {
  background: #4a90e2;
  opacity: 1;
}

.reader-font-large .reader-paragraph {
  font-size: 40rpx;
}

.reader-font-xlarge .reader-paragraph {
  font-size: 44rpx;
}

.reader-empty {
  padding: 160rpx 0;
  text-align: center;
  color: #9ca3af;
  font-size: 28rpx;
}

.reading-toolbar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 30;
  min-height: 96rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(74, 144, 226, 0.12);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 50rpx rgba(31, 41, 55, 0.12);
  box-sizing: border-box;
  backdrop-filter: blur(18rpx);
}

.toolbar-btn {
  height: 72rpx;
  min-width: 88rpx;
  padding: 0 20rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4b5563;
  font-size: 26rpx;
  font-weight: 700;
  background: #f4f6f8;
  box-sizing: border-box;
}

.toolbar-btn-primary {
  flex: 1;
  color: #ffffff;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  box-shadow: 0 10rpx 24rpx rgba(74, 144, 226, 0.24);
}

.toolbar-btn-checkin {
  color: #357abd;
  background: #eef5ff;
}

.poster-panel-mask {
  position: fixed;
  inset: 0;
  z-index: 100;
  background: rgba(8, 15, 30, 0.76);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.poster-panel {
  width: 100%;
  max-height: 92vh;
  border-radius: 36rpx 36rpx 0 0;
  background: #fffdf8;
  padding: 28rpx;
  box-sizing: border-box;
}

.poster-panel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.poster-panel-title {
  color: #1f2937;
  font-size: 32rpx;
  font-weight: 800;
}

.poster-panel-subtitle {
  margin-top: 6rpx;
  color: #7b8798;
  font-size: 22rpx;
}

.poster-panel-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #eff3f8;
  color: #7b8798;
  font-size: 34rpx;
  line-height: 56rpx;
  text-align: center;
}

.poster-preview-wrap {
  height: 760rpx;
  border-radius: 24rpx;
  background: #edf2f7;
  overflow: hidden;
  box-shadow: inset 0 0 0 1rpx rgba(31, 41, 55, 0.06);
}

.poster-preview {
  width: 100%;
  height: 100%;
}

.poster-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.poster-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 42rpx;
  background: #4a90e2;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}

.poster-btn::after {
  border: none;
}

.poster-btn-plain {
  background: #f4f6f8;
  color: #4b5563;
}

.poster-btn-ghost {
  background: #eef5ff;
  color: #357abd;
}

.reading-poster-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 900px;
  height: 1800px;
  opacity: 0;
  pointer-events: none;
}
