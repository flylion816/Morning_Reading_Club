page {
  background: #1c1917;
}

.podcast-player-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1c1917 0%, #292524 60%, #1c1917 100%);
  padding: 48rpx 40rpx;
  padding-bottom: calc(80rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(80rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.player-cover-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.player-cover-art {
  width: 320rpx;
  height: 320rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #292524 0%, #44403c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.5);
}

.player-cover-emoji {
  font-size: 120rpx;
}

.player-title-area {
  text-align: center;
}

.player-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #f5f5f4;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.player-subtitle {
  display: block;
  font-size: 26rpx;
  color: #f97316;
}

.player-progress-area {
  margin-bottom: 56rpx;
}

.player-progress-track {
  position: relative;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 4rpx;
  margin-bottom: 16rpx;
}

.player-progress-fill {
  position: absolute;
  left: 0;
  top: 0;
  height: 100%;
  background: #f97316;
  border-radius: 4rpx;
  transition: width 0.5s linear;
}

.player-progress-thumb {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #f97316;
  box-shadow: 0 0 8rpx rgba(249, 115, 22, 0.6);
}

.player-time-row {
  display: flex;
  justify-content: space-between;
}

.player-time-current,
.player-time-total {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.player-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 64rpx;
}

.player-btn-main {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(249, 115, 22, 0.45);
}

.player-btn-icon {
  font-size: 48rpx;
  color: #fff;
}

.player-desc-area {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 28rpx;
}

.player-desc-title {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.player-desc-content {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1.9;
}
