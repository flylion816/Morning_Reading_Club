<view class="podcast-player-page" wx:if="{{!checking}}">
  <view class="player-cover-area">
    <view class="player-cover-art">
      <text class="player-cover-emoji">🎙</text>
    </view>
    <view class="player-title-area">
      <text class="player-title">{{title}}</text>
      <text class="player-subtitle">凡人播客</text>
    </view>
  </view>

  <view class="player-progress-area">
    <view class="player-progress-track" bindtap="handleSeek">
      <view class="player-progress-fill" style="width: {{progress}}%"></view>
      <view class="player-progress-thumb" style="left: {{progress}}%"></view>
    </view>
    <view class="player-time-row">
      <text class="player-time-current">{{currentTimeText}}</text>
      <text class="player-time-total">{{durationText}}</text>
    </view>
  </view>

  <view class="player-controls">
    <view class="player-btn player-btn-main" bindtap="handlePlayPause">
      <view wx:if="{{playing}}" class="player-pause-icon">
        <view class="player-pause-bar"></view>
        <view class="player-pause-bar"></view>
      </view>
      <view wx:else class="player-play-triangle"></view>
    </view>
  </view>

  <view class="player-desc-area" wx:if="{{description}}">
    <view class="player-desc-title">简介</view>
    <view class="player-desc-content">
      <text user-select>{{description}}</text>
    </view>
  </view>
</view>
