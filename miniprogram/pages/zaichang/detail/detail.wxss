page {
  --zc-bg: #F5F0E8;
  --zc-primary: #2D5A3D;
  --zc-accent: #C4873A;
  --zc-text: #2C2C2C;
  --zc-text-secondary: #888888;
  background-color: var(--zc-bg);
}

.detail-page { background: var(--zc-bg); min-height: 100vh; padding-bottom: 140rpx; }

/* 图片区 */
.media-section { width: 100%; background: var(--zc-bg); }
.media-single { width: 100%; display: block; margin-bottom: 8rpx; }
.media-grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 4rpx; }
.media-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4rpx; }
.media-grid-item { position: relative; width: 100%; padding-top: 100%; overflow: hidden; }
.media-grid-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; }
.media-more-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.45); display: flex; align-items: center; justify-content: center; }
.media-more-text { color: #fff; font-size: 32rpx; font-weight: bold; }

/* 徽章 */
.badge { display: inline-block; padding: 6rpx 18rpx; border-radius: 20rpx; font-size: 22rpx; color: #fff; margin: 16rpx 0; }
.badge-reading { background: #2D5A3D; }
.badge-cooking { background: #C4873A; }
.badge-tea { background: #8B6355; }
.badge-walk { background: #4A7FA5; }
.badge-create { background: #7B5EA7; }
.badge-other { background: #888888; }

/* 基本信息 */
.main-info { padding: 8rpx 24rpx 24rpx; background: #fff; margin-bottom: 16rpx; }
.meta-row { display: flex; align-items: center; margin-bottom: 12rpx; }
.date, .dot, .location { font-size: 24rpx; color: var(--zc-text-secondary); }
.title { display: block; font-size: 36rpx; font-weight: 700; color: var(--zc-text); margin-bottom: 12rpx; line-height: 1.4; }
.desc { display: block; font-size: 28rpx; color: #555; line-height: 1.6; }

/* 通用 section */
.section { background: #fff; margin-bottom: 16rpx; padding: 24rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: var(--zc-text); }
.toggle-btn { font-size: 24rpx; color: var(--zc-primary); }

/* 在场人 */
.attendees-wall { display: flex; flex-wrap: wrap; gap: 20rpx; margin-bottom: 24rpx; }
.att-item { display: flex; flex-direction: column; align-items: center; gap: 8rpx; width: 80rpx; }
.att-avatar-wrap { width: 72rpx; height: 72rpx; border-radius: 50%; overflow: hidden; }
.att-avatar { width: 100%; height: 100%; }
.att-avatar-text { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--zc-primary); color: #fff; font-size: 26rpx; display: flex; align-items: center; justify-content: center; line-height: 72rpx; text-align: center; }
.att-name { font-size: 20rpx; color: var(--zc-text-secondary); text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; width: 80rpx; }
.attend-btn-wrap { display: flex; justify-content: center; }
.attend-btn { padding: 16rpx 48rpx; border-radius: 40rpx; border: 2rpx solid var(--zc-primary); color: var(--zc-primary); font-size: 28rpx; }
.attend-btn.attending { background: var(--zc-primary); color: #fff; border-color: var(--zc-primary); }

/* 共鸣 */
.reaction-list { display: flex; gap: 20rpx; }
.reaction-btn { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 20rpx 0; border-radius: 16rpx; background: #F5F0E8; gap: 6rpx; }
.reaction-emoji { font-size: 36rpx; }
.reaction-label { font-size: 22rpx; color: var(--zc-text-secondary); }
.reaction-count { font-size: 24rpx; font-weight: 600; color: var(--zc-text); }
.active-gonming { background: #E8F0EA; }
.active-ran { background: #FFF0E0; }
.active-xiangqu { background: #FFF5E8; }

/* 评论 */
.comment-list { margin-top: 16rpx; }
.comment-item { display: flex; gap: 16rpx; margin-bottom: 28rpx; }
.comment-avatar-wrap { flex-shrink: 0; }
.comment-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; }
.comment-avatar-text { width: 64rpx; height: 64rpx; border-radius: 50%; background: #C4873A; color: #fff; font-size: 24rpx; display: flex; align-items: center; justify-content: center; line-height: 64rpx; text-align: center; }
.comment-body { flex: 1; }
.comment-author { display: block; font-size: 24rpx; font-weight: 600; color: var(--zc-text); margin-bottom: 6rpx; }
.comment-content { font-size: 28rpx; color: var(--zc-text); line-height: 1.5; margin-bottom: 8rpx; }
.reply-to { color: var(--zc-primary); }
.comment-actions { display: flex; gap: 24rpx; align-items: center; }
.comment-time { font-size: 22rpx; color: var(--zc-text-secondary); }
.reply-btn { font-size: 22rpx; color: var(--zc-primary); }
.delete-btn { font-size: 22rpx; color: #e74c3c; }
.no-comment { text-align: center; font-size: 26rpx; color: var(--zc-text-secondary); padding: 40rpx 0; }

/* 底部输入框 */
.input-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1rpx solid #eee; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); z-index: 100; }
.reply-hint { display: flex; justify-content: space-between; align-items: center; font-size: 24rpx; color: var(--zc-primary); margin-bottom: 12rpx; }
.clear-reply { color: var(--zc-text-secondary); padding: 0 8rpx; }
.input-row { display: flex; gap: 16rpx; align-items: center; }
.comment-input { flex: 1; background: #F5F0E8; border-radius: 40rpx; padding: 16rpx 24rpx; font-size: 28rpx; }
.send-btn { padding: 16rpx 28rpx; border-radius: 40rpx; background: #ddd; color: #999; font-size: 26rpx; white-space: nowrap; }
.send-btn.active { background: var(--zc-primary); color: #fff; }
.edit-btn { padding: 16rpx 28rpx; border-radius: 40rpx; background: #F5F0E8; color: var(--zc-primary); font-size: 26rpx; white-space: nowrap; border: 2rpx solid var(--zc-primary); }
.delete-imprint-btn { padding: 16rpx 28rpx; border-radius: 40rpx; background: #FFF0F0; color: #e74c3c; font-size: 26rpx; white-space: nowrap; border: 2rpx solid #e74c3c; }

.loading-page { display: flex; justify-content: center; align-items: center; height: 60vh; font-size: 28rpx; color: var(--zc-text-secondary); }
