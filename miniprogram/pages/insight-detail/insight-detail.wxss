page {
  background: #f5f5f5;
}

.page-insight-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: calc(196rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(196rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.page-insight-detail-loading-state {
  padding: 0;
}

.insight-detail-loading {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 90;
  background: #f5f5f5;
}

/* 顶部标题卡片 */
.detail-header {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  padding: 32rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.day-title {
  font-weight: bold;
  font-size: 28rpx;
  line-height: 1.6;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.day-title-left {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  min-width: 0;
  flex: 1;
}

.day-title-text {
  font-weight: bold;
  font-size: 28rpx;
  word-break: break-word;
}

.day-period {
  font-size: 24rpx;
  opacity: 0.9;
  font-weight: normal;
  flex-shrink: 0;
}

.insight-tts-entry {
  display: flex;
  align-items: center;
  gap: 6rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.insight-tts-entry-active {
  background: rgba(255, 255, 255, 0.35);
}

.insight-tts-icon {
  font-size: 24rpx;
  line-height: 1;
}

.day-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 内容区 */
.content-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4a90e2;
  margin-bottom: 32rpx;
}

.content-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  text-align: justify;
  user-select: text;
  -webkit-user-select: text;
}

/* rich-text 内部样式 */
.content-text rich-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  user-select: text;
  -webkit-user-select: text;
}

.selectable-rich-text {
  user-select: text;
  -webkit-user-select: text;
}

/* 富文本内的段落样式 */
.content-text p {
  margin: 16rpx 0;
  line-height: 1.8;
  color: #333;
}

/* 富文本内的换行符样式 */
.content-text br {
  display: block;
  height: 0;
  margin: 8rpx 0;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.reading-progress-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 10rpx 24rpx 8rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.reading-progress-label {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
  flex-shrink: 0;
}

.reading-progress-track {
  flex: 1;
  height: 8rpx;
  background: #e8e8e8;
  border-radius: 4rpx;
  overflow: hidden;
}

.reading-progress-fill {
  height: 100%;
  background: #4a90e2;
  border-radius: 4rpx;
}

.reading-progress-pct {
  font-size: 22rpx;
  font-weight: 600;
  color: #4a90e2;
  min-width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 24rpx;
}

.action-btn {
  width: auto;
  min-width: 0;
  height: 72rpx;
  margin: 0;
  padding: 0 18rpx;
  border: none;
  border-radius: 36rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 72rpx;
  white-space: nowrap;
  box-sizing: border-box;
}

.action-btn::after {
  border: none;
}

.btn-back {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  transition: all 0.3s;
}

.btn-back:active {
  background: #e0e0e0;
  transform: scale(0.98);
}

.btn-like {
  flex: 1;
  background: #fff7f7;
  color: #e05252;
  border: 1rpx solid #f5c6c6;
}

.btn-like:active {
  background: #ffe8e8;
  transform: scale(0.98);
}

.btn-like.liked {
  background: #ffe8e8;
  color: #c0392b;
  border-color: #f5aaaa;
}

.btn-share {
  flex: 1;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  font-weight: bold;
}

/* ===== 长图预览弹层 ===== */
.poster-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.72);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
}

.poster-panel {
  width: 100%;
  max-height: 90vh;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.poster-panel-header {
  padding: 24rpx 32rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.poster-panel-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.poster-panel-close {
  font-size: 44rpx;
  color: #aaa;
  line-height: 1;
  padding: 0 4rpx;
}

.poster-panel-body {
  flex: 1;
  max-height: 66vh;
  overflow: hidden;
  background: #f5f5f5;
}

.poster-panel-img {
  width: 100%;
  display: block;
}

.poster-panel-footer {
  padding: 20rpx 32rpx 32rpx;
  display: flex;
  gap: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.poster-btn {
  flex: 1;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.poster-btn::after {
  border: none;
}

.poster-btn-outline {
  background: white;
  color: #4a90e2;
  border: 1rpx solid #c9dff8;
  font-weight: 500;
}

/* 隐藏的长图生成画布 */
.long-image-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750px;
  height: 1200px;
  opacity: 0;
  pointer-events: none;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* ===== 分享小菜单 ===== */
.share-popover-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: transparent;
  z-index: 900;
}

.share-popover {
  position: fixed;
  right: 24rpx;
  bottom: calc(126rpx + env(safe-area-inset-bottom));
  width: 164rpx;
  background: #fff;
  border: 1rpx solid #d7e6f8;
  border-radius: 18rpx;
  overflow: visible;
  box-shadow: 0 10rpx 32rpx rgba(35, 88, 150, 0.18);
  z-index: 901;
}

.share-popover::after {
  content: '';
  position: absolute;
  right: 44rpx;
  bottom: -10rpx;
  width: 20rpx;
  height: 20rpx;
  background: #fff;
  border-right: 1rpx solid #d7e6f8;
  border-bottom: 1rpx solid #d7e6f8;
  transform: rotate(45deg);
}

.share-popover-item {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #4a90e2;
  background: #fff;
  border-bottom: 1rpx solid #eef3f8;
  box-sizing: border-box;
}

.share-popover-item:last-child {
  border-bottom: none;
}

.share-popover-item:active {
  background: #edf4fd;
}

.share-popover-button {
  width: 100%;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 0;
}

.share-popover-button::after {
  border: none;
}

/* ===== 弹幕按钮 ===== */
.btn-danmaku {
  flex: 1;
  background: linear-gradient(135deg, #52c5a0 0%, #3aaa85 100%);
  color: white;
  font-weight: bold;
}

.btn-danmaku:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ===== 弹幕叠加层 ===== */
.danmaku-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 50;
}

/* 弹幕动画：从右向左匀速漂移 */
@keyframes danmakuFlow {
  from { transform: translateX(110vw); }
  to   { transform: translateX(-110vw); }
}

.danmaku-item {
  position: absolute;
  display: inline-flex;
  flex-direction: row;
  align-items: stretch;
  background: rgba(255, 255, 255, 0.93);
  border-radius: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.13);
  white-space: nowrap;
  max-width: 72vw;
  animation: danmakuFlow linear both;
  overflow: hidden;
}

/* 昵称徽章：三边彩色边框 + 左侧圆角与药丸吻合，stretch 撑满高度后用 flex 居中文字 */
.danmaku-name {
  display: flex;
  align-items: center;
  padding: 0 16rpx 0 22rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-top: 3rpx solid;
  border-left: 3rpx solid;
  border-bottom: 3rpx solid;
  border-radius: 36rpx 0 0 36rpx;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
}

/* 正文内容：无边框 */
.danmaku-msg {
  padding: 14rpx 24rpx 14rpx 12rpx;
  font-size: 30rpx;
  color: #1a2a3a;
  letter-spacing: 0.5rpx;
  line-height: 1.4;
  white-space: nowrap;
}

/* 4 条泳道：bubble 高≈76rpx，间隙 20rpx，最底 372rpx < 400rpx */
.danmaku-lane-0 { top: 8rpx; }
.danmaku-lane-1 { top: 104rpx; }
.danmaku-lane-2 { top: 200rpx; }
.danmaku-lane-3 { top: 296rpx; }

/* ===== 爱心飘散层 ===== */
/* 爱心全屏动效层 */
.hearts-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 200;
}

/* 每颗爱心从底部飞向各自散落位置，跳动3次（1.5倍慢速）后放大消失 */
/* 总时长 6s：飞行 ~1.1s | 三跳 ~3.9s (各约 1.3s) | 爆炸 ~1s */
@keyframes heartJourney {
  0%   { transform: translate(var(--sx, 20vw), var(--sy, 35vh)) scale(0.4); opacity: 0; }
  5%   { opacity: 1; }
  18%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(1); opacity: 1; }
  29%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(1.6); }
  40%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(0.85); }
  51%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(1.6); }
  62%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(0.85); }
  73%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(1.6); }
  84%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(0.85); opacity: 1; }
  93%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(6); opacity: 0.6; }
  100% { transform: translate(var(--dx, 0), var(--dy, 0)) scale(18); opacity: 0; }
}

.heart-item {
  position: absolute;
  left: calc(50% - 40rpx);
  top: calc(50% - 40rpx);
  width: 80rpx;
  height: 80rpx;
  opacity: 0;
  animation: heartJourney 6s ease-in-out forwards;
  filter: drop-shadow(0 0 12rpx rgba(255, 100, 130, 0.7));
}

/* ===== 弹幕功能浮层 ===== */
.danmaku-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1500;
  display: flex;
  align-items: flex-end;
}

.danmaku-panel {
  width: 100%;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease-out;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
}

.panel-handle {
  width: 72rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}

.panel-title-row {
  position: relative;
  padding: 24rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
  text-align: center;
}

.panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
}

.panel-close {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 48rpx;
  color: #bbb;
  line-height: 1;
  padding: 0 4rpx;
}

.panel-section {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.panel-toggle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.panel-section-label {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 面板内标签文字（覆盖全局 .section-title 的蓝色+粗体） */
.danmaku-panel .section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 0;
}

.section-desc {
  font-size: 22rpx;
  color: #aaa;
}

/* 输入区 */
.panel-input-area {
  border-bottom: none;
}

.danmaku-textarea {
  width: 100%;
  min-height: 88rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  line-height: 48rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid #eee;
}

.color-row {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  align-items: center;
}

.color-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  box-sizing: border-box;
  flex-shrink: 0;
  transition: transform 0.15s;
}

.color-dot.selected {
  border-color: #333;
  transform: scale(1.2);
}

.send-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.char-count {
  font-size: 22rpx;
  color: #bbb;
}

.send-btn {
  background: linear-gradient(135deg, #52c5a0 0%, #3aaa85 100%);
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 40rpx;
  margin: 0;
}

.send-btn::after { border: none; }

.send-btn[disabled] {
  background: #ddd;
  color: #aaa;
}

.panel-stats {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  padding: 24rpx 32rpx 0;
}
