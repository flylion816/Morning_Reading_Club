.page-insight-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 144rpx;
}

/* 顶部标题卡片 */
.detail-header {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  padding: 32rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.day-title {
  font-weight: bold;
  font-size: 28rpx;
  margin-bottom: 12rpx;
  line-height: 1.6;
  word-wrap: break-word;
  word-break: break-word;
  white-space: normal;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.day-period {
  font-size: 24rpx;
  opacity: 0.9;
  font-weight: normal;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.day-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 内容区 */
.content-section {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4a90e2;
  margin-bottom: 32rpx;
}

.content-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  text-align: justify;
}

/* rich-text 内部样式 */
.content-text rich-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

/* 富文本内的段落样式 */
.content-text p {
  margin: 16rpx 0;
  line-height: 1.8;
  color: #333;
}

/* 富文本内的换行符样式 */
.content-text br {
  display: block;
  height: 0;
  margin: 8rpx 0;
}

/* 底部按钮 */
.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-btn {
  width: auto;
  min-width: 0;
  height: 84rpx;
  margin: 0;
  padding: 0 18rpx;
  border: none;
  border-radius: 42rpx;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 84rpx;
  white-space: nowrap;
  box-sizing: border-box;
}

.action-btn::after {
  border: none;
}

.btn-back {
  flex: 0 0 124rpx;
  background: #f5f5f5;
  color: #666;
  transition: all 0.3s;
}

.btn-back:active {
  background: #e0e0e0;
  transform: scale(0.98);
}

.btn-long-share {
  flex: 1;
  background: white;
  color: #4a90e2;
  border: 1rpx solid #c9dff8;
}

.btn-long-share:active {
  background: #edf4fd;
  transform: scale(0.98);
}

.btn-share {
  flex: 1;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  font-weight: bold;
}

/* ===== 长图预览弹层 ===== */
.poster-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.72);
  z-index: 2000;
  display: flex;
  align-items: flex-end;
}

.poster-panel {
  width: 100%;
  max-height: 90vh;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.poster-panel-header {
  padding: 24rpx 32rpx 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.poster-panel-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.poster-panel-close {
  font-size: 44rpx;
  color: #aaa;
  line-height: 1;
  padding: 0 4rpx;
}

.poster-panel-body {
  flex: 1;
  max-height: 66vh;
  overflow: hidden;
  background: #f5f5f5;
}

.poster-panel-img {
  width: 100%;
  display: block;
}

.poster-panel-footer {
  padding: 20rpx 32rpx 32rpx;
  display: flex;
  gap: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.poster-btn {
  flex: 1;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.poster-btn::after {
  border: none;
}

.poster-btn-outline {
  background: white;
  color: #4a90e2;
  border: 1rpx solid #c9dff8;
  font-weight: 500;
}

/* 隐藏的长图生成画布 */
.long-image-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750px;
  height: 1200px;
  opacity: 0;
  pointer-events: none;
}

/* ===== 转发弹窗样式 ===== */
.share-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.share-modal-content {
  width: 100%;
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 32rpx 32rpx;
  animation: slideUp 0.3s ease-out;
}

.share-modal-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.share-friend-item {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.share-friend-item:active {
  background: #f0f0f0;
  transform: scale(0.98);
}

.friend-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  object-fit: cover;
}

.friend-info {
  flex: 1;
}

.friend-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.friend-desc {
  font-size: 22rpx;
  color: #999;
}

.friend-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.share-modal-cancel {
  text-align: center;
  padding: 20rpx;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-weight: 500;
}

/* ===== 转发成功提示 ===== */
.share-success-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: white;
  border-radius: 16rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  z-index: 1001;
  animation: popIn 0.3s ease-out;
}

@keyframes popIn {
  0% {
    transform: translate(-50%, -50%) scale(0.8);
    opacity: 0;
  }
  100% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }
}

.success-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.success-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  object-fit: cover;
}

.success-text {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.success-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.success-hint {
  font-size: 24rpx;
  color: #ccc;
}

/* ===== 分享菜单弹窗（开发环境） ===== */
.share-modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
}

.share-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  animation: slideUp 0.3s ease-out;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.modal-header {
  padding: 32rpx 32rpx 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #f5f5f5;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.share-options {
  padding: 16rpx 0;
}

.share-option {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  transition: all 0.2s;
}

.share-option:active {
  background: #f9f9f9;
}

.option-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  width: 64rpx;
  text-align: center;
}

.option-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.option-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.option-desc {
  font-size: 24rpx;
  color: #999;
}

.option-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 16rpx;
}

.modal-cancel {
  padding: 20rpx 32rpx;
  margin-top: 12rpx;
  text-align: center;
  font-size: 30rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 16rpx 16rpx 0 0;
  margin-left: 0;
  margin-right: 0;
}

/* ===== 弹幕按钮 ===== */
.btn-danmaku {
  flex: 1;
  background: linear-gradient(135deg, #52c5a0 0%, #3aaa85 100%);
  color: white;
  font-weight: bold;
}

.btn-danmaku:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ===== 弹幕叠加层 ===== */
.danmaku-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
  pointer-events: none;
  z-index: 50;
}

/* 弹幕动画：从右向左匀速漂移 */
@keyframes danmakuFlow {
  from { transform: translateX(110vw); }
  to   { transform: translateX(-110vw); }
}

.danmaku-item {
  position: absolute;
  display: inline-flex;
  flex-direction: row;
  align-items: stretch;
  background: rgba(255, 255, 255, 0.93);
  border-radius: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.13);
  white-space: nowrap;
  max-width: 72vw;
  animation: danmakuFlow linear forwards;
  overflow: hidden;
}

/* 昵称徽章：三边彩色边框 + 左侧圆角与药丸吻合，stretch 撑满高度后用 flex 居中文字 */
.danmaku-name {
  display: flex;
  align-items: center;
  padding: 0 16rpx 0 22rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-top: 3rpx solid;
  border-left: 3rpx solid;
  border-bottom: 3rpx solid;
  border-radius: 36rpx 0 0 36rpx;
  letter-spacing: 0.5rpx;
  white-space: nowrap;
}

/* 正文内容：无边框 */
.danmaku-msg {
  padding: 14rpx 24rpx 14rpx 12rpx;
  font-size: 30rpx;
  color: #1a2a3a;
  letter-spacing: 0.5rpx;
  line-height: 1.4;
  white-space: nowrap;
}

/* 4 条泳道：bubble 高≈76rpx，间隙 20rpx，最底 372rpx < 400rpx */
.danmaku-lane-0 { top: 8rpx; }
.danmaku-lane-1 { top: 104rpx; }
.danmaku-lane-2 { top: 200rpx; }
.danmaku-lane-3 { top: 296rpx; }

/* ===== 爱心飘散层 ===== */
/* 爱心全屏动效层 */
.hearts-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 200;
}

/* 每颗爱心从底部飞向各自散落位置，跳动3次后放大消失 */
@keyframes heartJourney {
  0%   { transform: translate(var(--sx, 20vw), var(--sy, 35vh)) scale(0.4); opacity: 0; }
  8%   { opacity: 1; }
  25%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(1); opacity: 1; }
  37%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(1.6); }
  44%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(0.85); }
  57%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(1.6); }
  64%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(0.85); }
  76%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(1.6); }
  83%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(0.85); opacity: 1; }
  93%  { transform: translate(var(--dx, 0), var(--dy, 0)) scale(6); opacity: 0.6; }
  100% { transform: translate(var(--dx, 0), var(--dy, 0)) scale(18); opacity: 0; }
}

.heart-item {
  position: absolute;
  left: calc(50% - 40rpx);
  top: calc(45% - 40rpx);
  font-size: 80rpx;
  opacity: 0;
  animation: heartJourney 4.5s ease-in-out forwards;
  filter: drop-shadow(0 0 12rpx rgba(255, 100, 130, 0.7));
}

/* ===== 弹幕功能浮层 ===== */
.danmaku-panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1500;
  display: flex;
  align-items: flex-end;
}

.danmaku-panel {
  width: 100%;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 calc(32rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease-out;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
}

.panel-handle {
  width: 72rpx;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin: 20rpx auto 0;
}

.panel-title-row {
  position: relative;
  padding: 24rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
  text-align: center;
}

.panel-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #222;
}

.panel-close {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 48rpx;
  color: #bbb;
  line-height: 1;
  padding: 0 4rpx;
}

.panel-section {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.panel-toggle-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.panel-section-label {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 面板内标签文字（覆盖全局 .section-title 的蓝色+粗体） */
.danmaku-panel .section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 0;
}

.section-desc {
  font-size: 22rpx;
  color: #aaa;
}

/* 点赞区 */
.panel-like-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.like-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.like-count {
  font-size: 22rpx;
  color: #aaa;
}

.like-btn {
  background: #fff7f7;
  color: #e05252;
  border: 1rpx solid #f5c6c6;
  border-radius: 40rpx;
  font-size: 26rpx;
  padding: 0 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin: 0;
  min-width: 160rpx;
}

.like-btn::after { border: none; }

.like-btn.liked {
  background: #ffe8e8;
  color: #c0392b;
  border-color: #f5aaaa;
}

/* 输入区 */
.panel-input-area {
  border-bottom: none;
}

.danmaku-textarea {
  width: 100%;
  min-height: 88rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  border: 1rpx solid #eee;
}

.color-row {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  align-items: center;
}

.color-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  box-sizing: border-box;
  flex-shrink: 0;
  transition: transform 0.15s;
}

.color-dot.selected {
  border-color: #333;
  transform: scale(1.2);
}

.send-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.char-count {
  font-size: 22rpx;
  color: #bbb;
}

.send-btn {
  background: linear-gradient(135deg, #52c5a0 0%, #3aaa85 100%);
  color: white;
  border: none;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 600;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 40rpx;
  margin: 0;
}

.send-btn::after { border: none; }

.send-btn[disabled] {
  background: #ddd;
  color: #aaa;
}

.panel-stats {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #bbb;
  padding: 24rpx 32rpx 0;
}
