<view class="page-insight-detail {{isDetailReady ? 'page-insight-detail-ready' : 'page-insight-detail-loading-state'}}">
  <view wx:if="{{!isDetailReady}}" class="insight-detail-loading"></view>

  <block wx:if="{{isDetailReady}}">
  <!-- 弹幕叠加层：常驻 DOM 避免 position:fixed 渲染时序问题 -->
  <view class="danmaku-overlay">
    <block wx:if="{{danmakuEnabled}}">
      <view
        wx:for="{{activeDanmaku}}"
        wx:key="id"
        class="danmaku-item danmaku-lane-{{item.lane}}"
        style="animation-duration:{{item.duration}}s;animation-delay:{{item.animDelay}}s"
      ><view class="danmaku-name" style="border-color:{{item.color}};color:{{item.color}}">{{item.nickname}}</view><text class="danmaku-msg">{{item.msg}}</text></view>
    </block>
  </view>

  <!-- 爱心飘散层：右下角向上飘散，不拦截点击 -->
  <view class="hearts-overlay" wx:if="{{showHearts}}">
    <image
      wx:for="{{heartItems}}"
      wx:key="id"
      class="heart-item"
      src="/assets/images/heart.png"
      mode="aspectFit"
      style="animation-delay:{{item.delay}}s;--sx:{{item.startX}};--sy:{{item.startY}};--dx:{{item.destX}};--dy:{{item.destY}}"
    />
  </view>

  <!-- 顶部课程标题卡片 -->
  <view class="detail-header">
    <view class="day-title">
      <view class="day-title-left">
        <text class="day-title-text">{{insight.title}}</text>
        <text wx:if="{{insight.periodName}}" class="day-period">{{insight.periodName}}</text>
      </view>
      <view class="insight-tts-entry {{ttsState !== 'idle' ? 'insight-tts-entry-active' : ''}}" bindtap="handleTtsPlay">
        <text class="insight-tts-icon">{{ttsState === 'playing' ? '⏸' : ttsState === 'loading' ? '…' : '♪'}}</text>
        <text>{{ttsState === 'playing' ? '暂停' : ttsState === 'loading' ? '合成中' : 'AI 朗读'}}</text>
      </view>
    </view>
  </view>

  <!-- 内容区 -->
  <view class="content-section">
    <!-- 图片内容 -->
    <view class="content-image" wx:if="{{insight.imageUrl}}">
      <image src="{{insight.imageUrl}}" mode="widthFix" style="width: 100%; border-radius: 8px;" show-menu-by-longpress="{{true}}" />
    </view>

    <!-- 正文内容 -->
    <view class="content-text" wx:if="{{insight.content}}">
      <rich-text class="selectable-rich-text" nodes="{{insight.content}}" selectable="{{true}}" />
    </view>
  </view>

  <!-- 底部检测哨兵：用于 IntersectionObserver 判断用户是否到达页面末尾 -->
  <view id="scroll-end-sentinel" style="height:1px"></view>

  <!-- 底部栏：阅读进度 + 操作按钮 -->
  <view class="bottom-bar">
    <view class="reading-progress-row">
      <text class="reading-progress-label">当前阅读位置</text>
      <view class="reading-progress-track">
        <view class="reading-progress-fill" style="width:{{scrollPercent}}%"></view>
      </view>
      <text class="reading-progress-pct">{{scrollPercent}}%</text>
    </view>
    <view class="action-buttons">
      <button wx:if="{{canEditInsight}}" class="action-btn btn-edit" bindtap="handleEdit">编辑</button>
      <button wx:else class="action-btn btn-back" bindtap="handleBack">返回</button>
      <button class="action-btn btn-like {{isLiked ? 'liked' : ''}}" bindtap="handleLike">
        <text>{{isLiked ? '❤️' : '♡'}}</text>
        <text>{{isLiked ? '已赞' : '点赞'}}</text>
      </button>
      <button class="action-btn btn-danmaku" bindtap="openDanmakuPanel">弹幕</button>
      <button class="action-btn btn-share" bindtap="openShareMenu">分享</button>
    </view>
  </view>

  <!-- 弹幕功能浮层 -->
  <view wx:if="{{showDanmakuPanel}}" class="danmaku-panel-mask" bindtap="closeDanmakuPanel">
    <view class="danmaku-panel" catchtap="noop">
      <view class="panel-handle"></view>
      <view class="panel-title-row">
        <text class="panel-title">弹幕功能</text>
        <text class="panel-close" bindtap="closeDanmakuPanel">×</text>
      </view>

      <!-- 弹幕开关 -->
      <view class="panel-section">
        <text class="section-title">弹幕显示</text>
        <view class="panel-toggle-row">
          <text class="section-desc">{{danmakuEnabled ? '已开启' : '已关闭'}}</text>
          <switch checked="{{danmakuEnabled}}" bindchange="toggleDanmaku" color="#4a90e2" />
        </view>
      </view>

      <!-- 发送弹幕 -->
      <view class="panel-section panel-input-area">
        <textarea
          class="danmaku-textarea"
          value="{{danmakuInput}}"
          bindinput="onDanmakuInput"
          placeholder="写下你划到的段落带给你的感悟"
          placeholder-style="font-size:28rpx;line-height:48rpx;color:#bbb;"
          maxlength="60"
          auto-height
          show-confirm-bar="{{false}}"
        />
        <view class="color-row">
          <view
            wx:for="{{danmakuColors}}"
            wx:key="value"
            class="color-dot {{danmakuColor === item.value ? 'selected' : ''}}"
            style="background:{{item.value}}"
            bindtap="selectColor"
            data-color="{{item.value}}"
          ></view>
        </view>
        <view class="send-row">
          <text class="char-count">{{danmakuInput.length}}/60</text>
          <button
            class="send-btn"
            bindtap="sendDanmaku"
            disabled="{{!danmakuInput}}"
          >发送</button>
        </view>
      </view>

      <text class="panel-stats">已有 {{danmakuList.length}} 条弹幕共鸣</text>
    </view>
  </view>

  <!-- 长图生成画布（隐藏） -->
  <canvas
    id="insightLongImageCanvas"
    canvas-id="insightLongImageCanvas"
    type="2d"
    class="long-image-canvas"></canvas>

  <!-- 长图预览弹层 -->
  <view wx:if="{{showPosterPanel}}" class="poster-panel-mask" bindtap="closePosterPanel">
    <view class="poster-panel" catchtap="noop">
      <view class="poster-panel-header">
        <text class="poster-panel-title">长图预览</text>
        <text class="poster-panel-close" bindtap="closePosterPanel">×</text>
      </view>
      <scroll-view scroll-y class="poster-panel-body">
        <image
          class="poster-panel-img"
          src="{{posterTempFilePath}}"
          mode="widthFix"
          show-menu-by-longpress="{{true}}" />
      </scroll-view>
      <view class="poster-panel-footer">
        <button class="poster-btn poster-btn-outline" bindtap="handleSavePoster">保存相册</button>
        <button class="poster-btn" bindtap="handleSharePoster">转发好友</button>
      </view>
    </view>
  </view>

  <!-- 分享小菜单 -->
  <view wx:if="{{showShareModal}}" class="share-popover-mask" bindtap="closeShareModal"></view>
  <view wx:if="{{showShareModal}}" class="share-popover" catchtap="noop">
    <button class="share-popover-item share-popover-button" open-type="share" bindtap="closeShareModal">微信</button>
    <view class="share-popover-item" bindtap="handleShareMenuLongImage">长图</view>
    <view class="share-popover-item" bindtap="handleTextShare">文本</view>
  </view>
  </block>
</view>

<podcast-player-bar bottom-offset="152" />
