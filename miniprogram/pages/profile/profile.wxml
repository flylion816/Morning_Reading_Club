<!-- 我的页面 -->
<view class="page-my">

  <!-- 已登录状态 -->
  <view wx:if="{{isLogin}}" class="logged-in-content">

    <!-- 用户信息卡 -->
    <view class="user-card">
      <view class="user-card-left">
        <view class="user-avatar-wrap" style="background: {{userInfo.avatarColor || '#4a90e2'}}">
          <image wx:if="{{userInfo.avatarUrl}}" class="user-avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
          <text wx:else class="user-avatar-emoji">{{userInfo.avatarText || '用'}}</text>
        </view>
        <view class="user-info">
          <text class="user-name">{{userInfo.nickname || userInfo.name || '用户'}}</text>
          <text class="user-phone">{{hasPhone ? phoneMasked : '未绑定手机号'}}</text>
          <text class="user-streak">累计打卡 <text class="streak-num">{{stats.totalCheckinDays || 0}}</text> 天</text>
        </view>
      </view>
    </view>

    <!-- 账号资料 -->
    <view class="settings-group">
      <view wx:if="{{canUsePaidFeatures && !hasPhone}}" class="settings-cell">
        <view class="cell-left">
          <text class="cell-icon">📱</text>
          <text class="cell-label">绑定手机号</text>
        </view>
        <button
          class="cell-phone-btn"
          open-type="getPhoneNumber"
          bindgetphonenumber="handleGetPhoneNumber"
        >立即绑定</button>
      </view>
      <view wx:elif="{{canUsePaidFeatures}}" class="settings-cell">
        <view class="cell-left">
          <text class="cell-icon">📱</text>
          <text class="cell-label">手机号管理</text>
        </view>
        <view class="cell-right">
          <text class="cell-value">{{phoneMasked}}</text>
          <button
            class="cell-rebind-btn"
            open-type="getPhoneNumber"
            bindgetphonenumber="handleGetPhoneNumber"
          >换绑</button>
        </view>
      </view>

      <view class="settings-cell" bindtap="goToEditProfile">
        <view class="cell-left">
          <text class="cell-icon">📝</text>
          <text class="cell-label">编辑资料</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="settings-divider"></view>

    <!-- 消息 -->
    <view class="settings-group">
      <view class="settings-cell" bindtap="goToNotifications">
        <view class="cell-left">
          <text class="cell-icon">📨</text>
          <text class="cell-label">消息通知</text>
        </view>
        <view class="cell-right">
          <view wx:if="{{unreadNotificationCount > 0}}" class="cell-badge">
            {{unreadNotificationCount > 99 ? '99+' : unreadNotificationCount}}
          </view>
          <text class="cell-arrow">›</text>
        </view>
      </view>

      <view wx:if="{{canUsePaidFeatures}}" class="settings-cell" bindtap="goToNotificationSettings">
        <view class="cell-left">
          <text class="cell-icon">⏰</text>
          <text class="cell-label">消息提醒设置</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>
    </view>

    <view wx:if="{{canUsePaidFeatures}}" class="settings-divider"></view>

    <!-- 我的内容 -->
    <view wx:if="{{canUsePaidFeatures}}" class="settings-group">
      <view wx:if="{{canUsePaidFeatures}}" class="settings-cell" bindtap="goToMyActivities">
        <view class="cell-left">
          <text class="cell-icon">📅</text>
          <text class="cell-label">我的活动</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>

      <view wx:if="{{canUsePaidFeatures}}" class="settings-cell" bindtap="goToMyCheckinRecords">
        <view class="cell-left">
          <text class="cell-icon">📔</text>
          <text class="cell-label">我的打卡日记</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>

      <view wx:if="{{canUsePaidFeatures}}" class="settings-cell" bindtap="goToCompletionReports">
        <view class="cell-left">
          <text class="cell-icon">📄</text>
          <text class="cell-label">我的实录报告</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>

      <view wx:if="{{canUsePaidFeatures}}" class="settings-cell" bindtap="goToMyCoupons">
        <view class="cell-left">
          <text class="cell-icon">🎫</text>
          <text class="cell-label">我的优惠券</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>
    </view>

    <view wx:if="{{isAdmin}}" class="settings-divider"></view>

    <!-- 管理员 -->
    <view wx:if="{{isAdmin}}" class="settings-group">
      <view class="settings-cell" bindtap="goToAdminWorkbench">
        <view class="cell-left">
          <text class="cell-icon">🧭</text>
          <text class="cell-label">管理工作台</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>
      <view class="settings-cell" bindtap="goToAdminAnalytics">
        <view class="cell-left">
          <text class="cell-icon">📈</text>
          <text class="cell-label">数据分析</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="settings-divider"></view>

    <!-- 协议 -->
    <view class="settings-group">
      <view class="settings-cell" bindtap="goToPrivacy">
        <view class="cell-left">
          <text class="cell-icon">🔒</text>
          <text class="cell-label">隐私政策</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>
      <view class="settings-cell" bindtap="goToAgreement">
        <view class="cell-left">
          <text class="cell-icon">📜</text>
          <text class="cell-label">用户协议</text>
        </view>
        <view class="cell-right">
          <text class="cell-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 退出登录 -->
    <view class="logout-wrap">
      <view class="logout-btn" bindtap="handleLogout">退出登录</view>
    </view>
  </view>

  <!-- 未登录状态 -->
  <view wx:if="{{!isLogin}}" class="guest-content">
    <view class="guest-banner">
      <text class="guest-emoji">🦁</text>
      <text class="guest-tip">登录后查看个人信息</text>
    </view>
    <view class="guest-login-btn" bindtap="goToLogin">立即登录</view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-overlay">
    <view class="loading-spinner"></view>
  </view>

</view>

<podcast-player-bar has-tabbar="{{true}}" ignore-safe-area="{{true}}" />
