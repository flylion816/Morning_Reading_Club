/* 我的页面样式 */
.page-my {
  min-height: 100vh;
  background:
    radial-gradient(circle at 18% 0%, var(--theme-primary-alpha-08) 0, rgba(255,255,255,0) 280rpx),
    linear-gradient(180deg, var(--app-page-bg) 0%, #fafaf5 100%);
  padding: 24rpx 24rpx 140rpx;
  box-sizing: border-box;
}

/* 用户信息卡 */
.user-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 22rpx;
  background:
    radial-gradient(circle at 80% 0%, var(--theme-primary-alpha-08) 0, rgba(255,255,255,0) 190rpx),
    linear-gradient(180deg, var(--app-paper) 0%, #ffffff 100%);
  padding: 32rpx;
  margin-bottom: 22rpx;
  border-radius: 24rpx;
  box-shadow: var(--app-shadow-soft);
  border: 1rpx solid rgba(49, 72, 56, 0.08);
  position: relative;
  overflow: hidden;
}

.user-card-glow {
  position: absolute;
  right: -64rpx;
  top: -80rpx;
  width: 210rpx;
  height: 210rpx;
  border-radius: 50%;
  border: 2rpx solid var(--theme-primary-alpha-12);
  pointer-events: none;
}

.user-card-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex: 1;
}

.user-avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 22rpx;
  background: #f0f4ff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.28);
}

.user-avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 22rpx;
}

.user-avatar-emoji {
  font-size: 52rpx;
  line-height: 1;
  color: #fff;
  font-weight: 600;
}

.user-info {
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 400;
  color: var(--app-text);
  line-height: 1.25;
}

.user-phone {
  font-size: 26rpx;
  color: var(--app-text-muted);
}

.user-streak {
  font-size: 24rpx;
  color: #666666;
}

.streak-num {
  color: var(--theme-primary);
  font-weight: 600;
}

.user-stat-pill {
  position: relative;
  z-index: 1;
  min-width: 118rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(236, 243, 233, 0.7);
  border: 1rpx solid var(--theme-primary-alpha-12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-pill-number {
  color: var(--theme-primary-dark);
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1;
}

.stat-pill-label {
  margin-top: 8rpx;
  color: var(--theme-primary);
  font-size: 20rpx;
  font-weight: 400;
}

/* 设置分组 */
.settings-group {
  background: linear-gradient(180deg, var(--app-paper) 0%, #ffffff 100%);
  margin-bottom: 0;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--app-shadow-soft);
  border: 1rpx solid rgba(49, 72, 56, 0.08);
}

.settings-divider {
  height: 18rpx;
  background: transparent;
}

/* 设置 cell */
.settings-cell {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
  height: 104rpx;
  border-bottom: 1rpx solid rgba(49, 72, 56, 0.07);
  background: transparent;
  transition: background 0.18s ease, transform 0.18s ease;
}

.settings-cell:active {
  background: #eef3ea;
  transform: translateY(1rpx);
}

.settings-cell:last-child {
  border-bottom: none;
}

.cell-left {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.cell-icon {
  width: 48rpx;
  height: 48rpx;
  background: transparent;
  font-size: 30rpx;
  text-align: center;
  line-height: 48rpx;
  box-shadow: none;
  text-shadow: none;
  filter: none;
}

.cell-label {
  font-size: 30rpx;
  color: var(--app-text);
  font-weight: 400;
}

.cell-right {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.cell-value {
  font-size: 28rpx;
  color: var(--app-text-muted);
}

.cell-badge {
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #e85f5c;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cell-arrow {
  font-size: 36rpx;
  color: #c2cac3;
  font-weight: 300;
}

/* 手机号绑定按钮 */
.cell-phone-btn,
.cell-rebind-btn {
  font-size: 26rpx;
  color: var(--theme-primary);
  background: var(--theme-primary-tint);
  border: none;
  padding: 10rpx 16rpx;
  margin: 0;
  line-height: 1;
  min-height: auto;
  border-radius: 12rpx;
  font-weight: 500;
  transition: opacity 0.18s ease, transform 0.18s ease;
}

.cell-phone-btn::after,
.cell-rebind-btn::after {
  border: none;
}

.cell-phone-btn:active,
.cell-rebind-btn:active {
  opacity: 0.76;
  transform: scale(0.98);
}

/* 退出登录 */
.logout-wrap {
  margin-top: 34rpx;
  padding: 0;
}

.logout-btn {
  text-align: center;
  color: #c94740;
  font-size: 30rpx;
  padding: 28rpx 0;
  background: var(--app-paper);
  border-radius: 20rpx;
  box-shadow: var(--app-shadow-soft);
  border: 1rpx solid rgba(49, 72, 56, 0.08);
  transition: background 0.18s ease, transform 0.18s ease;
}

.logout-btn:active {
  background: #fff5f3;
  transform: translateY(1rpx);
}

/* 未登录 */
.guest-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 180rpx;
  gap: 48rpx;
}

.guest-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.guest-emoji {
  font-size: 88rpx;
}

.guest-tip {
  font-size: 30rpx;
  color: var(--app-text-soft);
}

.guest-login-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-primary-dark) 100%);
  color: #ffffff;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 12rpx 26rpx var(--theme-primary-alpha-24);
  transition: transform 0.18s ease, opacity 0.18s ease;
}

.guest-login-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

/* 加载遮罩 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: var(--theme-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
