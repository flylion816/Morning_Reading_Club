.page-my-coupons {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx 24rpx 40rpx;
  box-sizing: border-box;
}

.loading-container, .empty-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 160rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: var(--theme-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text, .empty-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.empty-icon {
  font-size: 80rpx;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.coupon-card {
  display: flex;
  flex-direction: row;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.coupon-card--dim {
  opacity: 0.55;
}

.coupon-left {
  width: 200rpx;
  background: var(--theme-primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 16rpx;
  flex-shrink: 0;
}

.coupon-discount {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
}

.coupon-activity {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  margin-top: 8rpx;
  text-align: center;
  line-height: 1.4;
}

.coupon-divider {
  width: 2rpx;
  background: repeating-linear-gradient(
    to bottom,
    #e0e0e0 0,
    #e0e0e0 10rpx,
    transparent 10rpx,
    transparent 20rpx
  );
  flex-shrink: 0;
}

.coupon-right {
  flex: 1;
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.coupon-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.coupon-valid {
  font-size: 24rpx;
  color: #999;
}

.coupon-status {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  align-self: flex-start;
  margin-top: 4rpx;
}

.coupon-status--active {
  background: var(--theme-primary-tint);
  color: var(--theme-primary);
}

.coupon-status--used {
  background: #f0f0f0;
  color: #999;
}

.coupon-bottom-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-top: 4rpx;
}

.coupon-use-btn {
  font-size: 24rpx;
  color: var(--theme-primary);
  border: 1rpx solid var(--theme-primary);
  border-radius: 20rpx;
  padding: 4rpx 20rpx;
}
