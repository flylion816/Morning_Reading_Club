.page-checkin {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0 0 160rpx;
}

/* 自定义导航栏 */
.custom-nav {
  background: #4a90e2;
  display: flex;
  align-items: center;
  height: auto;
  padding-bottom: 0;
  position: relative;
}

.nav-back {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-back-arrow {
  width: 22rpx;
  height: 22rpx;
  border-left: 4rpx solid white;
  border-bottom: 4rpx solid white;
  transform: rotate(45deg);
  margin-left: 10rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.nav-placeholder {
  width: 88rpx;
  flex-shrink: 0;
}

.page-body {
  padding: 24rpx;
}

/* 课程标题 */
.course-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.course-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

/* 内容预览（未展开） */
.content-preview {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-preview {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: white;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.section-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.section-content-short {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 展开按钮 */
.expand-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #4a90e2;
  cursor: pointer;
}

.arrow {
  font-size: 20rpx;
}

/* 展开后的完整内容 */
.full-content {
  margin-bottom: 24rpx;
}

.content-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.section-title .section-icon {
  margin-right: 12rpx;
}

.section-content {
  font-size: 32rpx;
  color: #555;
  line-height: 2.2;
  text-align: justify;
  width: 100%;
  box-sizing: border-box;
  overflow: visible;
  letter-spacing: 1px;
}

/* 富文本内容样式 */
.section-content rich-text {
  font-size: 32rpx;
  line-height: 2.2;
  color: #555;
  width: 100%;
  display: block;
  letter-spacing: 1px;
}

/* 富文本段落样式 */
.section-content /deep/ p {
  margin: 24rpx 0;
  line-height: 1.8;
}

/* 富文本空段落样式 - 确保空行可见 */
.section-content /deep/ p:empty {
  min-height: 1em;
  display: block;
  margin: 24rpx 0;
}

/* 富文本粗体样式 */
.section-content /deep/ strong {
  font-weight: bold;
  color: #333;
}

/* 富文本缩进样式 */
.section-content /deep/ p[style*="margin-left"] {
  margin-left: 2em;
}

/* 富文本图片样式 */
.section-content /deep/ img {
  max-width: 100%;
  height: auto;
  border-radius: 8rpx;
  margin: 16rpx 0;
  display: block;
}

/* 富文本链接样式 */
.section-content /deep/ a {
  color: #4a90e2;
  text-decoration: underline;
}

/* 富文本列表样式 */
.section-content /deep/ ol,
.section-content /deep/ ul {
  margin: 24rpx 0;
  padding-left: 32rpx;
}

.section-content /deep/ li {
  margin: 16rpx 0;
  line-height: 1.8;
}

/* 日记输入区域 */
.diary-input-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.rich-editor-wrap {
  width: 100%;
  border: 2rpx solid #edf1f6;
  border-radius: 12rpx;
  background: #fff;
  overflow: hidden;
  box-sizing: border-box;
}

.editor-toolbar {
  border-bottom: 1rpx solid #edf1f6;
  background: #fbfcfe;
}

.toolbar-scroll {
  width: 100%;
  white-space: nowrap;
}

.toolbar-inner {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 16rpx;
  min-width: 100%;
  box-sizing: border-box;
}

.tool-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 8rpx;
  background: #f2f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #2f3b4a;
}

.tool-btn-active,
.tool-btn:active {
  background: #e8f4fd;
  color: #2f7ed8;
}

.tool-icon {
  font-size: 26rpx;
  line-height: 1;
  font-weight: 700;
}

.tool-bold {
  font-weight: 900;
}

.tool-italic {
  font-style: italic;
}

.tool-underline {
  text-decoration: underline;
}

.tool-heading {
  font-size: 28rpx;
}

.toolbar-divider {
  width: 1rpx;
  height: 36rpx;
  background: #e4eaf2;
  margin: 0 4rpx;
  flex-shrink: 0;
}

.color-swatch {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 0 0 1rpx #d7e0eb;
  flex-shrink: 0;
}

.color-swatch-active {
  box-shadow: 0 0 0 4rpx #b8d9fb;
}

.rich-editor {
  min-height: 360rpx;
  padding: 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

.char-count-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  margin-bottom: 24rpx;
}

.auto-save-status {
  font-size: 22rpx;
  color: #aaa;
}

.char-count {
  font-size: 24rpx;
  color: #999;
}

.rich-preview {
  margin-bottom: 28rpx;
  padding: 22rpx 24rpx;
  border-radius: 12rpx;
  background: #fbfcfe;
  border: 1rpx solid #e7edf5;
  box-sizing: border-box;
}

.rich-preview-title {
  margin-bottom: 14rpx;
  font-size: 24rpx;
  color: #7a8796;
  font-weight: 600;
}

.rich-preview-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  word-break: break-word;
}

.rich-preview-content rich-text {
  display: block;
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
}

.checkin-image-section {
  margin-bottom: 28rpx;
}

.checkin-image-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.checkin-image-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.checkin-image-count {
  font-size: 24rpx;
  color: #999;
}

.checkin-image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.checkin-image-tile,
.checkin-image-add {
  position: relative;
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f4f7fb;
}

.checkin-image-thumb {
  width: 100%;
  height: 100%;
  display: block;
}

.checkin-image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 30rpx;
  line-height: 42rpx;
  text-align: center;
}

.checkin-image-add {
  border: 1rpx dashed #bdd4ef;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #4a90e2;
  box-sizing: border-box;
}

.checkin-image-add-disabled {
  opacity: 0.6;
}

.checkin-image-add-icon {
  font-size: 52rpx;
  line-height: 1;
  margin-bottom: 8rpx;
}

.checkin-image-add-text {
  font-size: 24rpx;
}

/* 退出确认弹窗 */
.exit-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.exit-modal {
  width: 100%;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 32rpx 64rpx;
}

.exit-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.exit-modal-desc {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  margin-bottom: 40rpx;
}

.exit-modal-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.exit-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  border: none;
}

.exit-btn::after {
  border: none;
}

.exit-btn-publish {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  font-weight: bold;
}

.exit-btn-discard {
  background: #fff0f0;
  color: #e54545;
}

.exit-btn-stay {
  background: #f5f5f5;
  color: #666;
}

/* 可见范围 */
.visibility-section {
  margin-bottom: 24rpx;
}

.visibility-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.visibility-options {
  display: flex;
  gap: 16rpx;
}

.visibility-option {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.visibility-option.active {
  color: #4a90e2;
  background: #e8f4fd;
  border-color: #4a90e2;
}

/* 底部按钮 */
.bottom-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx 24rpx calc(20rpx + constant(safe-area-inset-bottom));
  padding: 20rpx 24rpx calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.btn-cancel {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 36rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-cancel::after {
  border: none;
}

.btn-submit {
  flex: 2;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  border: none;
  border-radius: 36rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-submit::after {
  border: none;
}

/* 允许长按选择文字 */
.course-title,
.course-date,
.section-content,
.section-content-short {
  user-select: text;
}

/* ===================== 打卡庆祝动画 ===================== */

/* 全屏遮罩 */
.cel-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: cel-fade-in 0.3s ease both;
}
.cel-A { background: rgba(10, 15, 30, 0.92); }
.cel-B { background: rgba(235, 244, 255, 0.97); }
.cel-C { background: rgba(0, 0, 0, 0.55); align-items: flex-end; }
.cel-D { background: linear-gradient(135deg, #111827 0%, #0f172a 55%, #020617 100%); }
.cel-E { background: linear-gradient(180deg, #1e3a8a 0%, #312e81 50%, #111827 100%); }
.cel-F { background: linear-gradient(180deg, #fff7ed 0%, #fef3c7 45%, #ffffff 100%); }
.cel-G { background: linear-gradient(180deg, #38bdf8 0%, #2563eb 46%, #0f172a 100%); }

@keyframes cel-fade-in { from { opacity: 0; } to { opacity: 1; } }

/* ---- 卡片基础 ---- */
.cel-card {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 48rpx;
  border-radius: 32rpx;
  width: 600rpx;
  box-sizing: border-box;
}
.cel-card-a {
  background: rgba(255,255,255,0.08);
  border: 2rpx solid rgba(255,215,0,0.3);
  animation: card-bounce 0.5s cubic-bezier(.34,1.56,.64,1) 0.2s both;
}
.cel-card-b {
  background: white;
  box-shadow: 0 16rpx 64rpx rgba(74,144,226,0.2);
  animation: card-drop 0.5s cubic-bezier(.34,1.56,.64,1) 0.3s both;
}
.cel-card-d {
  background: rgba(15,23,42,0.78);
  border: 2rpx solid rgba(45,212,191,0.4);
  box-shadow: 0 24rpx 80rpx rgba(45,212,191,0.24);
  animation: split-card 0.52s cubic-bezier(.34,1.56,.64,1) 0.28s both;
}
.cel-card-e {
  background: rgba(255,255,255,0.94);
  box-shadow: 0 28rpx 90rpx rgba(251,191,36,0.3);
  animation: stage-card 0.58s cubic-bezier(.34,1.56,.64,1) 0.34s both;
}
.cel-card-f {
  background: rgba(255,255,255,0.94);
  box-shadow: 0 20rpx 70rpx rgba(249,115,22,0.22);
  animation: card-bounce 0.5s cubic-bezier(.34,1.56,.64,1) 0.28s both;
}
.cel-card-g {
  background: rgba(255,255,255,0.92);
  box-shadow: 0 26rpx 90rpx rgba(37,99,235,0.34);
  animation: rocket-card 0.6s cubic-bezier(.34,1.56,.64,1) 0.42s both;
}
@keyframes card-bounce {
  from { transform: scale(0.5) translateY(60rpx); opacity: 0; }
  to   { transform: scale(1) translateY(0); opacity: 1; }
}
@keyframes card-drop {
  from { transform: scale(0.7) translateY(-40rpx); opacity: 0; }
  to   { transform: scale(1) translateY(0); opacity: 1; }
}
@keyframes split-card {
  0% { transform: scale(0.62) rotate(-7deg); opacity: 0; }
  70% { transform: scale(1.06) rotate(2deg); opacity: 1; }
  100% { transform: scale(1) rotate(0); opacity: 1; }
}
@keyframes stage-card {
  from { transform: translateY(130rpx) scale(0.82); opacity: 0; }
  to   { transform: translateY(0) scale(1); opacity: 1; }
}
@keyframes rocket-card {
  from { transform: translateY(150rpx) scale(0.78); opacity: 0; }
  to   { transform: translateY(0) scale(1); opacity: 1; }
}

/* ---- Style A 成功图标 ---- */
.cel-icon-a {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD700, #FF8C00);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  color: white;
  font-weight: bold;
  margin-bottom: 40rpx;
  animation: icon-spin 0.6s ease 0.3s both;
  box-shadow: 0 0 40rpx rgba(255,215,0,0.6);
}
@keyframes icon-spin {
  from { transform: scale(0) rotate(-180deg); opacity: 0; }
  to   { transform: scale(1) rotate(0deg); opacity: 1; }
}

/* ---- 消息文字 ---- */
.cel-msg {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  line-height: 1.6;
  white-space: pre-wrap;
  animation: cel-fade-up 0.5s ease 0.5s both;
}
.cel-card-a .cel-msg { color: #FFD700; }
.cel-msg-b { color: #2563EB; }
.cel-msg-c { color: #374151; font-size: 32rpx; font-weight: normal; margin-top: 16rpx; }
.cel-msg-d { color: #ccfbf1; text-shadow: 0 0 20rpx rgba(45,212,191,0.72); }
.cel-msg-e { color: #78350f; font-size: 32rpx; margin-top: 8rpx; }
.cel-msg-f { color: #7c2d12; font-size: 32rpx; margin-top: 10rpx; }
.cel-msg-g { color: #1e3a8a; font-size: 32rpx; margin-top: 8rpx; }

.cel-hint {
  margin-top: 32rpx;
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  animation: cel-fade-up 0.5s ease 0.8s both;
}
.cel-hint-b { color: #9CA3AF; }
.cel-card-e .cel-hint,
.cel-card-g .cel-hint { color: #9CA3AF; }

@keyframes cel-fade-up {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ---- Style A 扩散光环 ---- */
.cel-ring {
  position: absolute;
  border-radius: 50%;
  border: 4rpx solid rgba(255,215,0,0.6);
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(0);
}
.cel-ring1 { width: 200rpx; height: 200rpx; animation: ring-pulse 1.2s ease-out 0.1s both; }
.cel-ring2 { width: 320rpx; height: 320rpx; animation: ring-pulse 1.4s ease-out 0.25s both; }
@keyframes ring-pulse {
  0%   { transform: translate(-50%,-50%) scale(0); opacity: 1; }
  100% { transform: translate(-50%,-50%) scale(3); opacity: 0; }
}

/* ---- Style A 粒子（8主粒子 + 4副粒子）---- */
.cel-p {
  position: absolute;
  border-radius: 50%;
  top: 50%; left: 50%;
  opacity: 0;
}
/* 主粒子：8方向 */
.cel-pa1 { width: 20rpx; height: 20rpx; margin: -10rpx 0 0 -10rpx; background: #FFD700; animation: cfly1 0.85s ease-out 0.05s both; }
.cel-pa2 { width: 16rpx; height: 16rpx; margin: -8rpx 0 0 -8rpx;  background: #FF6B35; animation: cfly2 0.90s ease-out 0.12s both; }
.cel-pa3 { width: 22rpx; height: 22rpx; margin: -11rpx 0 0 -11rpx; background: #4ECDC4; animation: cfly3 0.80s ease-out 0s both; }
.cel-pa4 { width: 14rpx; height: 14rpx; margin: -7rpx 0 0 -7rpx;  background: #FFE66D; animation: cfly4 0.88s ease-out 0.18s both; }
.cel-pa5 { width: 18rpx; height: 18rpx; margin: -9rpx 0 0 -9rpx;  background: #87CEEB; animation: cfly5 0.82s ease-out 0.08s both; }
.cel-pa6 { width: 16rpx; height: 16rpx; margin: -8rpx 0 0 -8rpx;  background: #DDA0DD; animation: cfly6 0.92s ease-out 0.15s both; }
.cel-pa7 { width: 20rpx; height: 20rpx; margin: -10rpx 0 0 -10rpx; background: #FF8B94; animation: cfly7 0.78s ease-out 0.03s both; }
.cel-pa8 { width: 14rpx; height: 14rpx; margin: -7rpx 0 0 -7rpx;  background: #A8E6CF; animation: cfly8 0.86s ease-out 0.22s both; }
/* 副粒子：4方向（延迟出发，距离稍短） */
.cel-ps1 { width: 10rpx; height: 10rpx; margin: -5rpx 0 0 -5rpx; background: #FFD700; animation: cfly1s 0.6s ease-out 0.35s both; }
.cel-ps2 { width: 10rpx; height: 10rpx; margin: -5rpx 0 0 -5rpx; background: #4ECDC4; animation: cfly3s 0.6s ease-out 0.40s both; }
.cel-ps3 { width: 10rpx; height: 10rpx; margin: -5rpx 0 0 -5rpx; background: #FF6B35; animation: cfly5s 0.6s ease-out 0.30s both; }
.cel-ps4 { width: 10rpx; height: 10rpx; margin: -5rpx 0 0 -5rpx; background: #DDA0DD; animation: cfly7s 0.6s ease-out 0.45s both; }

@keyframes cfly1  { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(0,-220rpx);opacity:0} }
@keyframes cfly2  { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(156rpx,-156rpx);opacity:0} }
@keyframes cfly3  { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(220rpx,0);opacity:0} }
@keyframes cfly4  { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(156rpx,156rpx);opacity:0} }
@keyframes cfly5  { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(0,220rpx);opacity:0} }
@keyframes cfly6  { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(-156rpx,156rpx);opacity:0} }
@keyframes cfly7  { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(-220rpx,0);opacity:0} }
@keyframes cfly8  { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(-156rpx,-156rpx);opacity:0} }
@keyframes cfly1s { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(0,-140rpx);opacity:0} }
@keyframes cfly3s { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(140rpx,0);opacity:0} }
@keyframes cfly5s { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(0,140rpx);opacity:0} }
@keyframes cfly7s { 0%{transform:translate(0,0);opacity:1} 100%{transform:translate(-140rpx,0);opacity:0} }

/* ---- Style B 书页 ---- */
.cel-page {
  position: absolute;
  width: 60rpx;
  height: 80rpx;
  border-radius: 8rpx;
  opacity: 0;
}
.cel-pg1 { background: rgba(74,144,226,0.3);  animation: page-fly1 0.8s ease-out 0.1s both; }
.cel-pg2 { background: rgba(255,107,53,0.25); animation: page-fly2 0.9s ease-out 0.2s both; }
.cel-pg3 { background: rgba(78,205,196,0.3);  animation: page-fly3 0.7s ease-out 0.05s both; }
.cel-pg4 { background: rgba(255,215,0,0.35);  animation: page-fly4 0.85s ease-out 0.15s both; }
.cel-pg5 { background: rgba(168,230,207,0.4); animation: page-fly5 0.8s ease-out 0.25s both; }
.cel-pg6 { background: rgba(221,160,221,0.3); animation: page-fly6 0.9s ease-out 0.08s both; }

@keyframes page-fly1 { 0%{transform:translate(-400rpx,-500rpx) rotate(-30deg);opacity:1} 60%{opacity:0.8} 100%{transform:translate(-120rpx,-160rpx) rotate(15deg);opacity:0} }
@keyframes page-fly2 { 0%{transform:translate(400rpx,-500rpx) rotate(30deg);opacity:1} 60%{opacity:0.8} 100%{transform:translate(120rpx,-160rpx) rotate(-15deg);opacity:0} }
@keyframes page-fly3 { 0%{transform:translate(-500rpx,0) rotate(-45deg);opacity:1} 60%{opacity:0.8} 100%{transform:translate(-180rpx,40rpx) rotate(20deg);opacity:0} }
@keyframes page-fly4 { 0%{transform:translate(500rpx,0) rotate(45deg);opacity:1} 60%{opacity:0.8} 100%{transform:translate(180rpx,40rpx) rotate(-20deg);opacity:0} }
@keyframes page-fly5 { 0%{transform:translate(-400rpx,500rpx) rotate(30deg);opacity:1} 60%{opacity:0.8} 100%{transform:translate(-100rpx,180rpx) rotate(-10deg);opacity:0} }
@keyframes page-fly6 { 0%{transform:translate(400rpx,500rpx) rotate(-30deg);opacity:1} 60%{opacity:0.8} 100%{transform:translate(100rpx,180rpx) rotate(10deg);opacity:0} }

/* Style B 书本图标 */
.cel-book-icon {
  font-size: 100rpx;
  margin-bottom: 32rpx;
  animation: book-open 0.6s cubic-bezier(.34,1.56,.64,1) 0.2s both;
}
@keyframes book-open {
  from { transform: scale(0.4) rotate(-20deg); opacity: 0; }
  to   { transform: scale(1) rotate(0deg); opacity: 1; }
}

/* ---- Style C 底部卡片 ---- */
.cel-sheet {
  width: 100%;
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  padding: 60rpx 48rpx 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: sheet-slide-up 0.4s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes sheet-slide-up {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}
.cel-icon-c {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4a90e2, #357abd);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  animation: icon-pop 0.5s cubic-bezier(.34,1.56,.64,1) 0.3s both;
  box-shadow: 0 8rpx 32rpx rgba(74,144,226,0.4);
}
@keyframes icon-pop { from { transform: scale(0); opacity: 0; } to { transform: scale(1); opacity: 1; } }
.cel-check-c { font-size: 60rpx; color: white; font-weight: bold; }
.cel-title-c {
  font-size: 40rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 8rpx;
  animation: cel-fade-up 0.4s ease 0.4s both;
}

/* Style C 装饰点 */
.cel-dots { display: flex; gap: 16rpx; margin: 32rpx 0 40rpx; }
.cel-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%;
  animation: dot-bounce 0.6s ease infinite alternate;
}
.d1 { background: #4a90e2; animation-delay: 0s; }
.d2 { background: #FFD700; animation-delay: 0.15s; }
.d3 { background: #4ECDC4; animation-delay: 0.3s; }
@keyframes dot-bounce { from { transform: translateY(0); } to { transform: translateY(-10rpx); } }

/* Style C 关闭按钮 */
.cel-close-btn {
  background: linear-gradient(135deg, #4a90e2, #357abd);
  color: white;
  border-radius: 48rpx;
  padding: 28rpx 80rpx;
  font-size: 30rpx;
  font-weight: bold;
  animation: cel-fade-up 0.4s ease 0.6s both;
}

/* ---- Style D 碎片裂变 ---- */
.cel-shockwave {
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 50%;
  border: 4rpx solid rgba(45,212,191,0.64);
  transform: translate(-50%, -50%) scale(0.2);
}
.shock-1 { width: 220rpx; height: 220rpx; animation: shock-split 0.92s ease-out 0.08s both; }
.shock-2 { width: 380rpx; height: 380rpx; animation: shock-split 1.05s ease-out 0.18s both; }
.cel-crack {
  position: absolute;
  left: 50%;
  top: 50%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.94), transparent);
  box-shadow: 0 0 32rpx rgba(45,212,191,0.8);
  opacity: 0;
}
.crack-h { width: 720rpx; height: 4rpx; animation: crack-flash 0.46s ease-out 0.08s both; }
.crack-v { width: 4rpx; height: 720rpx; animation: crack-flash-v 0.46s ease-out 0.12s both; }
.cel-shard {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 46rpx;
  height: 62rpx;
  border-radius: 8rpx 8rpx 18rpx 8rpx;
  background: linear-gradient(135deg, rgba(45,212,191,0.95), rgba(14,165,233,0.72));
  opacity: 0;
  box-shadow: 0 0 28rpx rgba(45,212,191,0.5);
}
.shard-1 { animation: shard-1 0.82s ease-out 0.06s both; }
.shard-2 { animation: shard-2 0.86s ease-out 0.08s both; }
.shard-3 { animation: shard-3 0.78s ease-out 0.1s both; }
.shard-4 { animation: shard-4 0.88s ease-out 0.06s both; }
.shard-5 { animation: shard-5 0.8s ease-out 0.12s both; }
.shard-6 { animation: shard-6 0.84s ease-out 0.16s both; }
.shard-7 { animation: shard-7 0.9s ease-out 0.08s both; }
.shard-8 { animation: shard-8 0.82s ease-out 0.14s both; }
.shard-9 { animation: shard-9 0.74s ease-out 0.18s both; }
.shard-10 { animation: shard-10 0.86s ease-out 0.2s both; }
.cel-icon-d {
  font-size: 96rpx;
  color: #99f6e4;
  margin-bottom: 28rpx;
  text-shadow: 0 0 36rpx rgba(45,212,191,0.9);
  animation: split-icon 0.6s cubic-bezier(.34,1.56,.64,1) 0.34s both;
}
@keyframes shock-split { 0% { transform: translate(-50%,-50%) scale(0.2); opacity: 0; } 24% { opacity: 1; } 100% { transform: translate(-50%,-50%) scale(2.6); opacity: 0; } }
@keyframes crack-flash { 0% { transform: translate(-50%,-50%) scaleX(0); opacity: 0; } 30% { opacity: 1; } 100% { transform: translate(-50%,-50%) scaleX(1); opacity: 0; } }
@keyframes crack-flash-v { 0% { transform: translate(-50%,-50%) scaleY(0); opacity: 0; } 30% { opacity: 1; } 100% { transform: translate(-50%,-50%) scaleY(1); opacity: 0; } }
@keyframes shard-1 { 0% { transform: translate(-50%,-50%) rotate(0); opacity: 1; } 100% { transform: translate(-260rpx,-250rpx) rotate(-160deg); opacity: 0; } }
@keyframes shard-2 { 0% { transform: translate(-50%,-50%) rotate(0); opacity: 1; } 100% { transform: translate(-80rpx,-320rpx) rotate(110deg); opacity: 0; } }
@keyframes shard-3 { 0% { transform: translate(-50%,-50%) rotate(0); opacity: 1; } 100% { transform: translate(210rpx,-260rpx) rotate(190deg); opacity: 0; } }
@keyframes shard-4 { 0% { transform: translate(-50%,-50%) rotate(0); opacity: 1; } 100% { transform: translate(310rpx,-50rpx) rotate(-120deg); opacity: 0; } }
@keyframes shard-5 { 0% { transform: translate(-50%,-50%) rotate(0); opacity: 1; } 100% { transform: translate(220rpx,230rpx) rotate(150deg); opacity: 0; } }
@keyframes shard-6 { 0% { transform: translate(-50%,-50%) rotate(0); opacity: 1; } 100% { transform: translate(-20rpx,330rpx) rotate(-210deg); opacity: 0; } }
@keyframes shard-7 { 0% { transform: translate(-50%,-50%) rotate(0); opacity: 1; } 100% { transform: translate(-280rpx,180rpx) rotate(130deg); opacity: 0; } }
@keyframes shard-8 { 0% { transform: translate(-50%,-50%) rotate(0); opacity: 1; } 100% { transform: translate(-330rpx,-30rpx) rotate(-90deg); opacity: 0; } }
@keyframes shard-9 { 0% { transform: translate(-50%,-50%) rotate(0); opacity: 1; } 100% { transform: translate(80rpx,-210rpx) rotate(230deg); opacity: 0; } }
@keyframes shard-10 { 0% { transform: translate(-50%,-50%) rotate(0); opacity: 1; } 100% { transform: translate(80rpx,250rpx) rotate(-180deg); opacity: 0; } }
@keyframes split-icon { from { transform: scale(0) rotate(-60deg); opacity: 0; } to { transform: scale(1) rotate(0); opacity: 1; } }

/* ---- Style E 聚光登场 ---- */
.cel-spotlight {
  position: absolute;
  top: -120rpx;
  width: 260rpx;
  height: 760rpx;
  opacity: 0;
  background: linear-gradient(180deg, rgba(253,224,71,0.6), rgba(253,224,71,0));
  transform-origin: top center;
}
.spot-left { left: 8%; transform: rotate(24deg); animation: spot-sweep-left 1.25s ease-out 0.08s both; }
.spot-right { right: 8%; transform: rotate(-24deg); animation: spot-sweep-right 1.25s ease-out 0.14s both; }
.cel-stage {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 700rpx;
  height: 210rpx;
  border-radius: 50% 50% 0 0;
  background: radial-gradient(ellipse at center, rgba(251,191,36,0.52), rgba(251,191,36,0));
  transform: translateX(-50%);
  animation: stage-rise 0.7s ease-out both;
}
.cel-medal-glow {
  position: absolute;
  left: 50%;
  top: 42%;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(251,191,36,0.7), rgba(251,191,36,0));
  transform: translate(-50%, -50%);
  animation: medal-glow 1.1s ease-out 0.24s both;
}
.cel-stage-star {
  position: absolute;
  color: #fde68a;
  font-size: 38rpx;
  opacity: 0;
  text-shadow: 0 0 24rpx rgba(253,230,138,0.9);
}
.stage-star-1 { left: 20%; top: 30%; animation: stage-star-pop 0.8s ease-out 0.3s both; }
.stage-star-2 { right: 22%; top: 27%; animation: stage-star-pop 0.8s ease-out 0.42s both; }
.stage-star-3 { left: 48%; top: 16%; animation: stage-star-pop 0.8s ease-out 0.54s both; }
.cel-icon-e {
  font-size: 96rpx;
  margin-bottom: 12rpx;
  animation: medal-drop 0.7s cubic-bezier(.34,1.56,.64,1) 0.34s both;
}
.cel-title-e {
  font-size: 40rpx;
  font-weight: bold;
  color: #92400e;
  margin-bottom: 10rpx;
}
@keyframes spot-sweep-left { 0% { opacity: 0; transform: rotate(48deg); } 35% { opacity: 1; } 100% { opacity: 0.85; transform: rotate(24deg); } }
@keyframes spot-sweep-right { 0% { opacity: 0; transform: rotate(-48deg); } 35% { opacity: 1; } 100% { opacity: 0.85; transform: rotate(-24deg); } }
@keyframes stage-rise { from { transform: translateX(-50%) translateY(120rpx); opacity: 0; } to { transform: translateX(-50%) translateY(0); opacity: 1; } }
@keyframes medal-glow { 0% { transform: translate(-50%,-50%) scale(0.2); opacity: 0; } 45% { opacity: 1; } 100% { transform: translate(-50%,-50%) scale(1.9); opacity: 0; } }
@keyframes stage-star-pop { 0% { transform: translateY(30rpx) scale(0); opacity: 0; } 60% { transform: translateY(0) scale(1.4); opacity: 1; } 100% { transform: translateY(-20rpx) scale(1); opacity: 0.8; } }
@keyframes medal-drop { 0% { transform: translateY(-120rpx) rotate(-18deg); opacity: 0; } 70% { transform: translateY(8rpx) rotate(5deg); opacity: 1; } 100% { transform: translateY(0) rotate(0); opacity: 1; } }

/* ---- Style F 彩带狂欢 ---- */
.cel-confetti {
  position: absolute;
  top: -60rpx;
  width: 18rpx;
  height: 46rpx;
  border-radius: 6rpx;
  opacity: 0;
  animation: confetti-fall 1.5s ease-in both;
}
.confetti-1 { left: 8%; background: #ef4444; animation-delay: 0.02s; }
.confetti-2 { left: 16%; background: #f97316; animation-delay: 0.18s; }
.confetti-3 { left: 24%; background: #facc15; animation-delay: 0.08s; }
.confetti-4 { left: 34%; background: #22c55e; animation-delay: 0.26s; }
.confetti-5 { left: 43%; background: #14b8a6; animation-delay: 0.14s; }
.confetti-6 { left: 51%; background: #3b82f6; animation-delay: 0.3s; }
.confetti-7 { left: 60%; background: #6366f1; animation-delay: 0.06s; }
.confetti-8 { left: 68%; background: #a855f7; animation-delay: 0.22s; }
.confetti-9 { left: 76%; background: #ec4899; animation-delay: 0.1s; }
.confetti-10 { left: 84%; background: #06b6d4; animation-delay: 0.34s; }
.confetti-11 { left: 30%; background: #f43f5e; animation-delay: 0.42s; }
.confetti-12 { left: 70%; background: #84cc16; animation-delay: 0.46s; }
.cel-icon-f {
  font-size: 100rpx;
  margin-bottom: 18rpx;
  animation: confetti-icon 0.6s cubic-bezier(.34,1.56,.64,1) 0.28s both;
}
.cel-title-f {
  font-size: 40rpx;
  font-weight: bold;
  color: #9a3412;
  margin-bottom: 8rpx;
}
.cel-hint-f { color: #9ca3af; }
@keyframes confetti-fall { 0% { transform: translateY(0) rotate(0); opacity: 0; } 12% { opacity: 1; } 100% { transform: translateY(820rpx) rotate(520deg); opacity: 0; } }
@keyframes confetti-icon { from { transform: scale(0.3) rotate(-20deg); opacity: 0; } to { transform: scale(1) rotate(0); opacity: 1; } }

/* ---- Style G 火箭升空 ---- */
.cel-rocket-trail {
  position: absolute;
  left: 50%;
  bottom: 240rpx;
  width: 26rpx;
  height: 260rpx;
  border-radius: 999rpx;
  transform-origin: bottom center;
  opacity: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0), rgba(251,191,36,0.95), rgba(239,68,68,0));
}
.trail-1 { margin-left: -13rpx; animation: rocket-trail 0.95s ease-out 0.06s both; }
.trail-2 { margin-left: -58rpx; transform: rotate(-12deg); animation: rocket-trail-left 1s ease-out 0.12s both; }
.trail-3 { margin-left: 34rpx; transform: rotate(12deg); animation: rocket-trail-right 1s ease-out 0.12s both; }
.cel-cloud {
  position: absolute;
  bottom: 150rpx;
  width: 150rpx;
  height: 70rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.86);
  opacity: 0;
}
.cloud-1 { left: 14%; animation: cloud-burst-left 0.92s ease-out 0.15s both; }
.cloud-2 { right: 12%; animation: cloud-burst-right 0.92s ease-out 0.18s both; }
.cloud-3 { left: 40%; width: 180rpx; animation: cloud-burst-center 0.92s ease-out 0.12s both; }
.cel-rocket-spark {
  position: absolute;
  left: 50%;
  bottom: 270rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #fde68a;
  box-shadow: 0 0 20rpx rgba(253,230,138,0.95);
  opacity: 0;
}
.spark-1 { animation: rocket-spark-1 0.75s ease-out 0.18s both; }
.spark-2 { animation: rocket-spark-2 0.75s ease-out 0.24s both; }
.spark-3 { animation: rocket-spark-3 0.75s ease-out 0.3s both; }
.spark-4 { animation: rocket-spark-4 0.75s ease-out 0.34s both; }
.cel-icon-g {
  font-size: 98rpx;
  margin-bottom: 22rpx;
  animation: rocket-lift 0.9s cubic-bezier(.34,1.56,.64,1) 0.22s both;
}
@keyframes rocket-trail { 0% { transform: scaleY(0); opacity: 0; } 30% { opacity: 1; } 100% { transform: scaleY(1.5) translateY(120rpx); opacity: 0; } }
@keyframes rocket-trail-left { 0% { transform: rotate(-12deg) scaleY(0); opacity: 0; } 30% { opacity: 0.9; } 100% { transform: rotate(-12deg) scaleY(1.2) translateY(100rpx); opacity: 0; } }
@keyframes rocket-trail-right { 0% { transform: rotate(12deg) scaleY(0); opacity: 0; } 30% { opacity: 0.9; } 100% { transform: rotate(12deg) scaleY(1.2) translateY(100rpx); opacity: 0; } }
@keyframes cloud-burst-left { 0% { transform: translateX(80rpx) scale(0.4); opacity: 0; } 35% { opacity: 1; } 100% { transform: translateX(-120rpx) scale(1.25); opacity: 0; } }
@keyframes cloud-burst-right { 0% { transform: translateX(-80rpx) scale(0.4); opacity: 0; } 35% { opacity: 1; } 100% { transform: translateX(120rpx) scale(1.25); opacity: 0; } }
@keyframes cloud-burst-center { 0% { transform: translateY(30rpx) scale(0.4); opacity: 0; } 35% { opacity: 1; } 100% { transform: translateY(70rpx) scale(1.35); opacity: 0; } }
@keyframes rocket-spark-1 { 0% { transform: translate(0,0); opacity: 1; } 100% { transform: translate(-150rpx,-120rpx); opacity: 0; } }
@keyframes rocket-spark-2 { 0% { transform: translate(0,0); opacity: 1; } 100% { transform: translate(150rpx,-130rpx); opacity: 0; } }
@keyframes rocket-spark-3 { 0% { transform: translate(0,0); opacity: 1; } 100% { transform: translate(-110rpx,90rpx); opacity: 0; } }
@keyframes rocket-spark-4 { 0% { transform: translate(0,0); opacity: 1; } 100% { transform: translate(120rpx,80rpx); opacity: 0; } }
@keyframes rocket-lift { 0% { transform: translateY(90rpx) rotate(-10deg); opacity: 0; } 62% { transform: translateY(-14rpx) rotate(5deg); opacity: 1; } 100% { transform: translateY(0) rotate(0); opacity: 1; } }
