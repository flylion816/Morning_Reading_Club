.page-checkin {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0 0 160rpx;
}

/* 自定义导航栏 */
.custom-nav {
  background: #4a90e2;
  display: flex;
  align-items: center;
  height: auto;
  padding-bottom: 0;
  position: relative;
}

.nav-back {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nav-back-arrow {
  width: 22rpx;
  height: 22rpx;
  border-left: 4rpx solid white;
  border-bottom: 4rpx solid white;
  transform: rotate(45deg);
  margin-left: 10rpx;
}

.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.nav-placeholder {
  width: 88rpx;
  flex-shrink: 0;
}

.page-body {
  padding: 24rpx;
}

/* 课程标题 */
.course-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.course-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

/* 内容预览（未展开） */
.content-preview {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-preview {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  color: white;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.section-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.section-content-short {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 展开按钮 */
.expand-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  color: #4a90e2;
  cursor: pointer;
}

.arrow {
  font-size: 20rpx;
}

/* 展开后的完整内容 */
.full-content {
  margin-bottom: 24rpx;
}

.content-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.section-title .section-icon {
  margin-right: 12rpx;
}

.section-content {
  font-size: 32rpx;
  color: #555;
  line-height: 2.2;
  text-align: justify;
  width: 100%;
  box-sizing: border-box;
  overflow: visible;
  letter-spacing: 1px;
}

/* 富文本内容样式 */
.section-content rich-text {
  font-size: 32rpx;
  line-height: 2.2;
  color: #555;
  width: 100%;
  display: block;
  letter-spacing: 1px;
}

/* 富文本段落样式 */
.section-content /deep/ p {
  margin: 24rpx 0;
  line-height: 1.8;
}

/* 富文本空段落样式 - 确保空行可见 */
.section-content /deep/ p:empty {
  min-height: 1em;
  display: block;
  margin: 24rpx 0;
}

/* 富文本粗体样式 */
.section-content /deep/ strong {
  font-weight: bold;
  color: #333;
}

/* 富文本缩进样式 */
.section-content /deep/ p[style*="margin-left"] {
  margin-left: 2em;
}

/* 富文本图片样式 */
.section-content /deep/ img {
  max-width: 100%;
  height: auto;
  border-radius: 8rpx;
  margin: 16rpx 0;
  display: block;
}

/* 富文本链接样式 */
.section-content /deep/ a {
  color: #4a90e2;
  text-decoration: underline;
}

/* 富文本列表样式 */
.section-content /deep/ ol,
.section-content /deep/ ul {
  margin: 24rpx 0;
  padding-left: 32rpx;
}

.section-content /deep/ li {
  margin: 16rpx 0;
  line-height: 1.8;
}

/* 日记输入区域 */
.diary-input-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.diary-textarea {
  width: 100%;
  min-height: 300rpx;
  padding: 12rpx 0;  /* ✅ 调整顶部和底部边距使光标对齐 */
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
}

.char-count-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
  margin-bottom: 24rpx;
}

.auto-save-status {
  font-size: 22rpx;
  color: #aaa;
}

.char-count {
  font-size: 24rpx;
  color: #999;
}

/* 退出确认弹窗 */
.exit-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}

.exit-modal {
  width: 100%;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 32rpx 64rpx;
}

.exit-modal-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 16rpx;
}

.exit-modal-desc {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  margin-bottom: 40rpx;
}

.exit-modal-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.exit-btn {
  width: 100%;
  padding: 28rpx;
  border-radius: 48rpx;
  font-size: 30rpx;
  border: none;
}

.exit-btn::after {
  border: none;
}

.exit-btn-publish {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  font-weight: bold;
}

.exit-btn-discard {
  background: #fff0f0;
  color: #e54545;
}

.exit-btn-stay {
  background: #f5f5f5;
  color: #666;
}

/* 可见范围 */
.visibility-section {
  margin-bottom: 24rpx;
}

.visibility-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: block;
}

.visibility-options {
  display: flex;
  gap: 16rpx;
}

.visibility-option {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  border: 2rpx solid transparent;
}

.visibility-option.active {
  color: #4a90e2;
  background: #e8f4fd;
  border-color: #4a90e2;
}

/* 底部按钮 */
.bottom-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.btn-cancel {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-cancel::after {
  border: none;
}

.btn-submit {
  flex: 2;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-submit::after {
  border: none;
}

/* 允许长按选择文字 */
.course-title,
.course-date,
.section-content,
.section-content-short {
  user-select: text;
}
