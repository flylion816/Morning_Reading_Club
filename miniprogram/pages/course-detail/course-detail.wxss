.page-course-detail {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 24rpx;
  padding-bottom: 160rpx;
  overflow-x: hidden;
}

.page-course-detail.page-course-detail-detail {
  background: #f6f7fb;
  padding-bottom: 176rpx;
}

.long-image-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1040px;
  height: 1600px;
  opacity: 0;
  pointer-events: none;
}

.poster-gallery-overlay {
  position: fixed;
  inset: 0;
  z-index: 260;
  background: rgba(8, 15, 30, 0.72);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.poster-gallery-shell {
  width: 100%;
  max-height: 92vh;
  background: linear-gradient(180deg, #ffffff 0%, #f6f8fc 100%);
  border-radius: 32rpx;
  padding: 28rpx 28rpx 32rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 72rpx rgba(15, 23, 42, 0.22);
}

.poster-gallery-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.poster-gallery-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.poster-gallery-subtitle {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #8b94a5;
}

.poster-gallery-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #eff3f8;
  color: #7b8798;
  font-size: 34rpx;
  line-height: 56rpx;
  text-align: center;
}

.poster-gallery-preview-wrap {
  position: relative;
  height: 620rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #eef4fb 0%, #f8fbff 100%);
  overflow: hidden;
}

.poster-gallery-preview {
  width: 100%;
  height: 100%;
}

.poster-gallery-index {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  min-width: 88rpx;
  height: 44rpx;
  line-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: rgba(15, 23, 42, 0.6);
  color: #ffffff;
  font-size: 22rpx;
  text-align: center;
  box-sizing: border-box;
}

.poster-gallery-scroll {
  margin-top: 22rpx;
  white-space: nowrap;
}

.poster-gallery-list {
  display: flex;
  gap: 16rpx;
  padding-bottom: 10rpx;
}

.poster-gallery-thumb {
  width: 136rpx;
  flex-shrink: 0;
}

.poster-gallery-thumb-image {
  width: 136rpx;
  height: 176rpx;
  border-radius: 20rpx;
  background: #eef2f7;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}

.poster-gallery-thumb-active .poster-gallery-thumb-image {
  border-color: #4a90e2;
  box-shadow: 0 14rpx 28rpx rgba(74, 144, 226, 0.22);
}

.poster-gallery-thumb-name {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #5f6d82;
  text-align: center;
}

.poster-gallery-thumb-active .poster-gallery-thumb-name {
  color: #2f6fe4;
  font-weight: 600;
}

.poster-gallery-actions {
  margin-top: 24rpx;
  display: flex;
  gap: 16rpx;
}

.poster-gallery-btn {
  flex: 1;
  border: none;
  border-radius: 999rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #4a90e2 0%, #2f6fe4 100%);
  color: #ffffff;
  font-size: 28rpx;
  text-align: center;
  padding: 0 24rpx;
}

.poster-gallery-btn::after {
  border: none;
}

.poster-gallery-btn-plain {
  background: #eef2f7;
  color: #607089;
}

.poster-gallery-btn-ghost {
  background: #ffffff;
  color: #2f6fe4;
  border: 2rpx solid #d9e6ff;
}

.course-header {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  padding: 40rpx 32rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.notification-reminder {
  background: #fff8e8;
  border: 2rpx solid #f7d48b;
  color: #8a5a00;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.notification-reminder-text {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
}

.notification-reminder-link {
  flex-shrink: 0;
  color: #357abd;
  font-size: 24rpx;
  font-weight: 600;
}

.course-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.course-period {
  font-size: 26rpx;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.course-date {
  font-size: 24rpx;
  opacity: 0.8;
}

.calendar-section {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.calendar-title {
  font-weight: bold;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 24rpx;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 16rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.calendar-day.checked {
  background: #e8f4fd;
  border-color: #4a90e2;
}

.calendar-day.pending {
  background: #f9f9f9;
}

.day-number {
  font-size: 24rpx;
  font-weight: 500;
  color: #666;
}

.calendar-day.checked .day-number {
  color: #4a90e2;
}

.day-status {
  font-size: 20rpx;
  color: #4a90e2;
  margin-top: 4rpx;
}

/* 内容模块样式 */
.content-section {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.section-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.section-icon.calm,
.section-icon.question,
.section-icon.read,
.section-icon.think,
.section-icon.write,
.section-icon.extract,
.section-icon.share,
.section-icon.learn {
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
}

.section-content {
  font-size: 32rpx;
  color: #555;
  line-height: 2.2;
  text-align: justify;
  width: 100%;
  box-sizing: border-box;
  overflow: visible;
  letter-spacing: 1px;
}

/* 富文本内容样式 */
.section-content rich-text {
  font-size: 32rpx;
  line-height: 2.2;
  color: #555;
  width: 100%;
  display: block;
  letter-spacing: 1px;
}

/* 富文本段落样式 */
.section-content /deep/ p {
  margin: 24rpx 0;
  line-height: 1.8;
}

/* 富文本空段落样式 - 确保空行可见 */
.section-content /deep/ p:empty {
  min-height: 1em;
  display: block;
  margin: 24rpx 0;
}

/* 富文本粗体样式 */
.section-content /deep/ strong {
  font-weight: bold;
  color: #333;
}

/* 富文本缩进样式 */
.section-content /deep/ p[style*="margin-left"] {
  margin-left: 2em;
}

/* 富文本图片样式 */
.section-content /deep/ img {
  max-width: 100%;
  height: auto;
  border-radius: 8rpx;
  margin: 16rpx 0;
  display: block;
}

/* 富文本链接样式 */
.section-content /deep/ a {
  color: #4a90e2;
  text-decoration: underline;
}

/* 富文本列表样式 */
.section-content /deep/ ol,
.section-content /deep/ ul {
  margin: 24rpx 0;
  padding-left: 32rpx;
}

.section-content /deep/ li {
  margin: 16rpx 0;
  line-height: 1.8;
}

/* 底部固定按钮 */
.fixed-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 24rpx;
  display: flex;
  gap: 24rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.fixed-buttons.single-action {
  gap: 0;
}

.btn-back {
  flex: 1;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.btn-back.full-width {
  flex: 1 1 100%;
  width: 100%;
}

.btn-back::after {
  border: none;
}

.btn-checkin,
.btn-enroll {
  flex: 2;
  background: linear-gradient(135deg, #4a90e2 0%, #357abd 100%);
  color: white;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-checkin::after,
.btn-enroll::after {
  border: none;
}

/* 已打卡状态 */
.btn-checkin.disabled {
  background: #f0f0f0 !important;
  color: #666;
  opacity: 1;
  border: 2rpx solid #e0e0e0;
}

.btn-checkin:disabled {
  background: #f0f0f0 !important;
  color: #666;
  opacity: 1;
  border: 2rpx solid #e0e0e0;
}

/* 社群互动评论 */
.comments-section {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.comments-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.comments-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.comments-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.comments-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.comments-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.comment-item {
  display: flex;
  gap: 16rpx;
}

.comment-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  /* background 通过 inline style 设置 */
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 28rpx;
  color: white;
  font-weight: bold;
}

.avatar-image {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.avatar-image-small {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
}

.avatar-image-tiny {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
}

.comment-content {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.comment-user {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  letter-spacing: 1px;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.comment-text {
  font-size: 30rpx;
  color: #555;
  line-height: 2.2;
  margin-bottom: 12rpx;
  word-break: break-word;
  white-space: pre-wrap;
  letter-spacing: 1px;
}

.comment-footer {
  display: flex;
  gap: 32rpx;
}

.comment-like,
.comment-reply {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 0;
}

.like-icon,
.reply-icon {
  font-size: 24rpx;
}

.like-icon.liked {
  color: #ff6b6b;
}

.like-count {
  font-size: 22rpx;
}

/* 查看评论按钮 */
.comment-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #4a90e2;
  padding: 8rpx 0;
}

.toggle-icon {
  font-size: 24rpx;
}

.toggle-text {
  font-size: 24rpx;
}

.toggle-text.loading {
  color: #999;
}

/* 回复列表 */
.replies-list {
  margin-top: 16rpx;
  margin-left: 24rpx;
}

.reply-item {
  display: flex;
  gap: 0;
  margin-bottom: 16rpx;
  position: relative;
}

.reply-left-line {
  width: 4rpx;
  background: linear-gradient(180deg, #d0e7ff 0%, #e8f4fd 100%);
  border-radius: 2rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.reply-main {
  flex: 1;
  display: flex;
  gap: 12rpx;
  min-width: 0;
}

.reply-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.reply-avatar .avatar-text {
  font-size: 24rpx;
  color: white;
  font-weight: bold;
}

.reply-content {
  flex: 1;
  min-width: 0;
}

.reply-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.reply-user {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  letter-spacing: 1px;
}

.reply-text {
  font-size: 30rpx;
  color: #555;
  line-height: 2.2;
  margin-bottom: 12rpx;
  word-break: break-word;
  white-space: pre-wrap;
  letter-spacing: 1px;
}

.reply-time {
  font-size: 22rpx;
  color: #999;
}

.reply-footer {
  display: flex;
  gap: 32rpx;
}

.reply-like,
.reply-reply {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 0;
}

/* 嵌套回复的样式（回复的回复） */
.nested-replies-list {
  margin-top: 16rpx;
  padding-left: 20rpx;
  border-left: 2rpx solid #f0f0f0;
}

.nested-reply-item {
  display: flex;
  gap: 0;
  margin-bottom: 12rpx;
  position: relative;
}

.nested-reply-left-line {
  width: 2rpx;
  background: linear-gradient(180deg, #e8f4fd 0%, #f5faff 100%);
  border-radius: 1rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.nested-reply-main {
  flex: 1;
  display: flex;
  gap: 10rpx;
  min-width: 0;
}

.nested-reply-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.nested-reply-avatar .avatar-text {
  font-size: 20rpx;
  color: white;
  font-weight: bold;
}

.nested-reply-content {
  flex: 1;
  min-width: 0;
}

.nested-reply-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.nested-reply-user {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  letter-spacing: 1px;
}

.nested-reply-text {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
  margin-bottom: 8rpx;
  word-break: break-word;
  white-space: pre-wrap;
  letter-spacing: 1px;
}

.nested-reply-time {
  font-size: 20rpx;
  color: #bbb;
}

.nested-reply-footer {
  display: flex;
  gap: 24rpx;
}

.nested-reply-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  color: #bbb;
  padding: 6rpx 0;
}

.comment-item-focus,
.reply-item-focus,
.nested-reply-item-focus {
  animation: focusFlash 2.6s ease;
}

@keyframes focusFlash {
  0% {
    background: rgba(74, 144, 226, 0.12);
    box-shadow: 0 0 0 0 rgba(74, 144, 226, 0.26);
  }
  100% {
    background: transparent;
    box-shadow: 0 0 0 0 rgba(74, 144, 226, 0);
  }
}

.dynamic-detail-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(42, 72, 138, 0.08);
}

.dynamic-author-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.dynamic-author-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.dynamic-author-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.dynamic-author-meta {
  font-size: 24rpx;
  color: #8a94a6;
}

.dynamic-detail-content {
  font-size: 34rpx;
  line-height: 2;
  color: #202631;
  white-space: pre-wrap;
  word-break: break-word;
  letter-spacing: 1rpx;
}

.dynamic-hashtag {
  margin-top: 28rpx;
  font-size: 28rpx;
  color: #3675ff;
}

.dynamic-period-chip {
  margin-top: 20rpx;
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #4268c7;
  font-size: 24rpx;
}

.dynamic-date {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #9aa2b1;
}

.dynamic-share-actions {
  margin-top: 28rpx;
  display: flex;
  gap: 18rpx;
}

.dynamic-share-btn {
  flex: 1;
  border: none;
  border-radius: 999rpx;
  padding: 0 24rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: #ecf7ea;
  color: #1f9d45;
  font-size: 26rpx;
  text-align: center;
}

.dynamic-share-btn::after {
  border: none;
}

.dynamic-share-btn-plain {
  background: #f3f6fb;
  color: #607089;
}

.dynamic-like-strip {
  margin-top: 20rpx;
  padding: 0 12rpx 20rpx;
  border-bottom: 2rpx solid #e9edf4;
}

.dynamic-like-pill {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 0;
  color: #6b7280;
  font-size: 26rpx;
}

.dynamic-like-pill-icon,
.dynamic-bottom-action-icon {
  font-size: 30rpx;
  color: #8091aa;
}

.dynamic-like-pill-icon.liked,
.dynamic-bottom-action-icon.liked {
  color: #ff6b6b;
}

.dynamic-comments-block {
  margin-top: 28rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 28rpx;
}

.dynamic-comments-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.dynamic-replies-list {
  margin-left: 0;
  margin-top: 8rpx;
}

.dynamic-comments-empty {
  padding: 72rpx 0 84rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  color: #b8c0cd;
}

.dynamic-comments-empty-art {
  font-size: 68rpx;
}

.dynamic-comments-empty-text {
  font-size: 26rpx;
}

.dynamic-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 120;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 20rpx 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -10rpx 36rpx rgba(15, 23, 42, 0.08);
}

.dynamic-input-trigger {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #f3f5f9;
  color: #9aa2b1;
  font-size: 28rpx;
}

.dynamic-input-trigger-disabled {
  opacity: 0.7;
}

.dynamic-bottom-action {
  min-width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #ffffff;
  color: #6b7280;
  font-size: 28rpx;
  border: 2rpx solid #e9edf4;
  box-sizing: border-box;
}

.dynamic-bottom-share {
  border: 2rpx solid #e9edf4;
  line-height: 68rpx;
}

.dynamic-bottom-share::after {
  border: none;
}
