<view class="page-course-detail {{isCheckinDetailMode ? 'page-course-detail-detail' : ''}}">
  <block wx:if="{{isCheckinDetailMode}}">
    <view wx:if="{{detailCheckin}}" class="dynamic-detail-card">
      <view class="dynamic-author-row">
        <view
          class="comment-avatar"
          style="background: {{detailCheckin.avatarColor || '#4a90e2'}}"
          bindtap="handleAvatarClick"
          data-user-id="{{detailCheckin.userId}}">
          <image
            wx:if="{{detailCheckin.avatarUrl}}"
            class="avatar-image"
            src="{{detailCheckin.avatarUrl}}"
            mode="aspectFill" />
          <text wx:else class="avatar-text">{{detailCheckin.avatarText}}</text>
        </view>

        <view class="dynamic-author-copy">
          <text
            class="dynamic-author-name"
            bindtap="handleAvatarClick"
            data-user-id="{{detailCheckin.userId}}">{{detailCheckin.userName}}</text>
          <text class="dynamic-author-meta">{{detailCheckin.metaLine}}</text>
        </view>
      </view>

      <view class="dynamic-detail-content {{detailCheckin.canExpandContent && !detailCheckin.contentExpanded ? 'dynamic-detail-content-clamped' : ''}}"><text selectable>{{detailCheckin.content}}</text></view>
      <view
        wx:if="{{detailCheckin.canExpandContent}}"
        class="checkin-content-toggle dynamic-content-toggle"
        bindtap="toggleCheckinContent"
        data-checkin-id="{{detailCheckin.id}}">{{detailCheckin.contentExpanded ? '收起' : '展开更多'}}</view>

      <view wx:if="{{detailCheckin.hashTag}}" class="dynamic-hashtag">{{detailCheckin.hashTag}}</view>

      <view wx:if="{{detailCheckin.periodChip}}" class="dynamic-period-chip">{{detailCheckin.periodChip}}</view>

      <view wx:if="{{detailCheckin.dateLabel}}" class="dynamic-date">{{detailCheckin.dateLabel}}</view>

      <view wx:if="{{detailCheckin.canShare}}" class="dynamic-share-actions">
        <button class="dynamic-share-btn dynamic-share-btn-plain" bindtap="handleLongImageShare">{{posterGenerating ? '生成中...' : '长图'}}</button>
        <button class="dynamic-share-btn" open-type="share">微信好友</button>
      </view>
    </view>

    <view wx:if="{{detailCheckin}}" class="dynamic-like-strip">
      <view class="dynamic-like-pill" bindtap="handleLikeComment" data-id="{{detailCheckin.id}}">
        <text class="dynamic-like-pill-icon {{detailCheckin.isLiked ? 'liked' : ''}}">♡</text>
        <text class="dynamic-like-pill-count">{{detailCheckin.likeCount || 0}}</text>
      </view>
    </view>

    <view class="dynamic-comments-block">
      <view class="dynamic-comments-title">全部评论</view>

      <view
        wx:if="{{detailCheckin && detailCheckin.replies && detailCheckin.replies.length > 0}}"
        class="replies-list dynamic-replies-list">
        <view
          wx:for="{{detailCheckin.replies}}"
          wx:key="id"
          wx:for-item="reply"
          class="reply-item {{highlightCommentId === reply.id ? 'reply-item-focus' : ''}}"
          id="comment-{{reply.id}}">
          <view class="reply-left-line"></view>
          <view class="reply-main">
            <view
              class="reply-avatar"
              style="background: {{reply.avatarColor || '#7eb5f0'}}"
              bindtap="handleAvatarClick"
              data-user-id="{{reply.userId}}">
              <image wx:if="{{reply.avatarUrl}}" class="avatar-image avatar-image-small" src="{{reply.avatarUrl}}" mode="aspectFill" />
              <text wx:else class="avatar-text">{{reply.avatarText}}</text>
            </view>

            <view class="reply-content">
              <view class="reply-header">
                <text class="reply-user" bindtap="handleAvatarClick" data-user-id="{{reply.userId}}">{{reply.userName}}</text>
                <text class="reply-time">{{reply.createTime}}</text>
              </view>
              <view class="reply-text">{{reply.content}}</view>
              <view class="reply-footer">
                <view class="reply-like" bindtap="handleLikeReply" data-comment-id="{{detailCheckin.id}}" data-reply-id="{{reply.id}}">
                  <text class="like-icon {{reply.isLiked ? 'liked' : ''}}">♡</text>
                  <text class="like-count">{{reply.likeCount || 0}}</text>
                </view>
                <view
                  class="reply-reply"
                  bindtap="handleReplyToReply"
                  data-checkin-id="{{detailCheckin.id}}"
                  data-comment-id="{{reply.id}}"
                  data-reply-id="{{reply.userId}}"
                  data-user-name="{{reply.userName}}">
                  <text class="reply-icon">💬</text>
                  <text>回复</text>
                </view>
              </view>

              <view wx:if="{{reply.replies && reply.replies.length > 0}}" class="nested-replies-list">
                <view
                  wx:for="{{reply.replies}}"
                  wx:key="id"
                  wx:for-item="nestedReply"
                  class="nested-reply-item {{highlightReplyId === nestedReply.id ? 'nested-reply-item-focus' : ''}}"
                  id="reply-{{nestedReply.id}}">
                  <view class="nested-reply-left-line"></view>
                  <view class="nested-reply-main">
                    <view
                      class="nested-reply-avatar"
                      style="background: {{nestedReply.avatarColor || '#9cb5f0'}}"
                      bindtap="handleAvatarClick"
                      data-user-id="{{nestedReply.userId}}">
                      <image wx:if="{{nestedReply.avatarUrl}}" class="avatar-image avatar-image-tiny" src="{{nestedReply.avatarUrl}}" mode="aspectFill" />
                      <text wx:else class="avatar-text">{{nestedReply.avatarText}}</text>
                    </view>

                    <view class="nested-reply-content">
                      <view class="nested-reply-header">
                        <text class="nested-reply-user" bindtap="handleAvatarClick" data-user-id="{{nestedReply.userId}}">{{nestedReply.userName}}</text>
                        <text class="nested-reply-time">{{nestedReply.createTime}}</text>
                      </view>
                      <view class="nested-reply-text">{{nestedReply.content}}</view>
                      <view class="nested-reply-footer">
                        <view class="nested-reply-like" bindtap="handleLikeReply" data-comment-id="{{detailCheckin.id}}" data-reply-id="{{nestedReply.id}}">
                          <text class="like-icon {{nestedReply.isLiked ? 'liked' : ''}}">♡</text>
                          <text class="like-count">{{nestedReply.likeCount || 0}}</text>
                        </view>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:else class="dynamic-comments-empty">
        <view class="dynamic-comments-empty-art">📭</view>
        <text class="dynamic-comments-empty-text">内容为空</text>
      </view>
    </view>

    <view wx:if="{{detailCheckin}}" class="dynamic-bottom-bar">
      <view
        class="dynamic-input-trigger {{communityAccessState !== 'enabled' ? 'dynamic-input-trigger-disabled' : ''}}"
        bindtap="handleReplyComment"
        data-id="{{detailCheckin.id}}">
        说点什么...
      </view>
      <view class="dynamic-bottom-action" bindtap="handleLikeComment" data-id="{{detailCheckin.id}}">
        <text class="dynamic-bottom-action-icon {{detailCheckin.isLiked ? 'liked' : ''}}">♡</text>
        <text>{{detailCheckin.likeCount || 0}}</text>
      </view>
      <button wx:if="{{detailCheckin.canShare}}" class="dynamic-bottom-action dynamic-bottom-share" open-type="share">↗</button>
    </view>
  </block>

  <block wx:else>
    <view class="course-header">
      <view class="course-title">{{course.title}}</view>
    </view>

    <view class="notification-reminder" wx:if="{{communityAccessState === 'enabled' && notificationReminder}}">
      <text class="notification-reminder-text">{{notificationReminder}}</text>
      <view class="notification-reminder-link" bindtap="navigateToNotificationSettings">去补充</view>
    </view>

    <view class="content-section" wx:if="{{course.meditationVisible}}">
      <view class="section-title">
        <view class="section-icon calm">静</view>
        <text>静一静</text>
      </view>
      <view class="section-content"><text selectable>{{course.meditation}}</text></view>
    </view>

    <view class="content-section" wx:if="{{course.questionVisible}}">
      <view class="section-title">
        <view class="section-icon question">问</view>
        <text>问一问</text>
      </view>
      <view class="section-content"><text selectable>{{course.question}}</text></view>
    </view>

    <view class="content-section" wx:if="{{course.contentVisible}}">
      <view class="section-title">
        <view class="section-icon read">读</view>
        <text>读一读</text>
      </view>
      <view class="section-content">
        <rich-text nodes="{{course.content}}"></rich-text>
      </view>
    </view>

    <view class="content-section" wx:if="{{course.reflectionVisible}}">
      <view class="section-title">
        <view class="section-icon think">想</view>
        <text>想一想</text>
      </view>
      <view class="section-content"><text selectable>{{course.reflection}}</text></view>
    </view>

    <view class="content-section" wx:if="{{course.actionVisible}}">
      <view class="section-title">
        <view class="section-icon write">记</view>
        <text>记一记</text>
      </view>
      <view class="section-content"><text selectable>{{course.action}}</text></view>
    </view>

    <view class="content-section" wx:if="{{course.extractVisible}}">
      <view class="section-title">
        <view class="section-icon extract">摘</view>
        <text>摘一摘</text>
      </view>
      <view class="section-content"><text selectable>{{course.extract}}</text></view>
    </view>

    <view class="content-section" wx:if="{{course.sayVisible}}">
      <view class="section-title">
        <view class="section-icon share">说</view>
        <text>说一说</text>
      </view>
      <view class="section-content"><text selectable>{{course.say}}</text></view>
    </view>

    <view class="content-section" wx:if="{{course.learnVisible}}">
      <view class="section-title">
        <view class="section-icon learn">学</view>
        <text>学一学</text>
      </view>
      <view class="section-content"><text selectable>{{course.learn}}</text></view>
    </view>

    <view class="comments-section" wx:if="{{communityAccessState === 'enabled'}}">
      <view class="comments-header">
        <view class="comments-icon">✅</view>
        <text class="comments-title">每日打卡</text>
        <text class="comments-count" wx:if="{{course.comments.length}}">（{{course.comments.length}} 条）</text>
      </view>

      <view class="comments-list">
        <view
          class="comment-item {{highlightCheckinId === item.id ? 'comment-item-focus' : ''}}"
          id="checkin-{{item.id}}"
          wx:for="{{course.comments}}"
          wx:key="id"
          wx:if="{{item}}"
          bindtap="handleCheckinDetailTap"
          data-checkin-id="{{item.id}}"
          data-section-id="{{item.sectionId || courseId}}">
          <view class="comment-avatar" style="background: {{item.avatarColor || '#4a90e2'}}" catchtap="handleAvatarClick" data-user-id="{{item.userId}}">
            <image wx:if="{{item.avatarUrl}}" class="avatar-image" src="{{item.avatarUrl}}" mode="aspectFill" />
            <text wx:else class="avatar-text">{{item.avatarText}}</text>
          </view>
          <view class="comment-content">
            <view class="comment-header">
              <text class="comment-user" catchtap="handleAvatarClick" data-user-id="{{item.userId}}">{{item.userName}}</text>
              <text class="comment-time">{{item.createTime}}</text>
            </view>
            <view class="comment-text {{item.canExpandContent && !item.contentExpanded ? 'comment-text-clamped' : ''}}"><text selectable>{{item.content}}</text></view>
            <view
              wx:if="{{item.canExpandContent}}"
              class="checkin-content-toggle"
              catchtap="toggleCheckinContent"
              data-checkin-id="{{item.id}}">{{item.contentExpanded ? '收起' : '展开更多'}}</view>
            <view class="comment-footer">
              <view class="comment-like" catchtap="handleLikeComment" data-id="{{item.id}}">
                <text class="like-icon {{item.isLiked ? 'liked' : ''}}">❤️</text>
                <text class="like-count">{{item.likeCount}}</text>
              </view>
              <view class="comment-reply" catchtap="handleReplyComment" data-id="{{item.id}}">
                <text class="reply-icon">💬</text>
                <text>回复</text>
              </view>
              <view class="comment-toggle" catchtap="toggleComments" data-index="{{index}}">
                <text class="toggle-icon">💬</text>
                <text class="toggle-text" wx:if="{{!commentLoading[item.id]}}">{{commentExpanded[item.id] ? '收起评论' : '查看评论'}}</text>
                <text class="toggle-text loading" wx:else>加载中...</text>
              </view>
            </view>

            <view class="replies-list" wx:if="{{commentExpanded[item.id] && item.replies && item.replies.length > 0}}" catchtap="noop">
              <view
                class="reply-item {{highlightCommentId === reply.id ? 'reply-item-focus' : ''}}"
                id="comment-{{reply.id}}"
                wx:for="{{item.replies}}"
                wx:key="id"
                wx:for-item="reply">
                <view class="reply-left-line"></view>
                <view class="reply-main">
                  <view class="reply-avatar" style="background: {{reply.avatarColor || '#7eb5f0'}}" bindtap="handleAvatarClick" data-user-id="{{reply.userId}}">
                    <text class="avatar-text">{{reply.avatarText}}</text>
                  </view>
                  <view class="reply-content">
                    <view class="reply-header">
                      <text class="reply-user" bindtap="handleAvatarClick" data-user-id="{{reply.userId}}">{{reply.userName}}</text>
                      <text class="reply-time">{{reply.createTime}}</text>
                    </view>
                    <view class="reply-text"><text selectable>{{reply.content}}</text></view>
                    <view class="reply-footer" style="pointer-events: auto;">
                      <view class="reply-like" bindtap="handleLikeReply" data-comment-id="{{item.id}}" data-reply-id="{{reply.id}}" style="pointer-events: auto;">
                        <text class="like-icon {{reply.isLiked ? 'liked' : ''}}">❤️</text>
                        <text class="like-count">{{reply.likeCount || 0}}</text>
                      </view>
                      <view class="reply-reply" bindtap="handleReplyToReply" data-checkin-id="{{item.id}}" data-comment-id="{{reply.id}}" data-reply-id="{{reply.userId}}" data-user-name="{{reply.userName}}" style="pointer-events: auto;">
                        <text class="reply-icon">💬</text>
                        <text>回复</text>
                      </view>
                    </view>

                    <view class="nested-replies-list" wx:if="{{reply.replies && reply.replies.length > 0}}">
                      <view
                        class="nested-reply-item {{highlightReplyId === nestedReply.id ? 'nested-reply-item-focus' : ''}}"
                        id="reply-{{nestedReply.id}}"
                        wx:for="{{reply.replies}}"
                        wx:key="id"
                        wx:for-item="nestedReply">
                        <view class="nested-reply-left-line"></view>
                        <view class="nested-reply-main">
                          <view class="nested-reply-avatar" style="background: {{nestedReply.avatarColor || '#9cb5f0'}}" bindtap="handleAvatarClick" data-user-id="{{nestedReply.userId}}">
                            <text class="avatar-text">{{nestedReply.avatarText}}</text>
                          </view>
                          <view class="nested-reply-content">
                            <view class="nested-reply-header">
                              <text class="nested-reply-user" bindtap="handleAvatarClick" data-user-id="{{nestedReply.userId}}">{{nestedReply.userName}}</text>
                              <text class="nested-reply-time">{{nestedReply.createTime}}</text>
                            </view>
                            <view class="nested-reply-text"><text selectable>{{nestedReply.content}}</text></view>
                            <view class="nested-reply-footer" style="pointer-events: auto;">
                              <view class="nested-reply-like" bindtap="handleLikeReply" data-comment-id="{{item.id}}" data-reply-id="{{nestedReply.id}}" style="pointer-events: auto;">
                                <text class="like-icon {{nestedReply.isLiked ? 'liked' : ''}}">❤️</text>
                                <text class="like-count">{{nestedReply.likeCount || 0}}</text>
                              </view>
                            </view>
                          </view>
                        </view>
                      </view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{checkinHasMore || checkinLoadingMore}}" class="checkin-load-more">
        <view wx:if="{{checkinLoadingMore}}" class="checkin-load-more-text">加载中...</view>
        <view wx:else class="checkin-load-more-btn" bindtap="loadMoreCheckins">加载更多打卡记录 ↓</view>
      </view>
    </view>

    <view class="fixed-buttons {{communityAccessState !== 'enabled' ? 'single-action' : ''}}">
      <button class="btn-back {{communityAccessState !== 'enabled' ? 'full-width' : ''}}" bindtap="handleBack">返回</button>
      <button
        wx:if="{{communityAccessState === 'enabled'}}"
        class="btn-checkin {{hasUserCheckedIn ? 'disabled' : ''}}"
        bindtap="handleCheckin"
        disabled="{{hasUserCheckedIn}}">
        {{hasUserCheckedIn ? '已打卡' : '去打卡'}}
      </button>
    </view>
  </block>

  <view wx:if="{{posterGalleryVisible}}" class="poster-gallery-overlay" bindtap="closePosterGallery">
    <view class="poster-gallery-shell" catchtap="noop">
      <view class="poster-gallery-header">
        <view>
          <view class="poster-gallery-title">长图模板</view>
          <view class="poster-gallery-subtitle">切换样式后可预览或保存</view>
        </view>
        <view class="poster-gallery-close" bindtap="closePosterGallery">×</view>
      </view>

      <view class="poster-gallery-preview-wrap">
        <image
          wx:if="{{selectedPoster && selectedPoster.tempFilePath}}"
          class="poster-gallery-preview"
          src="{{selectedPoster.tempFilePath}}"
          mode="aspectFit" />
        <view class="poster-gallery-index">{{posterSelectedIndex + 1}} / {{posterGalleryItems.length}}</view>
      </view>

      <scroll-view scroll-x class="poster-gallery-scroll" show-scrollbar="{{false}}" enhanced="true">
        <view class="poster-gallery-list">
          <view
            wx:for="{{posterGalleryItems}}"
            wx:key="id"
            class="poster-gallery-thumb {{index === posterSelectedIndex ? 'poster-gallery-thumb-active' : ''}}"
            bindtap="handlePosterTemplateSelect"
            data-index="{{index}}">
            <image class="poster-gallery-thumb-image" src="{{item.tempFilePath}}" mode="aspectFill" />
            <text class="poster-gallery-thumb-name">{{item.name}}</text>
          </view>
        </view>
      </scroll-view>

      <view class="poster-gallery-actions">
        <button class="poster-gallery-btn poster-gallery-btn-plain" bindtap="handleSaveSelectedPoster">保存</button>
        <button class="poster-gallery-btn poster-gallery-btn-ghost" bindtap="handlePreviewSelectedPoster">预览</button>
        <button wx:if="{{canShareCurrentCheckin}}" class="poster-gallery-btn" open-type="share">微信好友</button>
      </view>
    </view>
  </view>

  <canvas
    id="longImageCanvas"
    canvas-id="longImageCanvas"
    type="2d"
    class="long-image-canvas"></canvas>
</view>
