<view class="page-activity-detail">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{!loading && activity}}">
    <!-- 基本信息卡片 -->
    <view class="info-card">
      <view class="type-tag type-{{activity.type}}">{{typeMap[activity.type] || activity.type}}</view>
      <text class="activity-title">{{activity.title}}</text>
      <view class="time-row">
        <text class="time-label">开始</text>
        <text class="time-value">{{activity.startTimeFormatted}}</text>
      </view>
      <view class="time-row" wx:if="{{activity.endTimeFormatted}}">
        <text class="time-label">结束</text>
        <text class="time-value">{{activity.endTimeFormatted}}</text>
      </view>
      <view class="count-row">
        <text class="count-text">已报名 {{activity.registrationCount || 0}} 人</text>
        <text wx:if="{{activity.maxParticipants > 0}}" class="count-limit"> / 上限 {{activity.maxParticipants}} 人</text>
      </view>
    </view>

    <!-- 腾讯会议区域（活动开始前30分钟到结束后显示） -->
    <view wx:if="{{showMeeting}}" class="meeting-card">
      <text class="meeting-title">腾讯会议</text>
      <view wx:if="{{activity.meetingId}}" class="meeting-id-row">
        <text class="meeting-id-label">会议号：</text>
        <text class="meeting-id-value">{{activity.meetingId}}</text>
      </view>
      <view class="meeting-actions">
        <view class="meeting-btn primary" bindtap="handleJoinMeeting">加入腾讯会议</view>
        <view wx:if="{{activity.meetingId}}" class="meeting-btn secondary" bindtap="handleCopyMeetingId">复制会议号</view>
      </view>
    </view>

    <!-- 我的报名信息 -->
    <view wx:if="{{activity.userRegistration && submittedAnswers.length > 0}}" class="my-registration-card">
      <view class="my-registration-head">
        <text class="my-registration-title">我的报名信息</text>
        <text class="my-registration-status">
          {{activity.userRegistration.paymentStatus === 'pending' ? '待支付' : '已提交'}}
        </text>
      </view>
      <view class="answer-list">
        <view wx:for="{{submittedAnswers}}" wx:key="fieldId" class="answer-row">
          <text class="answer-label">{{item.label}}</text>
          <text class="answer-value">{{item.displayValue}}</text>
        </view>
      </view>
    </view>

    <!-- 海报图 -->
    <image
      wx:if="{{activity.posterUrl}}"
      class="poster-image"
      src="{{activity.posterUrl}}"
      mode="widthFix"
    />

    <!-- 活动描述 -->
    <view wx:if="{{activity.descriptionHtml}}" class="desc-card">
      <text class="desc-title">活动介绍</text>
      <rich-text class="desc-content" nodes="{{activity.descriptionHtml}}" />
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar">
      <view class="bottom-bar-inner">
        <view
          wx:if="{{activity.computedStatus === 'cancelled' || activity.computedStatus === 'ended'}}"
          class="action-btn disabled"
        >
          <text>{{activity.computedStatus === 'cancelled' ? '活动已取消' : '活动已结束'}}</text>
        </view>
        <block wx:else>
          <!-- 付费待支付（pending），优先于立即报名 -->
          <view
            wx:if="{{!registered && activity.isPaid && activity.userRegistration.paymentStatus === 'pending'}}"
            class="action-btn primary"
            bindtap="handleContinuePay"
          >
            <text>继续支付 ¥{{activity.priceDisplay}}</text>
          </view>
          <!-- 付费未报名 -->
          <view
            wx:elif="{{!registered && activity.isPaid && activity.computedStatus === 'upcoming'}}"
            class="action-btn primary {{registering ? 'loading' : ''}}"
            bindtap="handleRegister"
          >
            <text>{{registering ? '处理中...' : '立即报名 ¥' + activity.priceDisplay}}</text>
          </view>
          <!-- 免费未报名 -->
          <view
            wx:elif="{{!registered}}"
            class="action-btn primary {{registering ? 'loading' : ''}}"
            bindtap="handleRegister"
          >
            <text>{{registering ? '报名中...' : '立即报名'}}</text>
          </view>
          <view
            wx:else
            class="action-btn cancel {{registering ? 'loading' : ''}}"
            bindtap="handleCancelRegister"
          >
            <text>{{registering ? '处理中...' : '取消报名'}}</text>
          </view>
        </block>
        <button class="share-btn" open-type="share">
          <text class="share-icon">↗</text>
          <text class="share-text">分享</text>
        </button>
      </view>
    </view>
  </block>

  <!-- 报名表单弹窗 -->
  <view wx:if="{{showFormModal}}" class="form-modal-mask" bindtap="handleFormCancel">
    <view class="form-modal" catchtap="noop">
      <view class="form-modal-title">填写报名信息</view>
      <scroll-view class="form-fields" scroll-y>
        <view wx:for="{{registrationFormFields}}" wx:key="fieldId" class="form-field">
          <view class="form-label">
            <text>{{item.label}}</text>
            <text wx:if="{{item.required}}" class="form-required">*</text>
          </view>
          <input
            wx:if="{{item.type === 'text' || item.type === 'phone' || item.type === 'number'}}"
            class="form-input"
            type="{{item.type === 'number' ? 'digit' : item.type === 'phone' ? 'number' : 'text'}}"
            value="{{item.value}}"
            placeholder="{{item.placeholder || '请输入'}}"
            data-field-id="{{item.fieldId}}"
            bindinput="handleFormInput"
          />
          <picker
            wx:elif="{{item.type === 'date'}}"
            mode="date"
            value="{{item.value}}"
            data-field-id="{{item.fieldId}}"
            bindchange="handleFormInput"
          >
            <view class="form-picker {{item.value ? '' : 'placeholder'}}">
              {{item.value || item.placeholder || '请选择日期'}}
            </view>
          </picker>
          <textarea
            wx:elif="{{item.type === 'textarea'}}"
            class="form-textarea"
            value="{{item.value}}"
            placeholder="{{item.placeholder || '请输入'}}"
            data-field-id="{{item.fieldId}}"
            bindinput="handleFormInput"
          />
          <view wx:elif="{{item.type === 'single_select'}}" class="option-list">
            <view
              wx:for="{{item.options}}"
              wx:for-item="option"
              wx:key="optionId"
              class="option-item {{option.checked ? 'selected' : ''}}"
              data-field-id="{{item.fieldId}}"
              data-option-id="{{option.optionId}}"
              bindtap="handleSingleSelect"
            >
              <text>{{option.label}}</text>
              <text wx:if="{{option.checked}}" class="option-check">✓</text>
            </view>
          </view>
          <view wx:elif="{{item.type === 'multi_select'}}" class="option-list">
            <view
              wx:for="{{item.options}}"
              wx:for-item="option"
              wx:key="optionId"
              class="option-item {{option.checked ? 'selected' : ''}}"
              data-field-id="{{item.fieldId}}"
              data-option-id="{{option.optionId}}"
              bindtap="handleMultiSelect"
            >
              <text>{{option.label}}</text>
              <text wx:if="{{option.checked}}" class="option-check">✓</text>
            </view>
          </view>
          <view wx:elif="{{item.type === 'boolean'}}" class="switch-row">
            <text>{{item.placeholder || '是否确认'}}</text>
            <switch
              checked="{{item.value}}"
              data-field-id="{{item.fieldId}}"
              bindchange="handleBooleanChange"
            />
          </view>
        </view>
      </scroll-view>
      <view class="form-modal-actions">
        <view class="form-btn cancel" bindtap="handleFormCancel">取消</view>
        <view class="form-btn confirm {{formSubmitting ? 'loading' : ''}}" bindtap="handleFormSubmit">
          <text>{{activity.isPaid ? '提交并支付 ¥' + activity.priceDisplay : '提交报名'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 支付确认弹窗 -->
  <view wx:if="{{showPayModal}}" class="pay-modal-mask" bindtap="handlePayCancel">
    <view class="pay-modal" catchtap="noop">
      <view class="pay-modal-title">确认报名</view>
      <view class="pay-modal-activity">{{activity.title}}</view>
      <view class="pay-modal-row">
        <text class="pay-label">原价</text>
        <text class="pay-value">¥{{payInfo.originalPriceDisplay}}</text>
      </view>
      <view wx:if="{{payInfo.coupon}}" class="pay-modal-row coupon-row">
        <text class="pay-label">优惠券</text>
        <view class="pay-coupon-right">
          <text class="pay-discount">{{payInfo.discountDisplay}}</text>
          <text class="pay-coupon-name">{{payInfo.coupon.name}}</text>
        </view>
      </view>
      <view class="pay-modal-divider"></view>
      <view class="pay-modal-row final-row">
        <text class="pay-label">实付</text>
        <text class="pay-final">¥{{payInfo.finalPriceDisplay}}</text>
      </view>
      <view class="pay-modal-actions">
        <view class="pay-btn cancel" bindtap="handlePayCancel">取消</view>
        <view class="pay-btn confirm {{paying ? 'loading' : ''}}" bindtap="handlePayConfirm">
          <text>{{paying ? '支付中...' : '立即支付'}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
