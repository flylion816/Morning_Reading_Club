.page-activity-detail {
  background: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: var(--theme-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.poster-image {
  width: 100%;
  display: block;
}

.info-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.type-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  background: var(--theme-primary-tint);
  color: var(--theme-primary);
}

.type-tag.type-witness { background: #fce8e8; color: #e53935; }
.type-tag.type-chat { background: #e8f5e9; color: #43a047; }
.type-tag.type-other { background: #f3e5f5; color: #8e24aa; }

.activity-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.time-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.time-label {
  font-size: 26rpx;
  color: #999;
  width: 60rpx;
}

.time-value {
  font-size: 28rpx;
  color: #444;
}

.count-row {
  margin-top: 16rpx;
}

.count-text {
  font-size: 26rpx;
  color: #666;
}

.count-limit {
  font-size: 26rpx;
  color: #999;
}

.meeting-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  border-left: 6rpx solid #1aad19;
}

.meeting-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1aad19;
  margin-bottom: 16rpx;
}

.meeting-id-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.meeting-id-label {
  font-size: 26rpx;
  color: #666;
}

.meeting-id-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.meeting-actions {
  display: flex;
  gap: 20rpx;
}

.meeting-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.meeting-btn.primary {
  background: #1aad19;
  color: #fff;
}

.meeting-btn.secondary {
  background: #f0f0f0;
  color: #333;
}

.my-registration-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
}

.my-registration-head,
.answer-row,
.switch-row,
.option-item,
.form-modal-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.my-registration-title {
  color: #222;
  font-size: 30rpx;
  font-weight: 600;
}

.my-registration-status {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  background: var(--theme-primary-tint);
  color: var(--theme-primary);
  font-size: 22rpx;
}

.answer-list {
  margin-top: 18rpx;
}

.answer-row {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
  gap: 24rpx;
}

.answer-row:last-child {
  border-bottom: 0;
}

.answer-label {
  color: #667085;
  font-size: 26rpx;
}

.answer-value {
  color: #1f2937;
  font-size: 26rpx;
  font-weight: 500;
  text-align: right;
}

.desc-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.desc-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.bottom-bar-inner {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.action-btn.primary { background: var(--theme-primary); color: #fff; }
.action-btn.cancel { background: #f5f5f5; color: #666; }
.action-btn.disabled { background: #e0e0e0; color: #999; }
.action-btn.loading { opacity: 0.7; }

.share-btn {
  width: 120rpx;
  min-width: 120rpx;
  height: 88rpx;
  background: var(--theme-primary-tint);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
  line-height: 1;
  gap: 4rpx;
}

.share-btn::after { border: none; }

.share-icon {
  font-size: 32rpx;
  color: var(--theme-primary);
  line-height: 1;
}

.share-text {
  font-size: 22rpx;
  color: var(--theme-primary);
  line-height: 1;
}

/* 报名表单弹窗 */
.form-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
}

.form-modal {
  width: 100%;
  max-height: 82vh;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.form-modal-title {
  color: #1f2937;
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.form-fields {
  max-height: 58vh;
}

.form-field {
  margin-bottom: 24rpx;
}

.form-label {
  color: #344054;
  font-size: 27rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.form-required {
  color: #e53935;
  margin-left: 4rpx;
}

.form-input,
.form-picker,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #1f2937;
  font-size: 28rpx;
  padding: 0 20rpx;
}

.form-input {
  height: 78rpx;
}

.form-picker {
  height: 78rpx;
  line-height: 78rpx;
}

.form-picker.placeholder {
  color: #98a2b3;
}

.form-textarea {
  min-height: 150rpx;
  padding-top: 18rpx;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option-item {
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #344054;
  font-size: 27rpx;
  box-sizing: border-box;
}

.option-item.selected {
  background: var(--theme-primary-tint);
  color: var(--theme-primary);
}

.option-check {
  font-size: 28rpx;
  font-weight: 700;
}

.switch-row {
  min-height: 78rpx;
  padding: 0 20rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  color: #344054;
  font-size: 27rpx;
}

.form-modal-actions {
  gap: 18rpx;
  margin-top: 24rpx;
}

.form-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.form-btn.cancel {
  background: #f2f4f7;
  color: #667085;
}

.form-btn.confirm {
  background: var(--theme-primary);
  color: #fff;
}

.form-btn.loading {
  opacity: 0.65;
}

/* 支付确认弹窗 */
.pay-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.pay-modal {
  background: #fff;
  border-radius: 24rpx;
  width: 600rpx;
  padding: 40rpx;
  box-sizing: border-box;
}

.pay-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  text-align: center;
  margin-bottom: 12rpx;
}

.pay-modal-activity {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}

.pay-modal-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.pay-label {
  font-size: 28rpx;
  color: #666;
}

.pay-value {
  font-size: 28rpx;
  color: #333;
}

.coupon-row {
  align-items: flex-start;
}

.pay-coupon-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.pay-discount {
  font-size: 28rpx;
  color: #e53935;
}

.pay-coupon-name {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.pay-modal-divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 8rpx 0;
}

.final-row {
  padding: 20rpx 0;
}

.pay-final {
  font-size: 36rpx;
  font-weight: 600;
  color: #e53935;
}

.pay-modal-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
  margin-top: 40rpx;
}

.pay-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.pay-btn.cancel {
  background: #f0f0f0;
  color: #666;
}

.pay-btn.confirm {
  background: #07c160;
  color: #fff;
}

.pay-btn.loading {
  opacity: 0.6;
}
