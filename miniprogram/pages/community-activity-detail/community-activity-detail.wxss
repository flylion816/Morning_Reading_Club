.page-activity-detail {
  background: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

.poster-image {
  width: 100%;
  display: block;
}

.info-card {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.type-tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
  background: #e8f0fe;
  color: #4a6cf7;
}

.type-tag.type-witness { background: #fce8e8; color: #e53935; }
.type-tag.type-chat { background: #e8f5e9; color: #43a047; }
.type-tag.type-other { background: #f3e5f5; color: #8e24aa; }

.activity-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 24rpx;
  line-height: 1.4;
}

.time-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.time-label {
  font-size: 26rpx;
  color: #999;
  width: 60rpx;
}

.time-value {
  font-size: 28rpx;
  color: #444;
}

.count-row {
  margin-top: 16rpx;
}

.count-text {
  font-size: 26rpx;
  color: #666;
}

.count-limit {
  font-size: 26rpx;
  color: #999;
}

.meeting-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 32rpx;
  border-left: 6rpx solid #1aad19;
}

.meeting-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1aad19;
  margin-bottom: 16rpx;
}

.meeting-id-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.meeting-id-label {
  font-size: 26rpx;
  color: #666;
}

.meeting-id-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.meeting-actions {
  display: flex;
  gap: 20rpx;
}

.meeting-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.meeting-btn.primary {
  background: #1aad19;
  color: #fff;
}

.meeting-btn.secondary {
  background: #f0f0f0;
  color: #333;
}

.desc-card {
  background: #fff;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  padding: 32rpx;
}

.desc-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.bottom-bar-inner {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.action-btn.primary { background: #667eea; color: #fff; }
.action-btn.cancel { background: #f5f5f5; color: #666; }
.action-btn.disabled { background: #e0e0e0; color: #999; }
.action-btn.loading { opacity: 0.7; }

.share-btn {
  width: 120rpx;
  min-width: 120rpx;
  height: 88rpx;
  background: #f0f2ff;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
  line-height: 1;
  gap: 4rpx;
}

.share-btn::after { border: none; }

.share-icon {
  font-size: 32rpx;
  color: #667eea;
  line-height: 1;
}

.share-text {
  font-size: 22rpx;
  color: #667eea;
  line-height: 1;
}
