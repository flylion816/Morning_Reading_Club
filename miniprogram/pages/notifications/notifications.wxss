/**
 * 通知页面样式
 */

.notifications-container {
  background: #f5f5f5;
  min-height: 100vh;
  padding: 24rpx 0 40rpx;
}

.tab-badge {
  background: #ff5a5f;
  color: white;
  font-size: 18rpx;
  min-width: 30rpx;
  height: 30rpx;
  padding: 0 7rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  line-height: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 90, 95, 0.24);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 24rpx;
  padding: 128rpx 32rpx;
  text-align: center;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 24rpx;
  padding: 100rpx 32rpx;
  background: #ffffff;
  border-radius: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
}

.loading-text {
  color: #9ca3af;
  font-size: 26rpx;
}

/* 选项卡 */
.tabs {
  display: flex;
  align-items: center;
  background: #eef2f7;
  border-radius: 16rpx;
  padding: 6rpx;
  margin: 0 24rpx 20rpx;
  gap: 4rpx;
}

.tab-item {
  flex: 1;
  height: 56rpx;
  padding: 0 6rpx;
  text-align: center;
  font-size: 24rpx;
  font-weight: 600;
  color: #64748b;
  border-radius: 12rpx;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6rpx;
  line-height: 1;
  white-space: nowrap;
}

.tab-item.active {
  color: var(--theme-primary);
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(15, 23, 42, 0.06);
}

.tab-action {
  color: var(--theme-primary);
  font-size: 22rpx;
}

.tab-action.disabled {
  color: #94a3b8;
  opacity: 0.55;
}

/* 通知列表 */
.notifications-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.notification-item {
  display: flex;
  position: relative;
  background: white;
  margin: 0;
  padding: 24rpx;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s ease;
  overflow: hidden;
}

.notification-item:active {
  transform: scale(0.99);
  background: #f8fafc;
}

.notification-item.unread {
  background: #f5f8ff;
  border-left: 6rpx solid var(--theme-primary);
}

.notification-item.read {
  opacity: 0.82;
}

/* 通知内容 */
.notification-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-width: 0;
}

/* 通知标题 */
.notification-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.notification-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-width: 0;
}

.type-icon {
  font-size: 32rpx;
  line-height: 1;
  flex-shrink: 0;
}

.type-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.action-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  font-size: 28rpx;
  color: #94a3b8;
  background: #f1f5f9;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  padding: 0;
}

.action-btn:active {
  opacity: 0.7;
}

.delete-btn {
  color: #94a3b8;
}

/* 通知消息 */
.notification-message {
  font-size: 28rpx;
  color: #64748b;
  line-height: 1.5;
  width: 100%;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 发送者信息 */
.sender-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 2rpx;
}

.sender-avatar {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e5e7eb;
  flex-shrink: 0;
}

.sender-avatar-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--theme-primary);
  color: white;
  font-size: 20rpx;
  font-weight: 600;
}

.sender-avatar-text {
  color: #fff;
  font-size: 24rpx;
}

.sender-name {
  font-size: 26rpx;
  color: #94a3b8;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 通知底部 */
.notification-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 2rpx;
  font-size: 24rpx;
  gap: 16rpx;
}

.notification-footer-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.notification-status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: var(--theme-primary);
  box-shadow: 0 0 0 6rpx var(--theme-primary-alpha-12);
  flex-shrink: 0;
}

.time {
  color: #cbd5e1;
}

.notification-action-hint {
  color: var(--theme-primary);
  font-size: 24rpx;
  font-weight: 600;
  background: #eef4ff;
  border-radius: 999rpx;
  padding: 10rpx 18rpx;
  line-height: 1;
  flex-shrink: 0;
}

/* 分页 */
.pagination {
  padding: 30rpx 24rpx;
  display: flex;
  justify-content: center;
}

.load-more-btn {
  width: 100%;
  max-width: 320rpx;
  height: 72rpx;
  background: var(--theme-primary);
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 999rpx;
  border: none;
  box-shadow: 0 6rpx 18rpx var(--theme-primary-alpha-28);
}

.load-more-btn::after {
  border: none;
}

.load-more-btn:active {
  opacity: 0.8;
}

/* 没有更多 */
.no-more {
  padding: 34rpx 30rpx 12rpx;
  text-align: center;
  color: #cbd5e1;
  font-size: 26rpx;
}

/* 响应式设计 */
@media (min-width: 768px) {
  .notification-item {
    max-width: 600rpx;
  }

  .tabs,
  .notifications-list,
  .empty-state,
  .loading-state {
    max-width: 648rpx;
    margin-left: auto;
    margin-right: auto;
  }
}
