<!--通知页面-->
<view class="notifications-container">
  <!-- 筛选选项卡 -->
  <view class="tabs">
    <view
      class="tab-item {{activeTab === 'all' ? 'active' : ''}}"
      bindtap="handleTabChange"
      data-tab="all"
    >
      全部
    </view>
    <view
      class="tab-item {{activeTab === 'false' ? 'active' : ''}}"
      bindtap="handleTabChange"
      data-tab="false"
    >
      未读 <text class="tab-badge" wx:if="{{unreadCount > 0}}">{{unreadCount}}</text>
    </view>
    <view
      class="tab-item {{activeTab === 'true' ? 'active' : ''}}"
      bindtap="handleTabChange"
      data-tab="true"
    >
      已读
    </view>
    <view
      class="tab-item tab-action {{unreadCount > 0 ? '' : 'disabled'}}"
      catchtap="handleMarkAllAsRead"
    >
      全部已读
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && displayedNotifications.length === 0}}">
    <view class="empty-icon">📬</view>
    <text class="empty-text">{{activeTab === 'false' ? '暂无未读通知' : activeTab === 'true' ? '暂无已读通知' : '暂无通知'}}</text>
    <text class="empty-desc">{{activeTab === 'false' ? '没有未读通知，可切回全部查看历史通知' : '你的通知会在这里显示'}}</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading && displayedNotifications.length === 0}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 通知列表 -->
  <view class="notifications-list">
    <view
      class="notification-item {{item.isRead ? 'read' : 'unread'}}"
      wx:for="{{displayedNotifications}}"
      wx:key="_id"
      bindtap="handleNotificationTap"
      data-id="{{item._id}}"
      data-index="{{index}}"
    >
      <!-- 通知内容 -->
      <view class="notification-content">
        <!-- 标题和操作 -->
        <view class="notification-header">
          <view class="notification-title">
            <text class="type-icon" style="color: {{item.typeColor}}">{{item.typeIcon}}</text>
            <text class="type-label">{{item.typeLabel}}</text>
          </view>
          <view class="notification-actions">
            <text
              class="action-btn delete-btn"
              catchtap="handleDelete"
              data-id="{{item._id}}"
            >
              ✕
            </text>
          </view>
        </view>

        <!-- 通知消息 -->
        <view class="notification-message">{{item.content}}</view>

        <!-- 发送者信息（如果有）-->
        <view class="sender-info" wx:if="{{item.senderName}}">
          <image wx:if="{{item.senderAvatar}}" class="sender-avatar" src="{{item.senderAvatar}}" mode="aspectFill" catchtap="handleSenderAvatarTap" data-user-id="{{item.senderUserId}}" data-period-id="{{item.periodIdValue}}"></image>
          <view wx:elif="{{item.senderAvatarText}}" class="sender-avatar sender-avatar-fallback sender-avatar-text" style="background: {{item.senderAvatarColor || '#4a90e2'}}" catchtap="handleSenderAvatarTap" data-user-id="{{item.senderUserId}}" data-period-id="{{item.periodIdValue}}">
            {{item.senderAvatarText}}
          </view>
          <view wx:else class="sender-avatar sender-avatar-fallback" style="background: {{item.senderAvatarColor || '#4a90e2'}}" catchtap="handleSenderAvatarTap" data-user-id="{{item.senderUserId}}" data-period-id="{{item.periodIdValue}}">
            {{item.senderInitial}}
          </view>
          <text class="sender-name">{{item.senderName}}</text>
        </view>

        <!-- 时间和状态 -->
        <view class="notification-footer">
          <view class="notification-footer-left">
            <view class="notification-status-dot" wx:if="{{!item.isRead}}"></view>
            <text class="time">{{item.formattedTime}}</text>
          </view>
          <text
            class="notification-action-hint"
            wx:if="{{item.actionText}}"
            catchtap="handleNotificationActionTap"
            data-id="{{item._id}}"
            data-index="{{index}}"
          >{{item.actionText}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 分页加载 -->
  <view class="pagination" wx:if="{{hasMore && displayedNotifications.length > 0}}">
    <button class="load-more-btn" bindtap="handleLoadMore" loading="{{loading}}">
      加载更多
    </button>
  </view>

  <!-- 没有更多内容 -->
  <view class="no-more" wx:if="{{!hasMore && displayedNotifications.length > 0}}">
    <text>没有更多通知了</text>
  </view>
</view>

<podcast-player-bar />
