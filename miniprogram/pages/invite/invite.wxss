.invite-page {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 加载 */
.loading-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.loading-text {
  font-size: 28rpx;
  color: #999;
  margin-top: 20rpx;
}

/* 封面 */
.cover-section {
  position: relative;
  width: 100%;
  height: 520rpx;
  overflow: hidden;
}
.cover-image {
  width: 100%;
  height: 100%;
}
.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-icon {
  font-size: 120rpx;
}
.cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 40rpx 48rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.55));
}
.brand-name {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 12rpx;
}
.period-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.2;
}
.period-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 8rpx;
}

/* 期次信息 */
.info-section {
  background: #fff;
  margin: 24rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 32rpx 36rpx;
}
.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.info-item:last-child {
  margin-bottom: 0;
}
.info-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}
.info-text {
  font-size: 28rpx;
  color: #333;
}

/* 邀请人 */
.inviter-section {
  background: #fff;
  margin: 16rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 28rpx 36rpx;
  display: flex;
  align-items: center;
}
.inviter-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #eee;
}
.inviter-avatar-emoji {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 36rpx;
}
.inviter-text {
  font-size: 28rpx;
  color: #555;
  flex: 1;
}

/* 价格 */
.price-section {
  background: #fff;
  margin: 16rpx 24rpx 0;
  border-radius: 16rpx;
  padding: 28rpx 36rpx;
  display: flex;
  align-items: baseline;
}
.price-current {
  font-size: 52rpx;
  font-weight: bold;
  color: #e74c3c;
}
.price-original {
  font-size: 28rpx;
  color: #bbb;
  text-decoration: line-through;
  margin-left: 16rpx;
}
.price-free {
  font-size: 36rpx;
  font-weight: bold;
  color: #27ae60;
}

/* 操作按钮 */
.action-section {
  padding: 40rpx 24rpx 60rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.btn-enroll {
  background: var(--theme-primary);
  border-radius: 48rpx;
  padding: 32rpx 0;
  text-align: center;
}
.btn-enroll text {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}
.btn-enrolled {
  background: #27ae60;
  border-radius: 48rpx;
  padding: 32rpx 0;
  text-align: center;
}
.btn-enrolled text {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
}
.btn-disabled {
  background: #ccc;
  border-radius: 48rpx;
  padding: 32rpx 0;
  text-align: center;
}
.btn-disabled text {
  font-size: 34rpx;
  color: #fff;
}
.btn-next {
  background: #fff;
  border: 2rpx solid var(--theme-primary);
  border-radius: 48rpx;
  padding: 28rpx 0;
  text-align: center;
}
.btn-next text {
  font-size: 30rpx;
  color: var(--theme-primary);
}

/* 错误 */
.error-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}
.error-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}
.error-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}
