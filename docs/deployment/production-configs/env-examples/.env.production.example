# 晨读营生产环境配置示例
# 注意：实际部署时需要替换为真实的敏感信息
# 绝对不要将真实的 .env.production 提交到 git

################################################################################
# Node.js 环境
################################################################################
NODE_ENV=production
PORT=3000

################################################################################
# MongoDB 数据库
################################################################################
MONGODB_URI=mongodb://admin:PASSWORD@127.0.0.1:27017/morning_reading?authSource=admin
MONGO_USER=admin
MONGO_PASSWORD=YOUR_MONGODB_PASSWORD_HERE

################################################################################
# MySQL 数据库
################################################################################
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=morning_user
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD_HERE
MYSQL_DATABASE=morning_reading
MYSQL_ROOT_PASSWORD=YOUR_MYSQL_ROOT_PASSWORD_HERE

################################################################################
# Redis 缓存
################################################################################
REDIS_HOST=127.0.0.1
REDIS_PORT=26379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE

################################################################################
# 微信小程序配置
################################################################################
WECHAT_APPID=wx2b9a3c1d5e4195f8
WECHAT_APP_SECRET=YOUR_WECHAT_APP_SECRET_HERE

################################################################################
# 管理后台和 API 配置
################################################################################
ADMIN_URL=https://wx.shubai01.com
API_BASE_URL=https://wx.shubai01.com/api/v1
FRONTEND_URL=https://wx.shubai01.com

################################################################################
# JWT 令牌配置
################################################################################
JWT_SECRET=YOUR_JWT_SECRET_KEY_HERE
JWT_EXPIRE=7d

################################################################################
# 日志配置
################################################################################
LOG_LEVEL=info
LOG_PATH=/var/www/morning-reading/backend/logs

################################################################################
# 邮件配置（可选）
################################################################################
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-email-password

################################################################################
# 其他配置
################################################################################
SESSION_SECRET=YOUR_SESSION_SECRET_HERE
